# Blog: API de Notion (se usan en build time para generar las páginas del blog)
NOTION_API_KEY=secret_xxx
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Endpoints de formularios (se incrustan en el HTML durante el build)
PUBLIC_CHANCHA_ENDPOINT=https://...
PUBLIC_FORM_ENDPOINT=https://...

# PostHog (Settings → Project → Project API Key)
PUBLIC_POSTHOG_KEY=phc_xxx
PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
