---
// Login del curso para suscriptores: el visitante entra con su cuenta de la
// app de Pablo (Supabase Auth) y solo con plan pago se desbloquean las
// sesiones. Reemplaza al viejo CursoLeadModal (nombre + correo a Brevo).
// Abrir con window.abrirCursoLoginModal(destinoOpcional).
---

<div
  id="curso-login-modal"
  class="cl-overlay"
  aria-hidden="true"
  role="dialog"
  aria-modal="true"
  aria-label="Inicia sesión para ver el curso"
>
  <div class="cl-card">
    <button class="cl-close" id="cl-close" aria-label="Cerrar">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>

    <!-- ── Paso 1: login con la cuenta de Pablo ── -->
    <div class="cl-paso" id="cl-paso-login">
      <img
        class="cl-mascota"
        src="/onboarding/images/pablo/pablo-anotando.webp"
        alt=""
        width="110"
        height="110"
        loading="lazy"
      />
      <h3 class="cl-titulo">Inicia sesión para ver el curso</h3>
      <p class="cl-sub">
        <strong>Finanzas de un Futuro Millonario</strong> está incluido con tu
        suscripción de Pablo. Entra con la misma cuenta que usas en la app.
      </p>

      <form id="cl-form" novalidate>
        <label class="cl-label" for="cl-email">Tu correo</label>
        <input
          class="cl-input"
          id="cl-email"
          name="email"
          type="email"
          placeholder="tucorreo@ejemplo.com"
          autocomplete="email"
          maxlength="120"
          required
        />
        <label class="cl-label" for="cl-password">Tu contraseña</label>
        <input
          class="cl-input"
          id="cl-password"
          name="password"
          type="password"
          placeholder="Tu contraseña de Pablo"
          autocomplete="current-password"
          maxlength="72"
          required
        />
        <p class="cl-error" id="cl-error" hidden></p>
        <button class="cl-cta" id="cl-enviar" type="submit">Entrar al curso</button>
      </form>
      <p class="cl-legal">
        ¿Aún no tienes Pablo? <a href="/#planes">Elige tu plan</a> y desbloquea el curso.
      </p>
    </div>

    <!-- ── Paso 2: cuenta sin suscripción ── -->
    <div class="cl-paso" id="cl-paso-sinsub" hidden>
      <img
        class="cl-mascota"
        src="/onboarding/images/pablo/pablo-logo.png"
        alt=""
        width="110"
        height="110"
        loading="lazy"
      />
      <h3 class="cl-titulo">Te falta desbloquear a Pablo</h3>
      <p class="cl-sub cl-sub--exito">
        Tu cuenta <strong id="cl-email-sinsub"></strong> todavía no tiene una
        suscripción activa. Elige un plan y el curso se desbloquea solito.
      </p>
      <a class="cl-cta cl-cta--link" href="/#planes">Ver los planes →</a>
    </div>
  </div>
</div>

<style>
  .cl-overlay {
    position: fixed;
    inset: 0;
    z-index: 1000;
    background: rgba(43, 44, 100, 0.5);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease;
  }

  .cl-overlay.is-open {
    opacity: 1;
    pointer-events: all;
  }

  .cl-card {
    position: relative;
    background: #fff;
    border-radius: 24px;
    width: 100%;
    max-width: 440px;
    max-height: 92vh;
    overflow-y: auto;
    padding: 32px 28px 26px;
    box-shadow: 0 24px 80px rgba(43, 44, 100, 0.22);
    transform: translateY(14px) scale(0.98);
    opacity: 0;
    transition:
      transform 0.28s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.25s ease;
  }

  .cl-overlay.is-open .cl-card {
    transform: translateY(0) scale(1);
    opacity: 1;
  }

  .cl-close {
    position: absolute;
    top: 12px;
    right: 12px;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: rgba(238, 234, 250, 0.9);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-heading);
    transition: background 0.15s, transform 0.15s;
  }

  .cl-close:hover {
    background: #e0dbf5;
    transform: scale(1.08);
  }

  .cl-paso {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .cl-paso[hidden] {
    display: none;
  }

  .cl-mascota {
    width: 110px;
    height: auto;
    margin-bottom: 6px;
    border-radius: 18px;
  }

  .cl-titulo {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    color: var(--color-heading);
    line-height: 1.25;
    margin-bottom: 8px;
  }

  .cl-sub {
    color: var(--color-body);
    font-size: 0.95rem;
    line-height: 1.55;
    margin-bottom: 20px;
    max-width: 340px;
  }

  .cl-sub--exito {
    max-width: 100%;
  }

  #cl-form {
    width: 100%;
    display: flex;
    flex-direction: column;
    text-align: left;
  }

  .cl-label {
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--color-heading);
    margin: 0 0 6px 4px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .cl-input {
    width: 100%;
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-heading);
    background: #fff;
    border: 2px solid #e5e5e5;
    border-radius: 16px;
    padding: 13px 16px;
    margin-bottom: 14px;
    outline: none;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .cl-input::placeholder {
    color: #b3b2c9;
  }

  .cl-input:focus {
    border-color: var(--color-amber);
    box-shadow: 0 0 0 3px rgba(245, 166, 35, 0.18);
  }

  .cl-error {
    color: #d64545;
    font-size: 0.85rem;
    font-weight: 600;
    margin: -4px 4px 10px;
  }

  /* CTA estilo Duolingo: reborde inferior 3D, uppercase (mismo look del hero) */
  .cl-cta {
    width: 100%;
    border: none;
    cursor: pointer;
    border-radius: 16px;
    padding: 15px 22px;
    margin-top: 4px;
    font-family: var(--font-body);
    font-weight: 800;
    font-size: 15px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    background: var(--color-amber);
    color: #2b2c64;
    box-shadow: 0 4px 0 0 #c9820a;
    transition: transform 0.12s ease, box-shadow 0.12s ease, opacity 0.15s;
  }

  .cl-cta:hover {
    transform: translateY(-1px);
    box-shadow: 0 5px 0 0 #c9820a;
  }

  .cl-cta:active {
    transform: translateY(3px);
    box-shadow: 0 1px 0 0 #c9820a;
  }

  .cl-cta:disabled {
    opacity: 0.65;
    cursor: wait;
    transform: none;
  }

  .cl-cta--link {
    display: block;
    text-align: center;
  }

  .cl-legal {
    font-size: 0.75rem;
    color: var(--color-secondary);
    margin-top: 14px;
  }

  .cl-legal a {
    color: var(--color-heading);
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  @media (max-width: 480px) {
    .cl-card {
      padding: 28px 20px 22px;
      border-radius: 20px;
    }
  }
</style>

<script>
  import { CURSO, SESIONES } from "../lib/cursos";
  import { loginCurso, verificarAccesoCurso, emailSesionCurso } from "../lib/cursoAcceso";

  const overlay = document.getElementById("curso-login-modal");
  const closeBtn = document.getElementById("cl-close");
  const form = document.getElementById("cl-form") as HTMLFormElement | null;
  const inputEmail = document.getElementById("cl-email") as HTMLInputElement | null;
  const inputPassword = document.getElementById("cl-password") as HTMLInputElement | null;
  const errorEl = document.getElementById("cl-error");
  const btnEnviar = document.getElementById("cl-enviar") as HTMLButtonElement | null;
  const pasoLogin = document.getElementById("cl-paso-login");
  const pasoSinSub = document.getElementById("cl-paso-sinsub");
  const emailSinSub = document.getElementById("cl-email-sinsub");

  const primeraSesion = `/cursos/${CURSO.slug}/${SESIONES[0].slug}`;
  // A dónde seguir tras iniciar sesión (la sesión que intentó abrir).
  let destino = primeraSesion;

  const capture = (evento: string, props?: Record<string, unknown>) => {
    try {
      (window as any).posthog?.capture(evento, props);
    } catch {
      /* PostHog puede no estar cargado */
    }
  };

  function abrir(destinoDeseado?: string) {
    if (destinoDeseado) destino = destinoDeseado;
    overlay?.classList.add("is-open");
    overlay?.setAttribute("aria-hidden", "false");
    document.body.style.overflow = "hidden";
    capture("curso_login_abierto", { curso: CURSO.slug });
  }

  function cerrar() {
    overlay?.classList.remove("is-open");
    overlay?.setAttribute("aria-hidden", "true");
    document.body.style.overflow = "";
  }

  (window as any).abrirCursoLoginModal = abrir;

  closeBtn?.addEventListener("click", cerrar);
  overlay?.addEventListener("click", (e) => {
    if (e.target === overlay) cerrar();
  });
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && overlay?.classList.contains("is-open")) cerrar();
  });

  // Prefill del correo si hay una sesión previa (aunque haya expirado).
  const previo = emailSesionCurso();
  if (previo && inputEmail) inputEmail.value = previo;

  function mostrarError(msg: string) {
    if (!errorEl) return;
    errorEl.textContent = msg;
    errorEl.hidden = false;
  }

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (errorEl) errorEl.hidden = true;

    const email = inputEmail?.value.trim() ?? "";
    const password = inputPassword?.value ?? "";
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/.test(email))
      return mostrarError("Ese correo no se ve bien, ¿lo revisas?");
    if (!password) return mostrarError("Escribe tu contraseña de Pablo.");

    if (btnEnviar) {
      btnEnviar.disabled = true;
      btnEnviar.textContent = "Entrando…";
    }

    try {
      const login = await loginCurso(email, password);
      if (!login.ok) return mostrarError(login.error ?? "No pudimos iniciar sesión.");

      const acceso = await verificarAccesoCurso(CURSO.slug);
      if (!acceso) return mostrarError("No pudimos verificar tu cuenta, intenta de nuevo.");

      if (!acceso.acceso) {
        // Cuenta válida pero sin plan pago: invitación a los planes.
        if (emailSinSub) emailSinSub.textContent = email;
        if (pasoLogin) pasoLogin.hidden = true;
        if (pasoSinSub) pasoSinSub.hidden = false;
        capture("curso_login_sin_sub", { curso: CURSO.slug, plan: acceso.plan });
        return;
      }

      capture("curso_login_exitoso", {
        curso: CURSO.slug,
        plan: acceso.plan,
        $set: { curso_finanzas_acceso: true },
      });
      window.location.href = destino;
    } catch {
      mostrarError("Algo falló, intenta de nuevo en un ratito.");
    } finally {
      if (btnEnviar) {
        btnEnviar.disabled = false;
        btnEnviar.textContent = "Entrar al curso";
      }
    }
  });
</script>
