---
import { Image } from 'astro:assets';
import logoImg from '../assets/Logo.png';
---

<header class="navbar">
  <div class="container navbar__inner">

    <!-- Logo -->
    <a href="/" class="navbar__logo">
      <Image src={logoImg} alt="Pablo logo" class="logo-img" width={36} height={36} />
      <span class="logo-text">Pablo</span>
    </a>

    <!-- Desktop Nav -->
    <nav class="navbar__nav">

      <!-- Conoce a Pablo -->
      <div class="nav-item">
        <a href="/#como-funciona" class="nav-trigger">
          Conoce a Pablo <span class="nav-arrow">▾</span>
        </a>
        <div class="dropdown">
          <a href="/#hero" class="dropdown-item">
            <span class="di-label">¿Qué es Pablo?</span>
            <span class="di-desc">Tu asistente financiero en WhatsApp</span>
          </a>
          <a href="/#como-funciona" class="dropdown-item">
            <span class="di-label">Cómo funciona</span>
            <span class="di-desc">Registra gastos, crea metas y más</span>
          </a>
          <a href="/#faq" class="dropdown-item">
            <span class="di-label">Preguntas frecuentes</span>
            <span class="di-desc">Resolvemos tus dudas</span>
          </a>
        </div>
      </div>

      <!-- Planes -->
      <div class="nav-item">
        <a href="/#planes" class="nav-trigger">
          Planes <span class="nav-arrow">▾</span>
        </a>
        <div class="dropdown">
          <a href="/#planes" class="dropdown-item">
            <span class="di-label">Plan Semanal <span class="di-badge">S/.7/sem</span></span>
            <span class="di-desc">Prueba Pablo esta semana</span>
          </a>
          <a href="/#planes" class="dropdown-item">
            <span class="di-label">Plan Mensual <span class="di-badge">S/.20/mes</span></span>
            <span class="di-desc">3 días gratis de prueba</span>
          </a>
          <a href="/#planes" class="dropdown-item">
            <span class="di-label">Plan Anual <span class="di-badge di-badge--featured">S/.200/año</span></span>
            <span class="di-desc">Ahorra 2 meses · 16% OFF</span>
          </a>
        </div>
      </div>

      <!-- Promos -->
      <div class="nav-item">
        <a href="/promos" class="nav-trigger">
          Promos <span class="nav-arrow">▾</span>
        </a>
        <div class="dropdown">
          <a href="/trabaja-con-nosotros" class="dropdown-item">
            <span class="di-label">Crea con Pablo y gana</span>
            <span class="di-desc">Monetiza tu audiencia con nosotros</span>
          </a>
          <div class="dropdown-item dropdown-item--disabled">
            <span class="di-label">Pablo Points <span class="di-badge di-badge--soon">Próximamente</span></span>
            <span class="di-desc">Acumula puntos y gana recompensas</span>
          </div>
          <a href="/pablo-pone-para-la-chancha" class="dropdown-item">
            <span class="di-label">Pablo pone para la chancha</span>
            <span class="di-desc">Ahorra con un objetivo en mente</span>
          </a>
        </div>
      </div>

      <!-- Recursos: dropdown simplificado — solo botones directos -->
      <div class="nav-item">
        <a href="/blog" class="nav-trigger">
          Recursos <span class="nav-arrow">▾</span>
        </a>
        <div class="dropdown">
          <a href="/blog" class="dropdown-item">
            <span class="di-label">Blog</span>
          </a>
          <a href="/cursos" class="dropdown-item">
            <span class="di-label">Cursos</span>
          </a>
          <span class="dropdown-item dropdown-item--disabled">
            <span class="di-label">Tutoriales <span class="di-badge di-badge--soon">Próximamente</span></span>
          </span>
        </div>
      </div>

    </nav>

    <button class="hamburger" id="hamburger-btn" aria-label="Abrir menú" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div class="navbar__mobile-menu" id="mobile-menu" aria-hidden="true">

    <!-- Conoce a Pablo accordion -->
    <div class="mob-section">
      <button class="mob-section__trigger">Conoce a Pablo <span class="mob-arrow">▾</span></button>
      <div class="mob-section__body">
        <a href="/#hero" class="mob-link">¿Qué es Pablo?</a>
        <a href="/#como-funciona" class="mob-link">Cómo funciona</a>
        <a href="/#faq" class="mob-link">Preguntas frecuentes</a>
      </div>
    </div>

    <!-- Planes accordion -->
    <div class="mob-section">
      <button class="mob-section__trigger">Planes <span class="mob-arrow">▾</span></button>
      <div class="mob-section__body">
        <a href="/#planes" class="mob-link">Plan Semanal <span class="mob-badge">S/.7</span></a>
        <a href="/#planes" class="mob-link">Plan Mensual <span class="mob-badge">S/.20</span></a>
        <a href="/#planes" class="mob-link">Plan Anual <span class="mob-badge mob-badge--featured">S/.200</span></a>
      </div>
    </div>

    <!-- Promos accordion -->
    <div class="mob-section">
      <button class="mob-section__trigger">Promos <span class="mob-arrow">▾</span></button>
      <div class="mob-section__body">
        <a href="/trabaja-con-nosotros" class="mob-link">Crea con Pablo y gana</a>
        <span class="mob-link mob-link--disabled">Pablo Points <span class="mob-badge mob-badge--soon">Próximamente</span></span>
        <a href="/pablo-pone-para-la-chancha" class="mob-link">Pablo pone para la chancha</a>
      </div>
    </div>

    <!-- Recursos accordion — solo botones directos -->
    <div class="mob-section">
      <button class="mob-section__trigger">Recursos <span class="mob-arrow">▾</span></button>
      <div class="mob-section__body">
        <a href="/blog" class="mob-link">Blog</a>
        <a href="/cursos" class="mob-link">Cursos</a>
        <span class="mob-link mob-link--disabled">Tutoriales <span class="mob-badge mob-badge--soon">Próximamente</span></span>
      </div>
    </div>

  </div>
</header>

<style>
  .navbar {
    position: sticky;
    top: 0;
    z-index: 100;
    background: transparent;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    border-bottom: none;
    transition: background 0.25s ease, backdrop-filter 0.25s ease;
  }

  .navbar.scrolled {
    background: var(--bg-header);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: 0 1px 0 rgba(43, 44, 100, 0.07);
  }

  .navbar__inner {
    display: flex;
    align-items: center;
    height: 72px;
    gap: 16px;
  }

  /* La navegación se lleva el espacio restante del logo y ancla a la derecha
   * (patrón Duolingo: logo a la izquierda, opciones alineadas a la derecha) */
  .navbar__nav {
    margin-left: auto;
  }

  /* Logo */
  .navbar__logo {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }

  .logo-img {
    width: 36px;
    height: 36px;
    object-fit: contain;
    border-radius: 8px;
  }

  .logo-text {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 20px;
    color: var(--color-heading);
  }

  /* Desktop Nav */
  .navbar__nav {
    display: flex;
    align-items: center;
    gap: 4px;
    margin-left: auto;
  }

  .nav-link {
    font-weight: 500;
    font-size: 14px;
    color: var(--color-heading);
    transition: color 0.15s;
    white-space: nowrap;
    padding: 8px 12px;
  }

  .nav-link:hover {
    color: var(--color-amber);
  }

  /* Nav item with dropdown */
  .nav-item {
    position: relative;
  }

  .nav-trigger {
    display: flex;
    align-items: center;
    gap: 5px;
    padding: 8px 12px;
    font-size: 14px;
    font-weight: 500;
    font-family: var(--font-body);
    color: var(--color-heading);
    background: none;
    border: none;
    cursor: pointer;
    white-space: nowrap;
    border-radius: 8px;
    transition: color 0.15s, background 0.15s;
  }

  .nav-trigger:hover {
    color: var(--color-amber);
    background: rgba(43, 44, 100, 0.04);
  }

  .nav-arrow {
    font-size: 10px;
    transition: transform 0.2s ease;
    display: inline-block;
    opacity: 0.6;
  }

  .nav-item:hover .nav-arrow {
    transform: rotate(-180deg);
  }

  /* Dropdown panel */
  .dropdown {
    position: absolute;
    top: calc(100% + 6px);
    left: 50%;
    transform: translateX(-50%) translateY(-6px);
    min-width: 240px;
    background: white;
    border: 1px solid rgba(43, 44, 100, 0.1);
    border-radius: 14px;
    box-shadow: 0 8px 32px rgba(43, 44, 100, 0.12);
    padding: 8px;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.18s ease, transform 0.18s ease, visibility 0.18s;
    z-index: 200;
  }

  .nav-item:hover .dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }

  /* Wide dropdown for Recursos */
  .dropdown--wide {
    min-width: 480px;
    display: flex;
    gap: 0;
    left: auto;
    right: 0;
    transform: translateY(-6px);
  }

  .nav-item:hover .dropdown--wide {
    transform: translateY(0);
  }

  .dropdown-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 4px;
  }

  .dropdown-col--border {
    border-left: 1px solid rgba(43, 44, 100, 0.08);
  }

  .dropdown-col-label {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--color-secondary);
    padding: 6px 10px 4px;
  }

  .dropdown-col-label--mt {
    margin-top: 8px;
  }

  /* Dropdown items */
  .dropdown-item {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 8px 10px;
    border-radius: 8px;
    text-decoration: none;
    color: inherit;
    transition: background 0.12s;
    cursor: pointer;
  }

  a.dropdown-item:hover {
    background: rgba(43, 44, 100, 0.05);
  }

  .dropdown-item--disabled {
    opacity: 0.5;
    cursor: default;
  }

  .dropdown-item--compact {
    padding: 6px 10px;
  }

  .di-label {
    font-size: 13.5px;
    font-weight: 600;
    color: var(--color-heading);
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
  }

  .di-desc {
    font-size: 12px;
    color: var(--color-secondary);
    line-height: 1.4;
  }

  .di-badge {
    font-size: 11px;
    font-weight: 600;
    padding: 2px 7px;
    border-radius: 20px;
    background: rgba(43, 44, 100, 0.07);
    color: var(--color-heading);
  }

  .di-badge--featured {
    background: #FEF3DA;
    color: #875A00;
    border: 1px solid #F5C970;
  }

  .di-badge--soon {
    background: rgba(43, 44, 100, 0.06);
    color: var(--color-secondary);
  }

  .dropdown-viewall {
    display: inline-block;
    font-size: 12px;
    font-weight: 600;
    color: var(--color-amber);
    padding: 6px 10px;
    text-decoration: none;
    transition: opacity 0.15s;
  }

  .dropdown-viewall:hover {
    opacity: 0.75;
  }

  /* CTA */
  .navbar__actions {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
  }

  .btn-sm {
    padding: 9px 20px !important;
    font-size: 14px !important;
  }

  /* Hamburger */
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    padding: 6px;
    margin-left: auto;
    cursor: pointer;
    background: none;
    border: none;
  }

  .hamburger span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--color-heading);
    border-radius: 2px;
    transition: all 0.3s ease;
  }

  .hamburger.is-open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .hamburger.is-open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .hamburger.is-open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* Mobile menu */
  .navbar__mobile-menu {
    display: none;
    flex-direction: column;
    padding: 8px 16px 20px;
    background: var(--bg-header);
    border-top: 1px solid rgba(43, 44, 100, 0.06);
    gap: 2px;
  }

  .navbar__mobile-menu.is-open {
    display: flex;
  }

  /* Mobile accordion section */
  .mob-section {
    border-bottom: 1px solid rgba(43, 44, 100, 0.06);
  }

  .mob-section__trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 12px 4px;
    font-size: 15px;
    font-weight: 600;
    font-family: var(--font-body);
    color: var(--color-heading);
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
  }

  .mob-arrow {
    font-size: 11px;
    transition: transform 0.2s;
    opacity: 0.5;
  }

  .mob-section.is-open .mob-arrow {
    transform: rotate(-180deg);
  }

  .mob-section__body {
    display: none;
    flex-direction: column;
    padding: 0 4px 10px 12px;
    gap: 2px;
  }

  .mob-section.is-open .mob-section__body {
    display: flex;
  }

  .mob-link {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 4px;
    font-size: 14px;
    color: var(--color-body);
    text-decoration: none;
    transition: color 0.15s;
  }

  a.mob-link:hover {
    color: var(--color-heading);
  }

  .mob-link--disabled {
    opacity: 0.5;
    cursor: default;
  }

  .mob-link--sub {
    font-size: 13px;
    padding-left: 0;
  }

  .mob-link--viewall {
    font-size: 13px;
    font-weight: 600;
    color: var(--color-amber);
  }

  .mob-link--standalone {
    padding: 12px 4px;
    font-size: 15px;
    font-weight: 500;
    color: var(--color-heading);
    border-top: 1px solid rgba(43, 44, 100, 0.06);
    margin-top: 4px;
  }

  .mob-section-label {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--color-secondary);
    padding: 8px 4px 2px;
  }

  .mob-badge {
    font-size: 11px;
    font-weight: 600;
    padding: 2px 7px;
    border-radius: 20px;
    background: rgba(43, 44, 100, 0.07);
    color: var(--color-heading);
  }

  .mob-badge--featured {
    background: #FEF3DA;
    color: #875A00;
  }

  .mob-badge--soon {
    background: rgba(43, 44, 100, 0.06);
    color: var(--color-secondary);
  }

  .mobile-actions {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding-top: 12px;
  }

  .mobile-actions .btn-primary {
    text-align: center;
    justify-content: center;
    width: 100%;
    padding: 12px 20px;
    font-size: 15px;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .navbar__nav { gap: 2px; }
    .nav-trigger, .nav-link { font-size: 13px; padding: 8px 8px; }
    .btn-sm { padding: 9px 14px !important; font-size: 13px !important; }
  }

  @media (max-width: 860px) {
    .navbar__nav,
    .navbar__actions {
      display: none;
    }

    .hamburger {
      display: flex;
    }
  }
</style>

<script>
  // Scroll behavior
  const navbar = document.querySelector('.navbar');
  function updateNavbar() {
    navbar?.classList.toggle('scrolled', window.scrollY > 10);
  }
  window.addEventListener('scroll', updateNavbar, { passive: true });
  updateNavbar();

  // Hamburger
  const hamburger = document.getElementById('hamburger-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  hamburger?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.toggle('is-open');
    hamburger.classList.toggle('is-open');
    hamburger.setAttribute('aria-expanded', String(isOpen));
    mobileMenu?.setAttribute('aria-hidden', String(!isOpen));
  });

  // Mobile accordion
  document.querySelectorAll('.mob-section__trigger').forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const section = trigger.closest('.mob-section');
      section?.classList.toggle('is-open');
    });
  });

  // Close mobile menu when a link is clicked
  mobileMenu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      mobileMenu.classList.remove('is-open');
      hamburger?.classList.remove('is-open');
      hamburger?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
