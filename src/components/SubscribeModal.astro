---
import { Image } from 'astro:assets';
import logoModal from '../assets/logodelmodal.png';
import iconPremiumRaw from '../assets/icon-premium.svg?raw';
---

<div id="subscribe-modal" class="smodal-overlay" aria-hidden="true">
  <div
    class="smodal-container"
    role="dialog"
    aria-modal="true"
    aria-labelledby="smodal-title"
  >

    <!-- Body -->
    <div class="smodal-body">
      <button class="smodal-back" id="smodal-close-btn">← Salir</button>

      <!-- Mascot -->
      <div class="smodal-mascot">
        <Image src={logoModal} alt="Pablo mascot" class="smodal-mascot-img" width={100} height={100} />
      </div>

      <h2 id="smodal-title" class="smodal-title">¡Hola! Soy Pablo</h2>
      <p class="smodal-subtitle">Tu asistente financiero en WhatsApp</p>

      <!-- Features card -->
      <div class="smodal-card">
        <p class="smodal-card-title">Juntos podemos:</p>
        <ul class="smodal-features">
          <li>
            <!-- WhatsApp icon -->
            <span class="smodal-feat-icon smodal-feat-icon--green">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="white">
                <path
                  d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
                ></path>
              </svg>
            </span>
            <span>Organizar tus finanzas chateando por WhatsApp.</span>
          </li>
          <li>
            <!-- Chart icon -->
            <span class="smodal-feat-icon smodal-feat-icon--navy">
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="white"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <line x1="18" y1="20" x2="18" y2="10"></line><line
                  x1="12"
                  y1="20"
                  x2="12"
                  y2="4"></line>
                <line x1="6" y1="20" x2="6" y2="14"></line>
              </svg>
            </span>
            <span
              >Detectar tus "gastos hormiga" y mejorar tus hábitos financieros.</span
            >
          </li>
          <li>
            <!-- Diamond / Premium icon -->
            <span class="smodal-feat-icon smodal-feat-icon--amber">
              <span class="smodal-icon-premium" set:html={iconPremiumRaw}></span>
            </span>
            <span
              >Si activas Premium, podremos automatizar tus registros y mucho
              más.</span
            >
          </li>
        </ul>
      </div>

      <!-- Info notice -->
      <div class="smodal-notice">
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <circle cx="12" cy="12" r="10"></circle><line
            x1="12"
            y1="8"
            x2="12"
            y2="12"></line>
          <line x1="12" y1="16" x2="12.01" y2="16"></line>
        </svg>
        <p>
          Ten en cuenta que <strong
            >necesitas tener un número de WhatsApp</strong
          > para registrarte y hablar con Pablo.
        </p>
      </div>

      <!-- Checkboxes -->
      <div class="smodal-checks">
        <label class="smodal-check-label">
          <input
            type="checkbox"
            id="smodal-check-terms"
            class="smodal-checkbox"
          />
          <span
            >Acepto los <a href="/terminos" class="smodal-link" target="_blank"
              >Términos y Condiciones de servicio</a
            >.</span
          >
        </label>
        <label class="smodal-check-label">
          <input
            type="checkbox"
            id="smodal-check-privacy"
            class="smodal-checkbox"
          />
          <span
            >Acepto las <a href="/privacidad" class="smodal-link" target="_blank"
              >Políticas de Privacidad</a
            > de Pablo.</span
          >
        </label>
      </div>

      <!-- CTA Button -->
      <div id="smodal-cta-area" class="smodal-cta-area">
        <!-- Disabled placeholder until both checks are marked -->
        <button id="smodal-register-btn" class="smodal-register-btn" disabled>
          Empezar Registro <span class="btn-arrow">→</span>
        </button>
      </div>
    </div>
  </div>
</div>

<style>
  /* Overlay */
  .smodal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.45);
    backdrop-filter: blur(4px);
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease;
  }

  .smodal-overlay.is-open {
    opacity: 1;
    pointer-events: all;
  }

  /* Container */
  .smodal-container {
    background: #f0edf7;
    width: 100%;
    max-width: 420px;
    max-height: 92vh;
    overflow-y: auto;
    border-radius: 0;
    display: flex;
    flex-direction: column;
    transform: translateY(24px);
    transition: transform 0.3s ease;
  }

  .smodal-overlay.is-open .smodal-container {
    transform: translateY(0);
  }

  /* Header */
  .smodal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px;
    background: #f0edf7;
    border-bottom: 1px solid rgba(43, 44, 100, 0.08);
    position: sticky;
    top: 0;
    z-index: 2;
  }

  .smodal-logo {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .smodal-logo-img {
    width: 32px;
    height: 32px;
    object-fit: contain;
    border-radius: 8px;
  }

  .smodal-logo-text {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 18px;
    color: var(--color-heading);
  }

  .smodal-hamburger {
    display: flex;
    flex-direction: column;
    gap: 4px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .smodal-hamburger span {
    display: block;
    width: 20px;
    height: 2px;
    background: var(--color-heading);
    border-radius: 2px;
  }

  /* Body */
  .smodal-body {
    padding: 20px 24px 32px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }

  /* Back button */
  .smodal-back {
    align-self: flex-start;
    background: none;
    border: none;
    font-size: 14px;
    font-weight: 600;
    color: var(--color-heading);
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 3px;
    padding: 0;
  }

  /* Mascot */
  .smodal-mascot {
    width: 100px;
    height: 100px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .smodal-mascot-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  /* Titles */
  .smodal-title {
    font-family: var(--font-heading);
    font-size: 28px;
    font-weight: 800;
    color: var(--color-heading);
    text-align: center;
    margin: 0;
  }

  .smodal-subtitle {
    font-size: 15px;
    color: var(--color-body);
    text-align: center;
    margin: -12px 0 0;
  }

  /* Features card */
  .smodal-card {
    background: white;
    border-radius: 16px;
    padding: 20px 24px;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .smodal-card-title {
    font-weight: 700;
    font-size: 15px;
    color: var(--color-heading);
    text-align: center;
  }

  .smodal-features {
    display: flex;
    flex-direction: column;
    gap: 14px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .smodal-features li {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-size: 14px;
    color: var(--color-heading);
    line-height: 1.45;
  }

  .smodal-feat-icon {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 1px;
  }

  .smodal-feat-icon--green {
    background: #25d366;
  }
  .smodal-feat-icon--navy {
    background: #2b2c64;
  }
  .smodal-feat-icon--amber {
    background: linear-gradient(135deg, #F6B72B 0%, #FBAB21 58%, #FEA41B 100%);
  }

  .smodal-icon-premium {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
  }

  .smodal-icon-premium svg {
    width: 18px;
    height: 18px;
  }

  /* Notice */
  .smodal-notice {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 14px;
    color: var(--color-body);
    line-height: 1.5;
    width: 100%;
  }

  .smodal-notice svg {
    flex-shrink: 0;
    margin-top: 2px;
    color: var(--color-heading);
  }

  .smodal-notice strong {
    color: var(--color-heading);
  }

  /* Checkboxes */
  .smodal-checks {
    display: flex;
    flex-direction: column;
    gap: 12px;
    width: 100%;
  }

  .smodal-check-label {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 14px;
    color: var(--color-heading);
    cursor: pointer;
    line-height: 1.45;
  }

  .smodal-checkbox {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    margin-top: 1px;
    accent-color: var(--color-heading);
    cursor: pointer;
    border-radius: 4px;
  }

  .smodal-link {
    color: var(--color-heading);
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* Register button */
  .smodal-register-btn {
    width: 100%;
    padding: 18px 24px;
    border-radius: 24px;
    background: var(--gradient-cta);
    color: var(--color-navy);
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 17px;
    cursor: pointer;
    border: none;
    transition:
      opacity 0.2s,
      transform 0.2s;
  }

  .smodal-register-btn:disabled {
    opacity: 0.45;
    cursor: not-allowed;
    transform: none !important;
  }

  .smodal-register-btn:not(:disabled):hover {
    transform: scale(1.02);
  }

  /* CTA area */
  .smodal-cta-area {
    width: 100%;
  }
</style>

<script>
  // Recibe la URL de checkout (app con Flow) del botón de la card de Pricing
  let _checkoutUrl = '';

  window.openSubscribeModal = function(checkoutUrl: string = '') {
    _checkoutUrl = checkoutUrl;
    // Reset checkboxes
    (document.getElementById('smodal-check-terms') as HTMLInputElement).checked = false;
    (document.getElementById('smodal-check-privacy') as HTMLInputElement).checked = false;
    (document.getElementById('smodal-register-btn') as HTMLButtonElement).disabled = true;
    // Open modal
    const modal = document.getElementById('subscribe-modal');
    modal?.classList.add('is-open');
    modal?.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  };

  function closeSubscribeModal() {
    const modal = document.getElementById('subscribe-modal');
    modal?.classList.remove('is-open');
    modal?.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  document.getElementById('smodal-close-btn')?.addEventListener('click', closeSubscribeModal);
  document.getElementById('subscribe-modal')?.addEventListener('click', (e) => {
    if (e.target === e.currentTarget) closeSubscribeModal();
  });

  // Enable button when both checks are marked
  function updateBtn() {
    const terms   = (document.getElementById('smodal-check-terms') as HTMLInputElement)?.checked;
    const privacy = (document.getElementById('smodal-check-privacy') as HTMLInputElement)?.checked;
    const btn = document.getElementById('smodal-register-btn') as HTMLButtonElement;
    if (btn) btn.disabled = !(terms && privacy);
  }
  document.getElementById('smodal-check-terms')?.addEventListener('change', updateBtn);
  document.getElementById('smodal-check-privacy')?.addEventListener('change', updateBtn);

  // Landing en local (localhost:4321 / IP LAN) → probar contra la app local
  // (vite en localhost:8080) en vez de producción. La landing es estática,
  // así que el destino se resuelve en runtime según el hostname.
  function resolverAppUrl(url: string): string {
    try {
      const esLocal = /^(localhost|127\.0\.0\.1|192\.168\.)/.test(location.hostname);
      if (!esLocal) return url;
      const u = new URL(url);
      return 'http://localhost:8080' + u.pathname + u.search;
    } catch {
      return url;
    }
  }

  // El pago vive en la app (usapablo.app + Flow): como navegamos por JS, el
  // decorador global de <a> no aplica y el ph_did se agrega aquí a mano.
  function conPhDid(url: string): string {
    try {
      const did = (window as any).posthog?.get_distinct_id?.();
      if (!did) return url;
      const u = new URL(url);
      u.searchParams.set('ph_did', did);
      return u.toString();
    } catch {
      return url;
    }
  }

  // On click: fire Meta Pixel InitiateCheckout + ir al checkout de la app
  document.getElementById('smodal-register-btn')?.addEventListener('click', () => {
    if (_checkoutUrl) {
      // Fire Meta Pixel InitiateCheckout with correct plan value
      const plan = (window as any).planSeleccionado;
      if (typeof (window as any).fbq !== 'undefined' && plan) {
        (window as any).fbq('track', 'InitiateCheckout', {
          content_name: plan.name,
          value: plan.value,
          currency: 'PEN',
          num_items: 1,
        });
      }
      // Fire TikTok Pixel InitiateCheckout
      if (typeof (window as any).ttq !== 'undefined' && plan) {
        (window as any).ttq.track('InitiateCheckout', {
          content_name: plan.name,
          value: plan.value,
          currency: 'PEN',
        });
      }
      window.open(conPhDid(resolverAppUrl(_checkoutUrl)), '_blank');
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeSubscribeModal();
  });
</script>
