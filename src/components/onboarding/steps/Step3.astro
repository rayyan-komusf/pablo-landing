<!-- Mensaje intro 2: WhatsApp (estilo Duolingo: escenario compartido + burbuja) -->
<section class="step !pb-0" data-step="step-3" aria-label="Paso 3" aria-hidden="true">
  <div class="duo-stage flex-1 flex flex-col items-center justify-center relative w-full px-6">
    <div class="speech-bubble" aria-live="polite">
      Hoy puedes hacerlo directamente desde WhatsApp. ¿Quieres ver cómo?
    </div>
    <div class="duo-stage__pablo">
      <img
        src="/onboarding/images/pablo/pablo-wave.png"
        alt="Pablo"
        width="240"
        height="240"
        loading="lazy"
      />
    </div>
  </div>

  <footer class="duo-footer cta-footer">
    <button
      class="duo-footer__link"
      onclick="pabloGoApp('step-3')"
      aria-label="Iniciar sesión si ya eres miembro"
    >
      ¿Ya eres miembro?
    </button>
    <button class="btn-primary btn-continue" onclick="pabloNext()" aria-label="Continuar">
      Continuar
    </button>
  </footer>
</section>
