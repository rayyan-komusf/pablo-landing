<!-- Pregunta 9: meta de ahorro -->
<section class="step !pb-0" data-step="step-15" aria-label="Pregunta 9 - Meta de ahorro" aria-hidden="true">
  <div class="flex-1 flex flex-col gap-5 w-full max-w-[560px] mx-auto px-5 pb-4 max-md:px-4 max-md:gap-4 max-[360px]:px-3 max-[360px]:gap-3 overflow-y-auto [scrollbar-width:none] [&::-webkit-scrollbar]:hidden vcenter">
    <!-- Header -->
    <div class="flex flex-col gap-2.5">
      <span class="font-display font-bold text-[12px] rounded-2xl text-amber tracking-[0.08em] uppercase bg-white px-3 py-1 inline-flex items-center gap-1 w-fit shadow-soft">
        Pregunta <span class="text-navy-soft font-medium">9</span>
      </span>
      <h2 class="font-display font-bold text-[22px] max-[360px]:text-[18px] md:text-[24px] text-navy tracking-[-0.01em] leading-[1.25]">
        ¿Estás ahorrando hacia alguna meta actualmente?
      </h2>
    </div>
    <!-- Opciones -->
    <div class="flex flex-col gap-2.5" role="radiogroup" aria-label="Selecciona tu situación de ahorro">
      <button class="option-card" role="radio" aria-checked="false"
        onclick="pabloSelect(this, 'hasSavingsGoal', 'si'); setTimeout(() => pabloNext(), 1);">
        <span class="option-radio"></span>
        <span class="option-icon">🎯</span>
        <span class="option-label text-left">Sí</span>
      </button>
      <button class="option-card" role="radio" aria-checked="false"
        onclick="pabloSelect(this, 'hasSavingsGoal', 'quiero-empezar'); setTimeout(() => pabloNext(), 1);">
        <span class="option-radio"></span>
        <span class="option-icon">🌱</span>
        <span class="option-label text-left">Quiero empezar</span>
      </button>
      <button class="option-card" role="radio" aria-checked="false"
        onclick="pabloSelect(this, 'hasSavingsGoal', 'todavia-no'); setTimeout(() => pabloNext(), 1);">
        <span class="option-radio"></span>
        <span class="option-icon">⏳</span>
        <span class="option-label text-left">Todavía no</span>
      </button>
    </div>
  </div>
</section>
