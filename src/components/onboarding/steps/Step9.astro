<!-- Pregunta 4: claridad del dinero -->
<section class="step !pb-0" data-step="step-9" aria-label="Pregunta 4 - Claridad del dinero" aria-hidden="true">
  <div class="flex-1 flex flex-col gap-5 w-full max-w-[560px] mx-auto px-5 pb-4 max-md:px-4 max-md:gap-4 max-[360px]:px-3 max-[360px]:gap-3 overflow-y-auto [scrollbar-width:none] [&::-webkit-scrollbar]:hidden vcenter">
    <!-- Header -->
    <div class="flex flex-col gap-2.5">
      <span class="font-display font-bold text-[12px] rounded-2xl text-amber tracking-[0.08em] uppercase bg-white px-3 py-1 inline-flex items-center gap-1 w-fit shadow-soft">
        Pregunta <span class="text-navy-soft font-medium">4</span>
      </span>
      <h2 class="font-display font-bold text-[22px] max-[360px]:text-[18px] md:text-[24px] text-navy tracking-[-0.01em] leading-[1.25]">
        ¿Qué tan seguido sientes que no sabes a dónde se fue tu dinero?
      </h2>
    </div>
    <!-- Opciones -->
    <div class="flex flex-col gap-2.5" role="radiogroup" aria-label="Selecciona tu respuesta">
      <button class="option-card" role="radio" aria-checked="false"
        onclick="pabloSelect(this, 'moneyClarity', 'siempre'); setTimeout(() => pabloNext(), 1);">
        <span class="option-radio"></span>
        <span class="option-icon">🤯</span>
        <span class="option-label text-left">Siempre</span>
      </button>
      <button class="option-card" role="radio" aria-checked="false"
        onclick="pabloSelect(this, 'moneyClarity', 'a-veces'); setTimeout(() => pabloNext(), 1);">
        <span class="option-radio"></span>
        <span class="option-icon">🤔</span>
        <span class="option-label text-left">A veces, pero no siempre</span>
      </button>
      <button class="option-card" role="radio" aria-checked="false"
        onclick="pabloSelect(this, 'moneyClarity', 'bajo-control'); setTimeout(() => pabloNext(), 1);">
        <span class="option-radio"></span>
        <span class="option-icon">😎</span>
        <span class="option-label text-left">No, tengo todo bajo control</span>
      </button>
    </div>
  </div>
</section>
