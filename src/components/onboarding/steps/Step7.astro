<!-- Pregunta 2: experiencia presupuestando (patrón Duolingo: header Pablito + pills + Continuar) -->
<section class="step !pb-0" data-step="step-7" aria-label="Pregunta 2 - Experiencia presupuestando" aria-hidden="true">
  <div class="fuente-header">
    <div class="fuente-header__inner">
      <div class="fuente-pablo">
        <picture>
          <source srcset="/onboarding/images/pablo/pablo-anotando.webp" type="image/webp" />
          <img src="/onboarding/images/pablo/pablo-point.png" alt="" width="140" height="140" loading="lazy" />
        </picture>
      </div>
      <div class="speech-bubble speech-bubble--side">¿Es tu primera vez presupuestando?</div>
    </div>
  </div>

  <div class="fuente-body flex-1 flex flex-col w-full mx-auto px-5 max-md:px-4 overflow-y-auto [scrollbar-width:none] [&::-webkit-scrollbar]:hidden vcenter">
    <div class="fuente-grid" role="radiogroup" aria-label="Selecciona tu experiencia">
      <button class="option-card option-card--pill" role="radio" aria-checked="false"
        onclick="pabloSelect(this, 'budgetingExp', 'primera-vez')">
        <span class="option-icon">🌱</span>
        <span class="option-label text-left">Sí, es mi primera vez</span>
      </button>
      <button class="option-card option-card--pill" role="radio" aria-checked="false"
        onclick="pabloSelect(this, 'budgetingExp', 'app')">
        <span class="option-icon">📱</span>
        <span class="option-label text-left">He usado una app antes</span>
      </button>
      <button class="option-card option-card--pill" role="radio" aria-checked="false"
        onclick="pabloSelect(this, 'budgetingExp', 'excel')">
        <span class="option-icon">📊</span>
        <span class="option-label text-left">He usado una plantilla de Excel</span>
      </button>
      <button class="option-card option-card--pill" role="radio" aria-checked="false"
        onclick="pabloSelect(this, 'budgetingExp', 'manual')">
        <span class="option-icon">✍️</span>
        <span class="option-label text-left">He presupuestado manualmente</span>
      </button>
    </div>
  </div>

  <footer class="duo-footer cta-footer">
    <button class="btn-primary btn-continue disabled" disabled onclick="pabloNext()" aria-label="Continuar">
      Continuar
    </button>
  </footer>
</section>
