<!-- Antesala de preguntas (estilo Duolingo: escenario compartido + burbuja) -->
<section class="step !pb-0" data-step="step-5" aria-label="Paso 5" aria-hidden="true">
  <div class="duo-stage flex-1 flex flex-col items-center justify-center relative w-full px-6">
    <div class="speech-bubble" aria-live="polite">
      Ahora, para entender tu situación personal, solo tengo algunas preguntas 📝
    </div>
    <div class="duo-stage__pablo">
      <picture>
        <source srcset="/onboarding/images/pablo/pablo-anotando.webp" type="image/webp" />
        <img
          src="/onboarding/images/pablo/pablo-point.png"
          alt="Pablo"
          width="240"
          height="240"
          loading="lazy"
        />
      </picture>
    </div>
  </div>

  <footer class="duo-footer cta-footer">
    <button
      class="duo-footer__link"
      onclick="pabloGoApp('step-5')"
      aria-label="Iniciar sesión si ya eres miembro"
    >
      ¿Ya eres miembro?
    </button>
    <button class="btn-primary btn-continue" onclick="pabloNext()" aria-label="Continuar">
      Continuar
    </button>
  </footer>
</section>
