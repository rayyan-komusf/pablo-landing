<!-- Bienvenida estilo Duolingo: mascota centrada en el "escenario" compartido
     (.duo-stage) — la fiesta usa el mismo escenario, así el cambio de pantalla
     no se siente: Pablo queda en el mismo sitio y solo cambia la burbuja. -->
<section class="step !pb-0" data-step="entry" aria-label="Bienvenida" aria-hidden="true">
  <div class="duo-stage flex-1 flex flex-col items-center justify-center relative w-full px-6">
    <div class="speech-bubble" aria-live="polite">¡Hola, soy Pablo! 👋</div>
    <div class="duo-stage__pablo">
      <picture>
        <source srcset="/onboarding/images/pablo/pablo-saludando.webp" type="image/webp" />
        <img
          src="/onboarding/images/pablo/pablo-saludando.gif"
          alt="Pablo, tu asistente financiero, saludando"
          width="240"
          height="240"
          loading="eager"
          fetchpriority="high"
        />
      </picture>
    </div>
  </div>

  <footer class="duo-footer cta-footer">
    <button class="btn-primary btn-continue" onclick="pabloNext()" aria-label="Continuar">
      Continuar
    </button>
  </footer>
</section>
