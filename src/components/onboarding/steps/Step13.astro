<!-- Pregunta 7: otras deudas (checkbox múltiple; solo si tiene deuda) -->
<section class="step !pb-0" data-step="step-13" aria-label="Pregunta 7 - Tipos de deuda" aria-hidden="true">
  <div class="fuente-header">
    <div class="fuente-header__inner">
      <div class="fuente-pablo">
        <picture>
          <source srcset="/onboarding/images/pablo/pablo-anotando.webp" type="image/webp" />
          <img src="/onboarding/images/pablo/pablo-point.png" alt="" width="140" height="140" loading="lazy" />
        </picture>
      </div>
      <div class="speech-bubble speech-bubble--side">
        ¿Tienes alguna otra deuda? Marca todas las que apliquen
      </div>
    </div>
  </div>

  <div class="fuente-body flex-1 flex flex-col w-full mx-auto px-5 max-md:px-4 overflow-y-auto [scrollbar-width:none] [&::-webkit-scrollbar]:hidden vcenter">
    <div class="fuente-grid" role="group" aria-label="Selecciona tus tipos de deuda">
      <button class="option-card option-card--pill checkbox" role="checkbox" aria-checked="false" onclick="pabloToggle(this, 'hipoteca')">
        <span class="option-icon">🏠</span>
        <span class="option-label text-left">Hipoteca</span>
      </button>
      <button class="option-card option-card--pill checkbox" role="checkbox" aria-checked="false" onclick="pabloToggle(this, 'vehicular')">
        <span class="option-icon">🚗</span>
        <span class="option-label text-left">Préstamo vehicular</span>
      </button>
      <button class="option-card option-card--pill checkbox" role="checkbox" aria-checked="false" onclick="pabloToggle(this, 'estudiantil')">
        <span class="option-icon">🎓</span>
        <span class="option-label text-left">Préstamo estudiantil</span>
      </button>
      <button class="option-card option-card--pill checkbox" role="checkbox" aria-checked="false" onclick="pabloToggle(this, 'personal')">
        <span class="option-icon">💰</span>
        <span class="option-label text-left">Préstamo personal</span>
      </button>
    </div>
  </div>

  <footer class="duo-footer cta-footer">
    <button class="btn-primary btn-continue" onclick="pabloNext()" aria-label="Continuar">
      Continuar
    </button>
  </footer>
</section>
