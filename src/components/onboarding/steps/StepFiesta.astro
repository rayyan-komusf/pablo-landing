<!-- Celebración tras elegir objetivo: confetti + "¡Que empiece la fiesta!"
     La imagen es placeholder PNG; se reemplaza por el GIF pablo-fiesta
     cuando esté generado (mismo src, distinta extensión). -->
<section class="step !pb-0" data-step="step-fiesta" aria-label="Celebración" aria-hidden="true">
  <div class="duo-stage flex-1 flex flex-col items-center justify-center relative w-full px-6">
    <!-- Escenario del confetti (las piezas las inyecta onboarding.js) -->
    <div class="fiesta-confetti" aria-hidden="true"></div>

    <div class="speech-bubble" aria-live="polite">¡Que empiece la fiesta! 🎉</div>

    <div class="duo-stage__pablo">
      <img
        src="/onboarding/images/pablo/emotions/pablo-emocionado.png"
        alt="Pablo celebrando"
        width="240"
        height="240"
        loading="lazy"
      />
    </div>
  </div>

  <footer class="duo-footer cta-footer">
    <button class="btn-primary btn-continue" onclick="pabloNext()" aria-label="Continuar">
      Continuar
    </button>
  </footer>
</section>
