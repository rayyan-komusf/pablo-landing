<!-- Pregunta 1: edad (patrón Duolingo: header Pablito + pills + Continuar) -->
<section class="step !pb-0" data-step="step-6" aria-label="Pregunta 1 - Edad" aria-hidden="true">
  <div class="fuente-header">
    <div class="fuente-header__inner">
      <div class="fuente-pablo">
        <picture>
          <source srcset="/onboarding/images/pablo/pablo-anotando.webp" type="image/webp" />
          <img src="/onboarding/images/pablo/pablo-point.png" alt="" width="140" height="140" loading="lazy" />
        </picture>
      </div>
      <div class="speech-bubble speech-bubble--side">¿Cuántos años tienes?</div>
    </div>
  </div>

  <div class="fuente-body flex-1 flex flex-col w-full mx-auto px-5 max-md:px-4 overflow-y-auto [scrollbar-width:none] [&::-webkit-scrollbar]:hidden vcenter">
    <div class="fuente-grid" role="radiogroup" aria-label="Selecciona tu rango de edad">
      <button class="option-card option-card--pill" role="radio" aria-checked="false"
        onclick="pabloSelect(this, 'age', 'menor-18')">
        <span class="option-icon">🧒</span>
        <span class="option-label text-left">Menos de 18 años</span>
      </button>
      <button class="option-card option-card--pill" role="radio" aria-checked="false"
        onclick="pabloSelect(this, 'age', '18-24')">
        <span class="option-icon">🎓</span>
        <span class="option-label text-left">18 — 24 años</span>
      </button>
      <button class="option-card option-card--pill" role="radio" aria-checked="false"
        onclick="pabloSelect(this, 'age', '25-34')">
        <span class="option-icon">💼</span>
        <span class="option-label text-left">25 — 34 años</span>
      </button>
      <button class="option-card option-card--pill" role="radio" aria-checked="false"
        onclick="pabloSelect(this, 'age', '35-50')">
        <span class="option-icon">🏠</span>
        <span class="option-label text-left">35 — 50 años</span>
      </button>
      <button class="option-card option-card--pill" role="radio" aria-checked="false"
        onclick="pabloSelect(this, 'age', 'mayor-50')">
        <span class="option-icon">🌟</span>
        <span class="option-label text-left">Más de 50 años</span>
      </button>
    </div>
  </div>

  <footer class="duo-footer cta-footer">
    <button class="btn-primary btn-continue disabled" disabled onclick="pabloNext()" aria-label="Continuar">
      Continuar
    </button>
  </footer>
</section>
