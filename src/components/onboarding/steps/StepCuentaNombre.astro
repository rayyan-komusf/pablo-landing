<!-- Registro paso a paso (1/3): nombre. Tras elegir plan en step-18, la
     cuenta se crea aquí mismo y el usuario llega a la app ya logueado. -->
<section class="step !pb-0" data-step="step-cuenta-nombre" aria-label="Crea tu cuenta: tu nombre" aria-hidden="true">
  <div class="fuente-header">
    <div class="fuente-header__inner">
      <div class="fuente-pablo">
        <picture>
          <source srcset="/onboarding/images/pablo/pablo-anotando.webp" type="image/webp" />
          <img
            src="/onboarding/images/pablo/pablo-point.png"
            alt=""
            width="140"
            height="140"
            loading="lazy"
          />
        </picture>
      </div>
      <div class="speech-bubble speech-bubble--side">¡Genial! Creemos tu cuenta. ¿Cómo te llamas?</div>
    </div>
  </div>

  <div class="fuente-body flex-1 flex flex-col w-full mx-auto px-5 max-md:px-4 overflow-y-auto [scrollbar-width:none] [&::-webkit-scrollbar]:hidden vcenter">
    <div class="cuenta-form">
      <input
        id="cuenta-nombre"
        class="cuenta-input"
        type="text"
        inputmode="text"
        placeholder="Tu nombre"
        autocomplete="given-name"
        maxlength="60"
        oninput="pabloCuentaNombreInput(this)"
        onkeydown="if(event.key==='Enter')pabloCuentaNombreNext()"
      />
      <button type="button" class="cuenta-link" onclick="pabloCuentaYaTengo()">
        ¿Ya tienes cuenta? Inicia sesión en la app
      </button>
    </div>
  </div>

  <footer class="duo-footer cta-footer">
    <button class="btn-primary btn-continue disabled" disabled onclick="pabloCuentaNombreNext()" aria-label="Continuar">
      Continuar
    </button>
  </footer>

  <script is:inline>
    window.pabloCuentaNombreInput = function (el) {
      window.onboarding?.gateCta("step-cuenta-nombre", el.value.trim().length >= 2);
    };
    window.pabloCuentaNombreNext = function () {
      var nombre = (document.getElementById("cuenta-nombre")?.value || "").trim();
      if (nombre.length < 2) return;
      sessionStorage.setItem("pablo_cuenta_nombre", nombre);
      // Burbuja reactiva del siguiente step: saluda por nombre.
      var saludo = document.querySelector("[data-cuenta-saludo]");
      if (saludo) saludo.textContent = "¡Mucho gusto, " + nombre + "! ¿Cuál es tu correo?";
      window.pabloTrack?.("onboarding_cuenta_nombre_ok", {});
      window.pabloNext();
    };
    // Escape para quien ya tiene cuenta: flujo clásico por la app (login → checkout).
    window.pabloCuentaYaTengo = function () {
      window.pabloTrack?.("onboarding_cuenta_ya_tenia", {});
      var plan = sessionStorage.getItem("pablo_plan_elegido") || "anual";
      window.location.href = window.pabloCuentaConPhDid(
        window.pabloCuentaAppBase() + "/pricing?plan=" + plan
      );
    };
  </script>
</section>
