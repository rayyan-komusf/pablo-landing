<!-- Mensaje intro 1 (estilo Duolingo: escenario compartido + burbuja) -->
<section class="step !pb-0" data-step="step-2" aria-label="Paso 2" aria-hidden="true">
  <div class="duo-stage flex-1 flex flex-col items-center justify-center relative w-full px-6">
    <div class="speech-bubble" aria-live="polite">
      No tienes que ser millonario para liberarte del estrés financiero. Solo necesitas tomar el
      control de tus gastos y crear un plan para tu ahorro y deuda futura.
    </div>
    <div class="duo-stage__pablo">
      <img
        src="/onboarding/images/pablo/pablo-point.png"
        alt="Pablo"
        width="240"
        height="240"
        loading="lazy"
      />
    </div>
  </div>

  <footer class="duo-footer cta-footer">
    <button
      class="duo-footer__link"
      onclick="pabloGoApp('step-2')"
      aria-label="Iniciar sesión si ya eres miembro"
    >
      ¿Ya eres miembro?
    </button>
    <button class="btn-primary btn-continue" onclick="pabloNext()" aria-label="Continuar">
      Continuar
    </button>
  </footer>
</section>
