<!-- Animación "No estás solo": 100 peruanos en puntos, con leyenda clara -->
<section class="step !pb-0" data-step="step-nuevo-1" aria-label="No estás solo" aria-hidden="true">
  <div class="fuente-header">
    <div class="fuente-header__inner">
      <div class="fuente-pablo">
        <img src="/onboarding/images/pablo/emotions/pablo-tierno.png" alt="" width="140" height="140" loading="lazy" />
      </div>
      <div class="speech-bubble speech-bubble--side">No estás solo 💛</div>
    </div>
  </div>

  <div class="fuente-body flex-1 flex flex-col w-full mx-auto px-5 max-md:px-4 overflow-y-auto [scrollbar-width:none] [&::-webkit-scrollbar]:hidden vcenter">
    <div class="nuevo1-zona flex flex-col items-center gap-5 w-full">
      <p class="font-display font-bold text-[18px] text-navy text-center m-0">
        De cada <span class="text-amber">100 peruanos</span>…
      </p>
      <div class="duo-card p-4 w-full max-w-[320px] max-[360px]:max-w-[260px]">
        <div id="dotGrid" style="display: grid; grid-template-columns: repeat(10, 1fr); gap: 4px;"></div>
      </div>
      <!-- Leyenda: le da significado a cada color del grid -->
      <div class="nuevo1-leyenda">
        <div class="nuevo1-leyenda__item">
          <span class="nuevo1-swatch" style="background:#F5A623"></span>
          <span><strong>68</strong> viven preocupados por el dinero</span>
        </div>
        <div class="nuevo1-leyenda__item">
          <span class="nuevo1-swatch" style="background:#1B2A6B"></span>
          <span><strong>16</strong> logran ahorrar a fin de mes</span>
        </div>
        <div class="nuevo1-leyenda__item">
          <span class="nuevo1-swatch" style="background:#9BA8D9"></span>
          <span><strong>16</strong> van al día, sin ahorrar</span>
        </div>
      </div>
      <p class="text-[14px] font-body text-navy-soft text-center m-0">
        Pablo existe para pasarte al equipo de los que ahorran 💪
      </p>
    </div>
  </div>

  <footer class="duo-footer cta-footer">
    <button class="btn-primary btn-continue" onclick="pabloNext()" aria-label="Continuar">
      Continuar
    </button>
  </footer>
</section>

<script is:inline type="module">
  const paleta = {
    amarillo: { bg: "#FFF3D6", circle: "#F5A623" },
    "azul-oscuro": { bg: "#E0E4F5", circle: "#1B2A6B" },
    "azul-claro": { bg: "#EEF0FA", circle: "#9BA8D9" },
  };

  function pintarGrid() {
    const grid = document.getElementById("dotGrid");
    if (!grid) return;
    grid.innerHTML = "";
    const esChico = window.innerWidth <= 360;
    grid.style.gap = esChico ? "3px" : "5px";

    const celdas = [
      ...Array(68).fill("amarillo"),
      ...Array(16).fill("azul-oscuro"),
      ...Array(16).fill("azul-claro"),
    ];
    for (let i = celdas.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [celdas[i], celdas[j]] = [celdas[j], celdas[i]];
    }

    celdas.forEach((tipo) => {
      const c = paleta[tipo];
      const celda = document.createElement("div");
      celda.style.cssText = `background:${c.bg};border-radius:6px;aspect-ratio:1;display:flex;align-items:center;justify-content:center;opacity:0;transform:scale(0.4);transition:opacity 0.3s ease, transform 0.3s ease;`;
      const circulo = document.createElement("div");
      circulo.style.cssText = `width:55%;height:55%;border-radius:50%;background:${c.circle};`;
      celda.appendChild(circulo);
      grid.appendChild(celda);
    });

    const hijos = Array.from(grid.children);
    hijos
      .map((_, i) => i)
      .sort(() => Math.random() - 0.5)
      .forEach((idx, orden) => {
        setTimeout(() => {
          hijos[idx].style.opacity = "1";
          hijos[idx].style.transform = "scale(1)";
        }, orden * 14);
      });
  }

  const stepEl = document.querySelector('[data-step="step-nuevo-1"]');
  const observer = new MutationObserver(() => {
    if (stepEl?.getAttribute("aria-hidden") === "false") pintarGrid();
  });
  if (stepEl) observer.observe(stepEl, { attributes: true });
</script>
