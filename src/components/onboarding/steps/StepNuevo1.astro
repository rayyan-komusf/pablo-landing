<!-- Animación "No estás solo": grid de puntos con el 68% / 16% -->
<section class="step !pb-0" data-step="step-nuevo-1" aria-label="No estás solo" aria-hidden="true">
  <div class="flex-1 flex flex-col items-center justify-center px-6 pt-8 pb-8 max-md:pb-[32px] gap-6 max-md:px-5 max-md:pt-16">
    <h2 class="font-display font-bold text-[26px] md:text-[30px] text-navy text-center tracking-[-0.02em] leading-[1.2]">
      No estás solo 💛
    </h2>
    <div class="bg-white rounded-[24px] shadow-clay-card p-4 w-full max-w-[320px] max-[360px]:max-w-[260px]">
      <div id="dotGrid" style="display: grid; grid-template-columns: repeat(10, 1fr); gap: 4px;"></div>
    </div>
    <div class="flex flex-col gap-2 w-full max-w-[320px]">
      <p class="text-[14px] font-body text-navy leading-[1.5]">
        El <strong>68%</strong> de peruanos se preocupan constantemente sobre el dinero.
      </p>
      <p class="text-[14px] font-body text-navy leading-[1.5]">
        Solo el <strong>16%</strong> logra ahorrar algo a fin de mes.
      </p>
    </div>
    <div class="w-full flex justify-center px-5 py-4 max-[360px]:py-3">
      <button class="btn-primary btn-primary--compact" onclick="pabloNext()">
        Siguiente
        <span class="arrow" aria-hidden="true">→</span>
      </button>
    </div>
  </div>
</section>

<script is:inline type="module">
  const paleta = {
    amarillo: { bg: "#FFF3D6", circle: "#F5A623" },
    "azul-oscuro": { bg: "#E0E4F5", circle: "#1B2A6B" },
    "azul-claro": { bg: "#EEF0FA", circle: "#9BA8D9" },
  };

  function pintarGrid() {
    const grid = document.getElementById("dotGrid");
    if (!grid) return;
    grid.innerHTML = "";
    const esChico = window.innerWidth <= 360;
    grid.style.gap = esChico ? "3px" : "5px";

    const celdas = [
      ...Array(68).fill("amarillo"),
      ...Array(16).fill("azul-oscuro"),
      ...Array(16).fill("azul-claro"),
    ];
    for (let i = celdas.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [celdas[i], celdas[j]] = [celdas[j], celdas[i]];
    }

    celdas.forEach((tipo) => {
      const c = paleta[tipo];
      const celda = document.createElement("div");
      celda.style.cssText = `
                background: ${c.bg};
                border-radius: 6px;
                aspect-ratio: 1;
                display: flex;
                align-items: center;
                justify-content: center;
                opacity: 0;
                transform: scale(0.4);
                transition: opacity 0.3s ease, transform 0.3s ease;
            `;
      const circulo = document.createElement("div");
      circulo.style.cssText = `
                width: 55%;
                height: 55%;
                border-radius: 50%;
                background: ${c.circle};
            `;
      celda.appendChild(circulo);
      grid.appendChild(celda);
    });

    const hijos = Array.from(grid.children);
    hijos
      .map((_, i) => i)
      .sort(() => Math.random() - 0.5)
      .forEach((idx, orden) => {
        setTimeout(() => {
          hijos[idx].style.opacity = "1";
          hijos[idx].style.transform = "scale(1)";
        }, orden * 20);
      });
  }

  const stepEl = document.querySelector('[data-step="step-nuevo-1"]');
  const observer = new MutationObserver(() => {
    if (stepEl?.getAttribute("aria-hidden") === "false") pintarGrid();
  });
  if (stepEl) observer.observe(stepEl, { attributes: true });
</script>
