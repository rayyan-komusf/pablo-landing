<!-- Funciones para ti: checkboxes que se marcan solos según las respuestas -->
<section class="step !pb-0" data-step="step-16" aria-label="Funciones personalizadas" aria-hidden="true">
  <div class="fuente-header">
    <div class="fuente-header__inner">
      <div class="fuente-pablo">
        <img src="/onboarding/images/pablo/pablo-wave.png" alt="" width="140" height="140" loading="lazy" />
      </div>
      <div class="speech-bubble speech-bubble--side">Marqué las funciones más útiles para ti según tus respuestas ✨</div>
    </div>
  </div>

  <div class="fuente-body flex-1 flex flex-col w-full mx-auto px-5 max-md:px-4 overflow-y-auto [scrollbar-width:none] [&::-webkit-scrollbar]:hidden vcenter">
    <div class="fuente-grid" role="group" aria-label="Selecciona las funciones que te interesan">
      <button class="option-card option-card--pill checkbox" role="checkbox" aria-checked="false" onclick="pabloToggle(this, 'whatsapp')">
        <span class="option-radio"></span>
        <span class="option-icon">📱</span>
        <span class="option-label text-left">Registro por WhatsApp</span>
      </button>
      <button class="option-card option-card--pill checkbox" role="checkbox" aria-checked="false" onclick="pabloToggle(this, 'presupuesto')">
        <span class="option-radio"></span>
        <span class="option-icon">📊</span>
        <span class="option-label text-left">Presupuesto mensual</span>
      </button>
      <button class="option-card option-card--pill checkbox" role="checkbox" aria-checked="false" onclick="pabloToggle(this, 'deuda')">
        <span class="option-radio"></span>
        <span class="option-icon">💳</span>
        <span class="option-label text-left">Gestión de deuda</span>
      </button>
      <button class="option-card option-card--pill checkbox" role="checkbox" aria-checked="false" onclick="pabloToggle(this, 'categorias')">
        <span class="option-radio"></span>
        <span class="option-icon">🎯</span>
        <span class="option-label text-left">Límite de categorías</span>
      </button>
      <button class="option-card option-card--pill checkbox" role="checkbox" aria-checked="false" onclick="pabloToggle(this, 'resumen')">
        <span class="option-radio"></span>
        <span class="option-icon">📈</span>
        <span class="option-label text-left">Resumen financiero visual</span>
      </button>
      <button class="option-card option-card--pill checkbox" role="checkbox" aria-checked="false" onclick="pabloToggle(this, 'metas')">
        <span class="option-radio"></span>
        <span class="option-icon">🚀</span>
        <span class="option-label text-left">Trackeo de metas</span>
      </button>
    </div>
  </div>

  <footer class="duo-footer cta-footer">
    <button class="btn-primary btn-continue" onclick="pabloNext()" aria-label="Continuar">
      Continuar
    </button>
  </footer>
</section>
