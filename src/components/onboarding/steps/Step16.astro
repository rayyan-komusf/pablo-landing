<!-- Funciones para ti: checkboxes que se marcan solos según las respuestas -->
<section class="step !pb-0" data-step="step-16" aria-label="Funciones personalizadas" aria-hidden="true">
  <div class="flex-1 flex flex-col gap-5 w-full max-w-[560px] mx-auto px-5 pb-4 pt-6 max-md:px-4 max-md:gap-4 max-[360px]:px-3 max-[360px]:gap-3 overflow-y-auto [scrollbar-width:none] [&::-webkit-scrollbar]:hidden max-md:pb-[60px] vcenter">
    <!-- Header -->
    <div class="flex flex-col gap-2.5">
      <h2 class="font-display font-bold text-[22px] max-[360px]:text-[18px] md:text-[24px] text-navy tracking-[-0.01em] leading-[1.25]">
        Funciones para ti
      </h2>
      <p class="text-[14px] text-navy-soft font-body">
        Con <strong>Pablo</strong>, podrás sacarle el máximo provecho a las siguientes funciones.
        <strong>Marca las que más te interesen:</strong>
      </p>
    </div>
    <!-- Opciones checkbox múltiple -->
    <div class="flex flex-col gap-2.5" role="group" aria-label="Selecciona las funciones que te interesan">
      <button class="option-card checkbox" role="checkbox" aria-checked="false" onclick="pabloToggle(this, 'whatsapp')">
        <span class="option-radio"></span>
        <span class="option-icon">📱</span>
        <span class="option-label text-left">Registro por WhatsApp</span>
      </button>
      <button class="option-card checkbox" role="checkbox" aria-checked="false" onclick="pabloToggle(this, 'presupuesto')">
        <span class="option-radio"></span>
        <span class="option-icon">📊</span>
        <span class="option-label text-left">Presupuesto mensual</span>
      </button>
      <button class="option-card checkbox" role="checkbox" aria-checked="false" onclick="pabloToggle(this, 'deuda')">
        <span class="option-radio"></span>
        <span class="option-icon">💳</span>
        <span class="option-label text-left">Gestión de deuda</span>
      </button>
      <button class="option-card checkbox" role="checkbox" aria-checked="false" onclick="pabloToggle(this, 'categorias')">
        <span class="option-radio"></span>
        <span class="option-icon">🎯</span>
        <span class="option-label text-left">Límite de categorías</span>
      </button>
      <button class="option-card checkbox" role="checkbox" aria-checked="false" onclick="pabloToggle(this, 'resumen')">
        <span class="option-radio"></span>
        <span class="option-icon">📈</span>
        <span class="option-label text-left">Resumen financiero visual</span>
      </button>
      <button class="option-card checkbox" role="checkbox" aria-checked="false" onclick="pabloToggle(this, 'metas')">
        <span class="option-radio"></span>
        <span class="option-icon">🚀</span>
        <span class="option-label text-left">Trackeo de metas</span>
      </button>
    </div>
  </div>
  <!-- CTA Footer -->
  <div class="w-full flex justify-center px-5 py-4 max-[360px]:py-3 max-md:mt-[2px] md:mt-[40px]">
    <button class="btn-primary btn-primary--compact" onclick="pabloNext()">
      Siguiente
      <span class="arrow" aria-hidden="true">→</span>
    </button>
  </div>
</section>
