---
// Rama con deuda: Pablo explica cómo ayuda + card del dashboard REAL de
// Pablo (CuentaCreditoCard replica AccountCard tipo tarjeta_credito).
import CuentaCreditoCard from "../dashboard-cards/CuentaCreditoCard.astro";
---

<section class="step !pb-0" data-step="step-nuevo-2" aria-label="Deudas" aria-hidden="true">
  <div class="fuente-header">
    <div class="fuente-header__inner">
      <div class="fuente-pablo">
        <img src="/onboarding/images/pablo/emotions/pablo-tierno.png" alt="" width="140" height="140" loading="lazy" />
      </div>
      <div class="speech-bubble speech-bubble--side">¡No hay problema! Te ayudo a pagar tus deudas mientras tus ahorros siguen creciendo 💪</div>
    </div>
  </div>

  <div class="fuente-body flex-1 flex flex-col items-center w-full mx-auto px-5 max-md:px-4 overflow-y-auto [scrollbar-width:none] [&::-webkit-scrollbar]:hidden vcenter">
    <p class="dashboard-preview-hint">Así se verá tu tarjeta en Pablo:</p>
    <CuentaCreditoCard />
  </div>

  <footer class="duo-footer cta-footer">
    <button class="btn-primary btn-continue" onclick="pabloNext()" aria-label="Continuar">
      Continuar
    </button>
  </footer>
</section>
