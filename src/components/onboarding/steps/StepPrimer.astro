<!-- Pregunta inicial: se muestra antes del saludo "¡Hola, soy Pablo!" -->
<section class="step !pb-0 relative" data-step="step-primer" aria-label="Pregunta inicial - Objetivo principal" aria-hidden="true">
  <!-- X de salida directa: desde la primera pantalla se sale sin confirmación -->
  <button
    class="btn-exit-floating"
    onclick="pabloExitDirect()"
    aria-label="Salir del onboarding"
    title="Salir"
  >
    ✕
  </button>

  <div class="flex-1 flex flex-col gap-5 w-full max-w-[560px] mx-auto px-5 pt-16 pb-4 max-md:px-4 max-md:gap-4 max-[360px]:px-3 max-[360px]:gap-3 overflow-y-auto [scrollbar-width:none] [&::-webkit-scrollbar]:hidden vcenter">
    <!-- Header -->
    <div class="flex flex-col gap-2.5">
      <span class="font-display font-bold text-[12px] rounded-2xl text-amber tracking-[0.08em] uppercase bg-white px-3 py-1 inline-flex items-center gap-1 w-fit shadow-soft">
        Antes de empezar
      </span>
      <h2 class="font-display font-bold text-[22px] max-[360px]:text-[18px] md:text-[24px] text-navy tracking-[-0.01em] leading-[1.25]">
        Quiero que Pablo me ayude a…
      </h2>
    </div>
    <!-- Opciones -->
    <div class="flex flex-col gap-2.5" role="radiogroup" aria-label="Selecciona tu objetivo principal">
      <button class="option-card" role="radio" aria-checked="false"
        onclick="pabloSelect(this, 'mainGoal', 'gastos-hormiga'); setTimeout(() => pabloNext(), 1);">
        <span class="option-radio"></span>
        <span class="option-icon">🐜</span>
        <span class="option-label text-left">Controlar mis gastos hormiga</span>
      </button>
      <button class="option-card" role="radio" aria-checked="false"
        onclick="pabloSelect(this, 'mainGoal', 'ahorrar'); setTimeout(() => pabloNext(), 1);">
        <span class="option-radio"></span>
        <span class="option-icon">🐷</span>
        <span class="option-label text-left">Ahorrar más para el futuro</span>
      </button>
      <button class="option-card" role="radio" aria-checked="false"
        onclick="pabloSelect(this, 'mainGoal', 'metas'); setTimeout(() => pabloNext(), 1);">
        <span class="option-radio"></span>
        <span class="option-icon">🎯</span>
        <span class="option-label text-left">Avanzar hacia mis metas</span>
      </button>
      <button class="option-card" role="radio" aria-checked="false"
        onclick="pabloSelect(this, 'mainGoal', 'automatizar'); setTimeout(() => pabloNext(), 1);">
        <span class="option-radio"></span>
        <span class="option-icon">⚡</span>
        <span class="option-label text-left">Automatizar mis finanzas</span>
      </button>
      <button class="option-card" role="radio" aria-checked="false"
        onclick="pabloSelect(this, 'mainGoal', 'deudas'); setTimeout(() => pabloNext(), 1);">
        <span class="option-radio"></span>
        <span class="option-icon">💳</span>
        <span class="option-label text-left">Gestionar mis deudas</span>
      </button>
      <button class="option-card" role="radio" aria-checked="false"
        onclick="pabloSelect(this, 'mainGoal', 'educacion'); setTimeout(() => pabloNext(), 1);">
        <span class="option-radio"></span>
        <span class="option-icon">📚</span>
        <span class="option-label text-left">Educarme financieramente</span>
      </button>
    </div>
  </div>
</section>
