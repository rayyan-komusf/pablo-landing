<!-- Pregunta inicial: se muestra antes del saludo "¡Hola, soy Pablo!" -->
<section class="step !pb-0 relative" data-step="step-primer" aria-label="Pregunta inicial - Objetivo principal" aria-hidden="true">
  <!-- Header tipo Duolingo: barra blanca con logo y acceso a la app -->
  <header class="duo-header">
    <div class="duo-header__inner">
      <button
        class="btn-exit duo-header__exit"
        onclick="pabloExitDirect()"
        aria-label="Salir del onboarding"
        title="Salir"
      >
        ✕
      </button>
      <a class="duo-header__brand" href="/" aria-label="Ir al inicio de Pablo">
        <img src="/onboarding/images/pablo/pablo-logo.png" alt="" width="34" height="34" loading="eager" />
        <span>pablo</span>
      </a>
      <button
        class="duo-header__link"
        onclick="pabloGoApp('step-primer')"
        aria-label="Iniciar sesión si ya eres miembro"
      >
        ¿Ya eres miembro?
      </button>
    </div>
  </header>

  <div class="primer-body flex-1 flex flex-col w-full mx-auto px-5 max-md:px-4 overflow-y-auto [scrollbar-width:none] [&::-webkit-scrollbar]:hidden vcenter">
    <!-- Título centrado, estilo selector de Duolingo -->
    <div class="flex flex-col items-center text-center">
      <h2 class="font-display font-bold text-[24px] max-[360px]:text-[20px] md:text-[30px] text-navy tracking-[-0.01em] leading-[1.25]">
        Quiero que Pablo me ayude a…
      </h2>
    </div>
    <!-- Opciones: cuadrícula de tarjetas cuadradas (auto-avance al elegir) -->
    <div class="options-grid" role="radiogroup" aria-label="Selecciona tu objetivo principal">
      <button class="option-card option-card--tile" role="radio" aria-checked="false"
        onclick="pabloSelect(this, 'mainGoal', 'gastos-hormiga'); setTimeout(() => pabloNext(), 250);">
        <span class="option-icon">🐜</span>
        <span class="option-label">Controlar mis gastos hormiga</span>
      </button>
      <button class="option-card option-card--tile" role="radio" aria-checked="false"
        onclick="pabloSelect(this, 'mainGoal', 'ahorrar'); setTimeout(() => pabloNext(), 250);">
        <span class="option-icon">🐷</span>
        <span class="option-label">Ahorrar más para el futuro</span>
      </button>
      <button class="option-card option-card--tile" role="radio" aria-checked="false"
        onclick="pabloSelect(this, 'mainGoal', 'metas'); setTimeout(() => pabloNext(), 250);">
        <span class="option-icon">🎯</span>
        <span class="option-label">Avanzar hacia mis metas</span>
      </button>
      <button class="option-card option-card--tile" role="radio" aria-checked="false"
        onclick="pabloSelect(this, 'mainGoal', 'automatizar'); setTimeout(() => pabloNext(), 250);">
        <span class="option-icon">⚡</span>
        <span class="option-label">Automatizar mis finanzas</span>
      </button>
      <button class="option-card option-card--tile" role="radio" aria-checked="false"
        onclick="pabloSelect(this, 'mainGoal', 'deudas'); setTimeout(() => pabloNext(), 250);">
        <span class="option-icon">💳</span>
        <span class="option-label">Gestionar mis deudas</span>
      </button>
      <button class="option-card option-card--tile" role="radio" aria-checked="false"
        onclick="pabloSelect(this, 'mainGoal', 'educacion'); setTimeout(() => pabloNext(), 250);">
        <span class="option-icon">📚</span>
        <span class="option-label">Educarme financieramente</span>
      </button>
    </div>
  </div>
</section>
