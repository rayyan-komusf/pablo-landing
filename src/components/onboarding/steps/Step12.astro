<!-- Pregunta 6: ¿endeudado? (patrón Duolingo: header Pablito + pills + Continuar) -->
<section class="step !pb-0" data-step="step-12" aria-label="Pregunta 6 - Deudas" aria-hidden="true">
  <div class="fuente-header">
    <div class="fuente-header__inner">
      <div class="fuente-pablo">
        <picture>
          <source srcset="/onboarding/images/pablo/pablo-anotando.webp" type="image/webp" />
          <img src="/onboarding/images/pablo/pablo-point.png" alt="" width="140" height="140" loading="lazy" />
        </picture>
      </div>
      <div class="speech-bubble speech-bubble--side">¿Actualmente estás endeudado?</div>
    </div>
  </div>

  <div class="fuente-body flex-1 flex flex-col w-full mx-auto px-5 max-md:px-4 overflow-y-auto [scrollbar-width:none] [&::-webkit-scrollbar]:hidden vcenter">
    <div class="fuente-grid" role="radiogroup" aria-label="¿Tienes deudas actualmente?">
      <button class="option-card option-card--pill" role="radio" aria-checked="false"
        onclick="pabloSelect(this, 'hasDebt', true)">
        <span class="option-icon">💳</span>
        <span class="option-label text-left">Sí</span>
      </button>
      <button class="option-card option-card--pill" role="radio" aria-checked="false"
        onclick="pabloSelect(this, 'hasDebt', false)">
        <span class="option-icon">✨</span>
        <span class="option-label text-left">¡Nop!</span>
      </button>
    </div>
  </div>

  <footer class="duo-footer cta-footer">
    <button class="btn-primary btn-continue disabled" disabled onclick="pabloNext()" aria-label="Continuar">
      Continuar
    </button>
  </footer>
</section>
