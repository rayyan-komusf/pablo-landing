<!-- Registro paso a paso (3/3): contraseña + creación de la cuenta.
     Crea la cuenta directo contra Supabase Auth (anon key pública) y entrega
     la sesión a la app por el FRAGMENT de la URL (no viaja a servidores):
     usapablo.app/auth/sesion?plan=X#access_token=…&refresh_token=…
     La app instala la sesión y sigue al checkout embebido de Flow. -->
<section class="step !pb-0" data-step="step-cuenta-password" aria-label="Crea tu cuenta: contraseña" aria-hidden="true">
  <div class="fuente-header">
    <div class="fuente-header__inner">
      <div class="fuente-pablo">
        <picture>
          <source srcset="/onboarding/images/pablo/pablo-anotando.webp" type="image/webp" />
          <img
            src="/onboarding/images/pablo/pablo-point.png"
            alt=""
            width="140"
            height="140"
            loading="lazy"
          />
        </picture>
      </div>
      <div class="speech-bubble speech-bubble--side">Última cosita: crea una contraseña para tu cuenta</div>
    </div>
  </div>

  <div class="fuente-body flex-1 flex flex-col w-full mx-auto px-5 max-md:px-4 overflow-y-auto [scrollbar-width:none] [&::-webkit-scrollbar]:hidden vcenter">
    <div class="cuenta-form">
      <input
        id="cuenta-password"
        class="cuenta-input"
        type="password"
        placeholder="Tu contraseña"
        autocomplete="new-password"
        maxlength="72"
        oninput="pabloCuentaPasswordInput(this)"
        onkeydown="if(event.key==='Enter')pabloCuentaCrear()"
      />
      <p class="cuenta-hint">Mínimo 6 caracteres. La usarás para entrar a Pablo.</p>
      <p class="cuenta-error" id="cuenta-error" role="alert"></p>
    </div>
  </div>

  <footer class="duo-footer cta-footer">
    <button
      id="cuenta-crear-btn"
      class="btn-primary btn-continue disabled"
      disabled
      onclick="pabloCuentaCrear()"
      aria-label="Crear mi cuenta"
    >
      Crear mi cuenta
    </button>
  </footer>

  <script is:inline>
    (function () {
      var SUPABASE_URL = "https://mezpfnagkubumzbromsh.supabase.co";
      // Anon key pública de Supabase (la misma que usa la app en el navegador).
      var SUPABASE_ANON_KEY =
        "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im1lenBmbmFna3VidW16YnJvbXNoIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NjM0NDM3NDMsImV4cCI6MjA3OTAxOTc0M30.HsTSJqkzslq4HWxLlIvuFwudrFzkemHELgsi54vIJDw";

      /* Helpers compartidos por los steps de cuenta (también los usa el
       * "¿Ya tienes cuenta?" del step del nombre). En local (localhost/LAN)
       * el destino es la app local para poder testear. */
      window.pabloCuentaAppBase = function () {
        return /^(localhost|127\.0\.0\.1|192\.168\.)/.test(location.hostname)
          ? "http://localhost:8080"
          : "https://usapablo.app";
      };
      window.pabloCuentaConPhDid = function (url) {
        try {
          var did = window.posthog?.get_distinct_id?.();
          if (!did) return url;
          var u = new URL(url);
          u.searchParams.set("ph_did", did);
          return u.toString();
        } catch (e) {
          return url;
        }
      };

      var creando = false;

      function planElegido() {
        return sessionStorage.getItem("pablo_plan_elegido") || "anual";
      }
      function mostrarError(msg) {
        var el = document.getElementById("cuenta-error");
        if (el) {
          el.textContent = msg;
          el.classList.add("visible");
        }
      }
      function limpiarError() {
        document.getElementById("cuenta-error")?.classList.remove("visible");
      }
      function setBoton(texto, deshabilitado) {
        var btn = document.getElementById("cuenta-crear-btn");
        if (!btn) return;
        btn.textContent = texto;
        btn.classList.toggle("disabled", deshabilitado);
        if (deshabilitado) btn.setAttribute("disabled", "");
        else btn.removeAttribute("disabled");
      }

      async function authFetch(path, body) {
        var res = await fetch(SUPABASE_URL + path, {
          method: "POST",
          headers: { "Content-Type": "application/json", apikey: SUPABASE_ANON_KEY },
          body: JSON.stringify(body),
        });
        var data = {};
        try {
          data = await res.json();
        } catch (e) {
          /* respuesta sin body */
        }
        return { ok: res.ok, data: data };
      }

      window.pabloCuentaPasswordInput = function (el) {
        limpiarError();
        window.onboarding?.gateCta("step-cuenta-password", el.value.length >= 6);
      };

      window.pabloCuentaCrear = async function () {
        if (creando) return;
        var pass = document.getElementById("cuenta-password")?.value || "";
        if (pass.length < 6) {
          mostrarError("La contraseña debe tener al menos 6 caracteres.");
          return;
        }
        var nombre = sessionStorage.getItem("pablo_cuenta_nombre") || "";
        var correo = sessionStorage.getItem("pablo_cuenta_correo") || "";
        if (!correo) {
          window.pabloGoTo?.("step-cuenta-correo");
          return;
        }

        creando = true;
        limpiarError();
        setBoton("Creando tu cuenta…", true);

        try {
          // El registro desde la landing crea la cuenta como free; el plan se
          // activa al pagar con Flow en la app (no pasa por el gate de n8n).
          var r = await authFetch("/auth/v1/signup", {
            email: correo,
            password: pass,
            data: { nombre: nombre, apellido: "" },
          });

          var yaExiste =
            !r.ok &&
            (r.data.error_code === "user_already_exists" ||
              /already|registrado/i.test(r.data.msg || r.data.message || r.data.error_description || ""));
          if (yaExiste) {
            // Ese correo ya tiene cuenta: probamos iniciar sesión con la
            // contraseña que acaba de escribir.
            r = await authFetch("/auth/v1/token?grant_type=password", {
              email: correo,
              password: pass,
            });
            if (!r.ok) {
              mostrarError(
                "Ese correo ya tiene una cuenta y la contraseña no coincide. Usa “¿Ya tienes cuenta?” para iniciar sesión en la app."
              );
              creando = false;
              setBoton("Crear mi cuenta", false);
              return;
            }
          } else if (!r.ok) {
            mostrarError(
              r.data.msg || r.data.message || r.data.error_description || "No pudimos crear tu cuenta, intenta de nuevo."
            );
            creando = false;
            setBoton("Crear mi cuenta", false);
            return;
          }

          window.pabloTrack?.("onboarding_cuenta_creada", {
            plan: planElegido(),
            ya_existia: Boolean(yaExiste),
          });
          if (window.fbq) window.fbq("trackCustom", "CuentaCreada", { plan: planElegido() });

          var accessToken = r.data.access_token;
          var refreshToken = r.data.refresh_token;
          if (!accessToken || !refreshToken) {
            // Confirmación por correo activada en Supabase: flujo clásico.
            window.location.href = window.pabloCuentaConPhDid(
              window.pabloCuentaAppBase() + "/pricing?plan=" + planElegido()
            );
            return;
          }

          setBoton("¡Cuenta lista! Llevándote al pago…", true);
          var url =
            window.pabloCuentaConPhDid(
              window.pabloCuentaAppBase() + "/auth/sesion?plan=" + planElegido()
            ) +
            "#access_token=" +
            encodeURIComponent(accessToken) +
            "&refresh_token=" +
            encodeURIComponent(refreshToken);
          window.location.href = url;
        } catch (e) {
          console.error("[Pablo] Registro falló:", e);
          mostrarError("No pudimos conectar con el servidor. Revisa tu internet e intenta de nuevo.");
          creando = false;
          setBoton("Crear mi cuenta", false);
        }
      };
    })();
  </script>
</section>
