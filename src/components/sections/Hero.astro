---
// Hero estilo Duolingo: ocupa exactamente el viewport (menos el navbar),
// iPhone con demo en loop a la izquierda, titular + CTAs apilados a la
// derecha. Las demás secciones solo aparecen al scrollear.
import HeroPhone from "./HeroPhone.astro";
import { CTA, IS_LIVE, APP_URL } from "../../siteConfig";
---

<section class="hero" id="hero">
  <div class="container hero__inner">
    <!-- ── Izquierda: iPhone con el demo en loop ── -->
    <div class="hero__phone-area">
      <HeroPhone />
    </div>

    <!-- ── Derecha: titular + CTAs apilados ── -->
    <div class="hero__content">
      <h1 class="hero__title">
        Manejar tu dinero nunca fue <span class="highlight">tan fácil</span>
      </h1>

      <div class="hero__ctas">
        {
          IS_LIVE ? (
            <a
              href={CTA.href!}
              class="btn-primary hero__cta"
              id="hero-cta-btn"
              onclick="if(typeof fbq!=='undefined')fbq('trackCustom','Ver_Planes');if(typeof ttq!=='undefined')ttq.track('ClickButton',{content_name:'Ver_Planes'});"
            >
              {CTA.label}
            </a>
          ) : (
            <button
              onclick="window.openWaitlistModal();"
              class="btn-primary hero__cta"
              id="hero-cta-btn"
            >
              {CTA.label}
            </button>
          )
        }
        <a href={APP_URL} class="btn-secondary hero__cta">Ya tengo una cuenta</a>
      </div>
    </div>
  </div>
</section>

<style>
  /* El hero llena exactamente la pantalla (navbar de 72px arriba):
   * nada de otras secciones a la vista sin scrollear, como Duolingo. */
  .hero {
    background: #ffffff;
    height: calc(100dvh - 72px);
    min-height: 540px;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 48px;
    width: 100%;
  }

  .hero__phone-area {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  /* ── Columna de contenido (como Duolingo: titular + botones apilados) ── */
  .hero__content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 28px;
    max-width: 480px;
  }

  .hero__title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 44px;
    line-height: 1.2;
    color: var(--color-heading);
  }

  /* CTAs apilados en columna con ancho fijo, como Duolingo */
  .hero__ctas {
    display: flex;
    flex-direction: column;
    gap: 12px;
    width: 100%;
    max-width: 340px;
  }

  /* Botones estilo Duolingo: reborde inferior 3D, uppercase, radio 16 */
  .hero__cta {
    width: 100%;
    justify-content: center;
    text-align: center;
    border-radius: 16px;
    padding: 16px 22px;
    font-weight: 800;
    font-size: 15px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    transition: transform 0.12s ease, box-shadow 0.12s ease;
  }

  .hero__cta.btn-primary {
    background: var(--color-ambar, #fba920);
    color: #2b2c64;
    box-shadow: 0 4px 0 0 #c9820a;
  }

  .hero__cta.btn-primary:hover {
    transform: translateY(-1px);
    box-shadow: 0 5px 0 0 #c9820a;
  }

  .hero__cta.btn-primary:active {
    transform: translateY(3px);
    box-shadow: 0 1px 0 0 #c9820a;
  }

  .hero__cta.btn-secondary {
    background: #ffffff;
    color: #f59e0b;
    border: 2px solid #e5e5e5;
    border-bottom-width: 2px;
    box-shadow: 0 4px 0 0 #e5e5e5;
  }

  .hero__cta.btn-secondary:hover {
    background: #f7f7f7;
    color: #f59e0b;
    transform: translateY(-1px);
  }

  .hero__cta.btn-secondary:active {
    transform: translateY(3px);
    box-shadow: 0 1px 0 0 #e5e5e5;
  }

  /* ── Responsive: mobile apilado, todo dentro del viewport.
   * Como Duolingo: el teléfono llena el espacio disponible y los CTAs
   * quedan anclados en la parte de abajo. ── */
  @media (max-width: 768px) {
    .hero {
      height: calc(100dvh - 72px);
      min-height: 560px;
      align-items: stretch;
      padding-block: 4px 14px;
    }

    .hero__inner {
      display: flex;
      flex-direction: column;
      gap: 10px;
      align-items: center;
      height: 100%;
    }

    .hero__phone-area {
      order: 1;
      flex: 1;
      min-height: 0;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .hero__content {
      order: 2;
      flex: none;
      align-items: center;
      text-align: center;
      gap: 18px;
      max-width: none;
      width: 100%;
    }

    .hero__title {
      font-size: clamp(20px, 6.4vw, 28px);
      max-width: 340px;
    }

    .hero__ctas {
      max-width: 340px;
    }

    .hero__cta {
      padding-block: 14px;
    }

    /* El teléfono se dimensiona por viewport: NUNCA desborda el hero.
     * Pantalla ≈ 44% del alto visible; el ancho acompaña en proporción. */
    .hero :global(.hphone) {
      --w: clamp(235px, 31dvh, 330px);
    }
    .hero :global(.hphone__pantalla) {
      height: clamp(355px, 54dvh, 580px);
      border-radius: 36px;
    }
    .hero :global(.hphone) {
      border-radius: 44px;
    }
  }
</style>
