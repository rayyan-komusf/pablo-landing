---
// Hero estilo Duolingo: ocupa exactamente el viewport (menos el navbar),
// iPhone con demo en loop a la izquierda, titular + CTAs apilados a la
// derecha. Las demás secciones solo aparecen al scrollear.
import HeroPhone from "./HeroPhone.astro";
import { CTA, IS_LIVE, APP_URL } from "../../siteConfig";
---

<section class="hero" id="hero">
  <div class="container hero__inner">
    <!-- ── Izquierda: iPhone con el demo en loop ── -->
    <div class="hero__phone-area">
      <HeroPhone />
    </div>

    <!-- ── Derecha: titular + CTAs apilados ── -->
    <div class="hero__content">
      <div class="hero__badge">
        <span>✨</span>
        <span>Tu asistente financiero en WhatsApp</span>
      </div>

      <h1 class="hero__title">
        Manejar tu dinero nunca fue <span class="highlight">tan fácil</span>
      </h1>

      <div class="hero__ctas">
        {
          IS_LIVE ? (
            <a
              href={CTA.href!}
              class="btn-primary hero__cta"
              id="hero-cta-btn"
              onclick="if(typeof fbq!=='undefined')fbq('trackCustom','Ver_Planes');if(typeof ttq!=='undefined')ttq.track('ClickButton',{content_name:'Ver_Planes'});"
            >
              {CTA.label}
            </a>
          ) : (
            <button
              onclick="window.openWaitlistModal();"
              class="btn-primary hero__cta"
              id="hero-cta-btn"
            >
              {CTA.label}
            </button>
          )
        }
        <a href={APP_URL} class="btn-secondary hero__cta">Ya tengo una cuenta</a>
      </div>
    </div>
  </div>
</section>

<style>
  /* El hero llena exactamente la pantalla (navbar de 72px arriba):
   * nada de otras secciones a la vista sin scrollear, como Duolingo. */
  .hero {
    background: #ffffff;
    height: calc(100dvh - 72px);
    min-height: 540px;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 48px;
    width: 100%;
  }

  .hero__phone-area {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  /* ── Columna de contenido (como Duolingo: titular + botones apilados) ── */
  .hero__content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 28px;
    max-width: 480px;
  }

  .hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 7px 16px;
    border-radius: var(--radius-pill);
    background: #f7f5fb;
    border: 2px solid #e5e5e5;
    font-weight: 600;
    font-size: 14px;
    color: var(--color-heading);
  }

  .hero__title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 44px;
    line-height: 1.2;
    color: var(--color-heading);
  }

  /* CTAs apilados en columna con ancho fijo, como Duolingo */
  .hero__ctas {
    display: flex;
    flex-direction: column;
    gap: 12px;
    width: 100%;
    max-width: 340px;
  }

  .hero__cta {
    width: 100%;
    text-align: center;
  }

  /* ── Responsive: mobile apilado, todo dentro del viewport ── */
  @media (max-width: 768px) {
    .hero {
      height: calc(100dvh - 72px);
      min-height: 620px;
      align-items: flex-start;
      padding-top: 12px;
    }

    .hero__inner {
      grid-template-columns: 1fr;
      gap: 20px;
      justify-items: center;
    }

    .hero__phone-area {
      order: 1;
    }

    .hero__content {
      order: 2;
      align-items: center;
      text-align: center;
      gap: 18px;
      max-width: none;
      width: 100%;
    }

    .hero__badge {
      font-size: 12px;
      padding: 6px 12px;
    }

    .hero__title {
      font-size: 28px;
      max-width: 340px;
    }

    .hero__ctas {
      max-width: 340px;
    }
  }

  /* Pantallas bajitas en mobile: se reduce el teléfono vía variable */
  @media (max-width: 768px) and (max-height: 760px) {
    .hero :global(.hphone) {
      --w: 240px;
    }
    .hero :global(.hphone__pantalla) {
      height: 360px;
    }
    .hero__title {
      font-size: 22px;
    }
    .hero__inner {
      gap: 14px;
    }
    .hero__content {
      gap: 12px;
    }
    .hero__cta {
      padding-block: 14px;
    }
  }
</style>
