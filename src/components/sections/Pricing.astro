---
import { IS_LIVE, CHECKOUT_URLS, OFFER_AVAILABLE, FREE_TRIAL, KOMU_PROMO, PROMO_MILLONARIA } from '../../siteConfig';
import iconPremiumRaw from '../../assets/icon-premium.svg?raw';
import coronaRaw from '../../assets/corona-premium.svg?raw';

// Selecciona el link correcto del plan anual según el modo FREE_TRIAL
const annualCheckoutUrl = FREE_TRIAL ? CHECKOUT_URLS.annual_trial : CHECKOUT_URLS.annual_no_trial;
// src/components/sections/Pricing.astro
---

<section class="pricing" id="planes">
  <div class="container pricing__inner">

    {KOMU_PROMO ? (
      /* ====================================================
         MODO: Promo La Komu — "Los 4 Pecados de Pablo"
         ==================================================== */
      <>
        <!-- Header Komu -->
        <div class="pricing__header">
          <h2 class="pricing__title section-title">
            Los 4 Pecados de Pablo — <span class="highlight">Pablo Promo Komunitaria — Últimas horas</span>
          </h2>
          <p class="pricing__subtitle">
            Oferta activa solo durante el evento. Elige el plan que más te convenga y llévate el pase de La Komu <strong>incluido gratis</strong>.
          </p>
        </div>

        <!-- Cards Komu -->
        <div class="pricing__cards">

          <!-- Komu: Plan Mensual -->
          <div class="plan-card plan-monthly komu-card">
            <div class="plan-header">
              <div class="plan-icon plan-icon--navy">
                <span class="icon-premium" set:html={iconPremiumRaw}></span>
              </div>
              <div>
                <h3 class="plan-name">Pablo Premium</h3>
                <span class="plan-sub">+ Pase Mensual La Komu</span>
              </div>
            </div>
            <p class="plan-tagline">
              Lleva tus finanzas al siguiente nivel con herramientas avanzadas — más todo lo de La Komu incluido.
            </p>
            <div class="plan-price">
              <span class="plan-amount">S/.20</span>
              <span class="plan-period">/mensuales</span>
            </div>
            <div class="plan-original-price">
              <span class="plan-crossed">S/.54</span>
              <span class="plan-discount-badge">✨ 63% OFF · Precio especial La Komu</span>
            </div>
            <ul class="plan-features">
              <li>
                <svg class="check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2B2C64" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                Registro ilimitado con texto, audio o foto desde Whatsapp.
              </li>
              <li>
                <svg class="check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2B2C64" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                Presupuestos y categorías personalizadas
              </li>
              <li>
                <svg class="check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2B2C64" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                Metas, análisis, consejos y más.
              </li>
            </ul>
            <div class="komu-bonus">
              <div class="komu-bonus__header">🎁 Bonus exclusivo · La Komu</div>
              <ul class="plan-features">
                <li>
                  <svg class="check check--komu" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#C0392B" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                  <strong>Pase mensual de La Komu incluido gratis</strong>
                </li>
                <li>
                  <svg class="check check--komu" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#C0392B" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                  Asesorías financieras grupales
                </li>
                <li>
                  <svg class="check check--komu" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#C0392B" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                  Clases semanales de inversiones
                </li>
                <li>
                  <svg class="check check--komu" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#C0392B" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                  Recursos y herramientas financieras
                </li>
                <li>
                  <svg class="check check--komu" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#C0392B" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                  Participación en eventos de networking
                </li>
              </ul>
            </div>
            {OFFER_AVAILABLE ? (
              <button
                onclick={`window.planSeleccionado={name:'Plan Mensual Komu',value:20};if(typeof fbq!=='undefined')fbq('trackCustom','Abrir_Modal',{plan:'mensual_komu'});window.openSubscribeModal('${CHECKOUT_URLS.monthly}')`}
                class="plan-cta plan-cta--monthly"
                id="pricing-komu-monthly-cta"
              >
                Quiero el Plan Mensual
              </button>
            ) : (
              <button class="plan-cta plan-cta--unavailable" disabled id="pricing-komu-monthly-cta">
                Oferta no disponible
              </button>
            )}
          </div>

          <!-- Komu: Plan Anual (mejor opción) -->
          <div class="plan-card plan-premium plan-annual komu-card">
            <div class="plan-best-badge">
              <span class="icon-corona" set:html={coronaRaw}></span>
              Tu mejor opción
            </div>
            <div class="plan-header">
              <div class="plan-icon plan-icon--amber">
                <span class="icon-premium" set:html={iconPremiumRaw}></span>
              </div>
              <div>
                <h3 class="plan-name">Pablo Premium</h3>
                <span class="plan-sub plan-sub--amber">+ Pase Anual La Komu</span>
              </div>
            </div>
            <p class="plan-tagline">
              Lleva tus finanzas al siguiente nivel con herramientas avanzadas — más todo lo de La Komu incluido un año completo.
            </p>
            <div class="plan-price">
              <span class="plan-amount">S/.200</span>
              <span class="plan-period">/anuales</span>
            </div>
            <div class="plan-original-price">
              <span class="plan-crossed">S/.660</span>
              <span class="plan-discount-badge">✨ 70% OFF · Precio especial La Komu</span>
            </div>
            <ul class="plan-features">
              <li>
                <svg class="check check--amber" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#F5A623" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                Todo lo incluido en el Plan Mensual.
              </li>
              <li>
                <svg class="check check--amber" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#F5A623" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                Ahorras 2 meses de suscripción al instante.
              </li>
              <li>
                <svg class="check check--amber" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#F5A623" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                Un año entero de tranquilidad, sin renovación mensual.
              </li>
              <li>
                <svg class="check check--amber" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#F5A623" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                Acompañamiento a largo plazo para asegurar que cumplas tus metas.
              </li>
            </ul>
            <div class="komu-bonus">
              <div class="komu-bonus__header">🎁 Bonus exclusivo · La Komu</div>
              <ul class="plan-features">
                <li>
                  <svg class="check check--komu" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#C0392B" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                  <strong>Pase anual de La Komu incluido gratis</strong>
                </li>
                <li>
                  <svg class="check check--komu" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#C0392B" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                  Asesorías financieras grupales
                </li>
                <li>
                  <svg class="check check--komu" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#C0392B" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                  Clases semanales de inversiones
                </li>
                <li>
                  <svg class="check check--komu" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#C0392B" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                  Recursos y herramientas financieras
                </li>
                <li>
                  <svg class="check check--komu" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#C0392B" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                  Participación en eventos de networking
                </li>
              </ul>
            </div>
            {OFFER_AVAILABLE ? (
              <button
                onclick={`window.planSeleccionado={name:'Plan Anual Komu',value:200};if(typeof fbq!=='undefined')fbq('trackCustom','Abrir_Modal',{plan:'anual_komu'});window.openSubscribeModal('${annualCheckoutUrl}')`}
                class="plan-cta plan-cta--premium btn-primary"
                id="pricing-komu-annual-cta"
              >
                Quiero el Plan Anual
              </button>
            ) : (
              <button class="plan-cta plan-cta--unavailable" disabled id="pricing-komu-annual-cta">
                Oferta no disponible
              </button>
            )}
          </div>

        </div>

        <p class="pricing__note pricing__note--komu">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          Oferta válida hasta el 26 de abril de 2026. Cancela cuando quieras.
        </p>
      </>
    ) : (
      /* ====================================================
         MODO NORMAL: Diseño estándar de precios
         ==================================================== */
      <>
        <!-- Header -->
        <div class="pricing__header">
          <div class="pricing__badge">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
            Pasos simples, resultados reales
          </div>
          <div class="millonaria-pill" data-promo-millonaria hidden>
            🔥 Oferta Millonaria — solo esta noche
          </div>
          <h2 class="pricing__title section-title">
            Da el primer paso hacia tu <span class="highlight">bienestar financiero</span>
          </h2>
          <p class="pricing__subtitle">
            Empieza con lo esencial y mejora tu plan cuando tú decides.
            Sin presiones ni letra chica.
          </p>
        </div>

        <!-- Cards -->
        <div class="pricing__cards pricing__cards--three">

        {IS_LIVE ? (
          <>
            <!-- LIVE: Weekly Plan -->
            <div class="plan-card plan-monthly">
              <div class="plan-header">
                <div class="plan-icon plan-icon--navy">
                  <span class="icon-premium" set:html={iconPremiumRaw}></span>
                </div>
                <h3 class="plan-name">Pablo Premium</h3>
              </div>
              <p class="plan-tagline">
                Prueba Pablo una semana completa y empieza a controlar tus finanzas desde hoy.
              </p>
              <div class="plan-price">
                <span class="plan-amount">S/.7</span>
                <span class="plan-period">/semanal</span>
              </div>
              <ul class="plan-features">
                <li>
                  <svg class="check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2B2C64" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                  Registro ilimitado con texto, audio o foto desde Whatsapp
                </li>
                <li>
                  <svg class="check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2B2C64" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                  Presupuestos y categorías personalizadas
                </li>
                <li>
                  <svg class="check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2B2C64" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                  Metas de ahorro para mantener tu motivación
                </li>
                <li>
                  <svg class="check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2B2C64" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                  Análisis y consejos sin tecnicismos
                </li>
                <li>
                  <svg class="check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2B2C64" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                  Control automático de tus pagos recurrentes
                </li>
              </ul>
              {OFFER_AVAILABLE ? (
                <button
                  onclick={`window.planSeleccionado={name:'Plan Semanal',value:7};if(typeof fbq!=='undefined')fbq('trackCustom','Abrir_Modal',{plan:'semanal'});if(typeof ttq!=='undefined')ttq.track('ViewContent',{content_name:'Plan Semanal',value:7,currency:'PEN'});window.openSubscribeModal('${CHECKOUT_URLS.weekly}')`}
                  class="plan-cta plan-cta--monthly"
                  id="pricing-weekly-cta"
                >
                  Empieza esta semana
                </button>
              ) : (
                <button class="plan-cta plan-cta--unavailable" disabled id="pricing-weekly-cta">
                  Oferta no disponible
                </button>
              )}
            </div>

            <!-- LIVE: Monthly Plan -->
            <div class="plan-card plan-monthly">
              <div class="plan-header">
                <div class="plan-icon plan-icon--navy">
                  <span class="icon-premium" set:html={iconPremiumRaw}></span>
                </div>
                <h3 class="plan-name">Pablo Premium</h3>
              </div>
              <p class="plan-tagline">
                Lleva tus finanzas al siguiente nivel con herramientas avanzadas y una experiencia a tu medida.
              </p>
              <div class="plan-price">
                <span class="plan-amount">S/.20</span>
                <span class="plan-period">/mensuales</span>
              </div>
              <ul class="plan-features">
                <li>
                  <svg class="check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2B2C64" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                  <span data-pm-swap="14 días gratis de prueba">3 días gratis de prueba</span>
                </li>
                <li data-promo-millonaria hidden>
                  <svg class="check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2B2C64" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                  Acceso al reto Camino al Millón
                </li>
                <li>
                  <svg class="check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2B2C64" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                  Registro ilimitado con texto, audio o foto desde Whatsapp
                </li>
                <li>
                  <svg class="check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2B2C64" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                  Presupuestos y categorías personalizadas
                </li>
                <li>
                  <svg class="check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2B2C64" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                  Metas de ahorro para mantener tu motivación
                </li>
                <li>
                  <svg class="check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2B2C64" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                  Análisis y consejos sin tecnicismos
                </li>
                <li>
                  <svg class="check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2B2C64" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                  Control automático de tus pagos recurrentes
                </li>
              </ul>
              {OFFER_AVAILABLE ? (
                <button
                  onclick={`window.planSeleccionado={name:'Plan Mensual',value:20};if(typeof fbq!=='undefined')fbq('trackCustom','Abrir_Modal',{plan:'mensual'});if(typeof ttq!=='undefined')ttq.track('ViewContent',{content_name:'Plan Mensual',value:20,currency:'PEN'});window.openSubscribeModal('${CHECKOUT_URLS.monthly}')`}
                  class="plan-cta plan-cta--monthly"
                  id="pricing-monthly-cta"
                >
                  Desbloquea a Pablo
                </button>
              ) : (
                <button class="plan-cta plan-cta--unavailable" disabled id="pricing-monthly-cta">
                  Oferta no disponible
                </button>
              )}
            </div>

            <!-- LIVE: Annual Plan -->
            <div class="plan-card plan-premium plan-annual">
              <div class="plan-best-badge">
                <span class="icon-corona" set:html={coronaRaw}></span>
                Tu mejor opción
              </div>
              <div class="plan-header">
                <div class="plan-icon plan-icon--amber">
                  <span class="icon-premium" set:html={iconPremiumRaw}></span>
                </div>
                <h3 class="plan-name">Pablo Premium</h3>
              </div>
              <p class="plan-tagline">
                Lleva tus finanzas al siguiente nivel con herramientas avanzadas y una experiencia a tu medida.
              </p>
              <div class="plan-price">
                <span class="plan-amount">S/.200</span>
                <span class="plan-period">/anuales</span>
              </div>
              <div class="plan-original-price">
                <span class="plan-crossed">S/.240</span>
                <span class="plan-discount-badge">✨ 16% OFF · Oferta</span>
              </div>
              <ul class="plan-features">
                <li>
                  <svg class="check check--amber" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#F5A623" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                  Todo lo incluido en el plan Mensual.
                </li>
                {FREE_TRIAL && (
                  <li data-pm-hide>
                    <svg class="check check--amber" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#F5A623" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                    <span>7 días gratis de prueba.</span>
                  </li>
                )}
                <li data-promo-millonaria hidden>
                  <svg class="check check--amber" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#F5A623" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                  <strong>Sin prueba: acceso inmediato a todo por un año.</strong>
                </li>
                <li>
                  <svg class="check check--amber" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#F5A623" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                  16% de descuento exclusivo por temporada.
                </li>
                <li>
                  <svg class="check check--amber" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#F5A623" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                  Ahorras 2 meses de suscripción al instante.
                </li>
                <li>
                  <svg class="check check--amber" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#F5A623" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                  Un año entero de tranquilidad, sin renovación mensual.
                </li>
                <li>
                  <svg class="check check--amber" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#F5A623" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                  Acompañamiento a largo plazo para asegurar que cumplas tus metas.
                </li>
              </ul>
              <div class="millonaria-bonus" data-promo-millonaria hidden>
                <div class="millonaria-bonus__header">🏆 Oferta Millonaria · 5 bonos incluidos</div>
                <ul class="plan-features">
                  <li>
                    <svg class="check check--amber" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#F5A623" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                    <span><strong>Reto "Camino al Millón en 30 días"</strong>: complétalo y te devolvemos el 100% (Pablo gratis un año)</span>
                  </li>
                  <li>
                    <svg class="check check--amber" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#F5A623" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                    <span>Asesoría 1-a-1 con Rodrigo ($80 USD)</span>
                  </li>
                  <li>
                    <svg class="check check--amber" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#F5A623" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                    <span>Pase Mensual a La Komunidad de Futuros Millonarios ($60 USD)</span>
                  </li>
                  <li>
                    <svg class="check check--amber" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#F5A623" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                    <span>Toolkit Komunitario: +10 recursos de finanzas e inversiones</span>
                  </li>
                  <li>
                    <svg class="check check--amber" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#F5A623" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                    <span>Garantía de satisfacción de 14 días</span>
                  </li>
                </ul>
              </div>
              {OFFER_AVAILABLE ? (
                <button
                  onclick={`window.planSeleccionado={name:'Plan Anual',value:200};if(typeof fbq!=='undefined')fbq('trackCustom','Abrir_Modal',{plan:'anual'});if(typeof ttq!=='undefined')ttq.track('ViewContent',{content_name:'Plan Anual',value:200,currency:'PEN'});window.openSubscribeModal('${annualCheckoutUrl}')`}
                  class="plan-cta plan-cta--premium btn-primary"
                  id="pricing-annual-cta"
                >
                  Empieza tu prueba gratis
                </button>
              ) : (
                <button class="plan-cta plan-cta--unavailable" disabled id="pricing-annual-cta">
                  Oferta no disponible
                </button>
              )}
            </div>
          </>
        ) : (
          <>
            <!-- WAITLIST: Free Plan -->
            <div class="plan-card plan-free">
              <div class="plan-header">
                <div class="plan-icon plan-icon--outline">
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#2B2C64" stroke-width="1.8"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                </div>
                <h3 class="plan-name">Pablo gratis</h3>
              </div>
              <p class="plan-tagline">
                Empieza a organizar tu dinero con Pablo en WhatsApp, simple, cercano y 100% gratis.
              </p>
              <div class="plan-price">
                <span class="plan-amount">S/.0</span>
                <span class="plan-period">siempre</span>
              </div>
              <ul class="plan-features">
                <li><svg class="check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2B2C64" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Registro ilimitado de gastos e ingresos por texto</li>
                <li><svg class="check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2B2C64" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Hasta 5 registros por voz y foto al mes</li>
                <li><svg class="check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2B2C64" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Tips financieros semanales</li>
                <li><svg class="check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2B2C64" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Reportes básicos de gastos</li>
