<script is:inline define:vars={{ pmInicio: PROMO_MILLONARIA.nocheInicioISO, pmFin: PROMO_MILLONARIA.nocheFinISO }}>
  // Flash de la Oferta Millonaria en el home: SOLO la noche del webinar
  // (8:40 PM → medianoche del 23). Muestra [data-promo-millonaria], aplica los
  // textos de [data-pm-swap] (mensual a 14 días) y oculta [data-pm-hide] (el
  // trial del anual, que en la oferta es cobro directo). Fuera de la ventana no
  // toca nada: el home se ve normal.
  (function () {
    var ahora = Date.now();
    if (ahora < Date.parse(pmInicio) || ahora >= Date.parse(pmFin)) return;
    document.querySelectorAll('[data-promo-millonaria]').forEach(function (el) {
      el.hidden = false;
    });
    document.querySelectorAll('[data-pm-swap]').forEach(function (el) {
      el.textContent = el.getAttribute('data-pm-swap');
    });
    document.querySelectorAll('[data-pm-hide]').forEach(function (el) {
      el.hidden = true;
    });
  })();
</script>
