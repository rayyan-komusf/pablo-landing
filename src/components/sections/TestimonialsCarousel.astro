---
// Carrusel infinito de testimonios (marquee CSS puro, sin librerías).
// Efecto foco: la tarjeta al centro del viewport se agranda; las de los
// costados se encogen y desvanecen (script de abajo, distancia al centro).
// Se usa en la landing principal (sección Testimonials) y en /webinar.
// Los testimonios viven en src/data/testimonios.ts.
import { TESTIMONIOS } from '../../data/testimonios';
---

<div class="carrusel" role="region" aria-label="Testimonios de usuarios de Pablo">
  <div class="carrusel__track">
    {
      [0, 1].map((copia) => (
        <div class="carrusel__grupo" aria-hidden={copia === 1 ? 'true' : undefined}>
          {TESTIMONIOS.map((t) => (
            <article class="tc-card">
              <svg class="tc-quote" width="22" height="22" viewBox="0 0 24 24" fill="#D4D0F0">
                <path d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V20c0 1 0 1 1 1z" />
                <path d="M15 21c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2h.75c0 2.25.25 4-2.75 4v3c0 1 0 1 1 1z" />
              </svg>
              <p class="tc-text">{t.texto}</p>
              <div class="tc-author">
                <span class="tc-name">{t.nombre}</span>
                {t.detalle && <span class="tc-detalle">{t.detalle}</span>}
              </div>
            </article>
          ))}
        </div>
      ))
    }
  </div>
</div>

<style>
  .carrusel {
    width: 100%;
    overflow: hidden;
    -webkit-mask-image: linear-gradient(to right, transparent, #000 5%, #000 95%, transparent);
    mask-image: linear-gradient(to right, transparent, #000 5%, #000 95%, transparent);
  }

  .carrusel__track {
    display: flex;
    width: max-content;
    padding: 26px 0 38px; /* aire para la tarjeta agrandada del centro y su sombra */
    animation: carrusel-scroll 60s linear infinite;
  }

  .carrusel:hover .carrusel__track {
    animation-play-state: paused;
  }

  .carrusel__grupo {
    display: flex;
    align-items: center; /* cada tarjeta con la altura de SU texto: sin espacio blanco de relleno */
  }

  .tc-card {
    width: min(240px, 66vw);
    flex-shrink: 0;
    margin-right: 18px;
    background: white;
    border-radius: var(--radius-md);
    padding: 18px 20px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    box-shadow: var(--card-shadow);
    transform-origin: center;
    will-change: transform, opacity;
  }

  .tc-quote {
    opacity: 0.6;
    flex-shrink: 0;
  }

  .tc-text {
    font-size: 13.5px;
    line-height: 1.55;
    color: var(--color-heading);
  }

  .tc-author {
    display: flex;
    flex-direction: column;
    gap: 1px;
    align-items: flex-end;
    text-align: right;
  }

  .tc-name {
    font-weight: 700;
    font-size: 12.5px;
    color: var(--color-heading);
  }

  .tc-detalle {
    font-size: 11px;
    color: var(--color-secondary);
  }

  /* La pista se duplica para el loop: cada mitad mide lo mismo,
     así que al llegar a -50% el salto al inicio es invisible. */
  @keyframes carrusel-scroll {
    to {
      transform: translateX(-50%);
    }
  }

  @media (max-width: 768px) {
    .carrusel__track {
      animation-duration: 45s;
    }
  }

  /* Sin animación: scroll horizontal manual y sin copia duplicada */
  @media (prefers-reduced-motion: reduce) {
    .carrusel {
      overflow-x: auto;
      -webkit-mask-image: none;
      mask-image: none;
    }

    .carrusel__track {
      animation: none;
    }

    .carrusel__grupo[aria-hidden='true'] {
      display: none;
    }
  }
</style>

<script>
  // Foco central: escala y opacidad de cada tarjeta según su distancia al
  // centro del viewport, actualizado por frame mientras el marquee avanza.
  const reducirMovimiento = window.matchMedia('(prefers-reduced-motion: reduce)');

  document.querySelectorAll<HTMLElement>('.carrusel').forEach((carrusel) => {
    const cards = carrusel.querySelectorAll<HTMLElement>('.tc-card');
    let visible = false;

    new IntersectionObserver((entradas) => {
      visible = entradas.some((e) => e.isIntersecting);
    }).observe(carrusel);

    const actualizar = () => {
      if (visible) {
        const centro = window.innerWidth / 2;
        const alcance = Math.max(1, carrusel.clientWidth / 2);
        cards.forEach((card) => {
          const r = card.getBoundingClientRect();
          const d = Math.min(1, Math.abs(r.left + r.width / 2 - centro) / alcance);
          card.style.transform = `scale(${(1.12 - 0.34 * d).toFixed(3)})`;
          card.style.opacity = (1 - 0.62 * d).toFixed(3);
        });
      }
      requestAnimationFrame(actualizar);
    };

    if (!reducirMovimiento.matches) requestAnimationFrame(actualizar);
  });
</script>
