---
// src/components/sections/Testimonials.astro
// Carrusel infinito de testimonios (antes: grid estático de 3 cards).
import TestimonialsCarousel from './TestimonialsCarousel.astro';
---

<section class="testimonials">
  <div class="test__inner">
    <div class="container test__header">
      <h2 class="section-title test__title">
        Gente real, <span class="highlight">resultados reales</span>
      </h2>
      <p class="test__subtitle">
        Sé parte de una comunidad que está transformando su relación con el dinero gracias a Pablo.
      </p>
    </div>

    <TestimonialsCarousel />
  </div>
</section>

<style>
  .testimonials {
    background: var(--bg-testimonials);
    padding: var(--section-py) 0;
    overflow: hidden;
  }

  .test__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 40px;
  }

  .test__header {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
  }

  .test__title {
    font-size: 42px;
    line-height: 1.15;
  }

  .test__subtitle {
    font-size: 16px;
    color: var(--color-body);
    max-width: 480px;
  }

  @media (max-width: 768px) {
    .test__title {
      font-size: 28px;
    }
  }
</style>
