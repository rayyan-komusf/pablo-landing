---
import { Image } from 'astro:assets';
import portada from '../../assets/portada-webinar.png';
import { WEBINAR_MANDAMIENTOS as W } from '../../siteConfig';
// Landing del webinar "Los 4 Mandamientos Financieros".
// Mismo lenguaje visual que Eventos.astro (Los 4 Pecados).

const horaChip = W.horaConfirmada ? W.horaTexto : 'Hora por confirmar';
---

<section class="evento">
  <!-- Decorative blobs -->
  <div class="evento__blob evento__blob--1" aria-hidden="true"></div>
  <div class="evento__blob evento__blob--2" aria-hidden="true"></div>

  <div class="container evento__inner">
    <!-- Primera vista: todo lo que debe verse sin hacer scroll -->
    <div class="evento__fold">
    <!-- Badge: cupos limitados -->
    <div class="evento__badge">
      <span class="evento__badge-dot"></span>
      Cupos limitados — reserva el tuyo antes de que se acaben
    </div>

    <!-- Title -->
    <h1 class="evento__title">
      Los <span class="highlight">4 Mandamientos</span> Financieros
    </h1>

    <!-- Subtitle -->
    <p class="evento__subtitle">
      Para dejar atrás la ansiedad financiera y empezar a ahorrar más para tu
      futuro, <strong>sin tener que sacrificar el presente</strong>.
    </p>

    <!-- Chips con los detalles del evento -->
    <div class="evento__chips">
      <span class="evento__chip">📅 {W.fechaTexto}</span>
      <span class="evento__chip">🕖 {horaChip}</span>
      <span class="evento__chip">📺 En vivo por {W.plataforma}</span>
    </div>

    <!-- Portada -->
    <div class="evento__portada">
      <Image
        src={portada}
        alt="Webinar Los 4 Mandamientos Financieros: Pablo con la clase en vivo y los recursos gratuitos"
        widths={[480, 800, 1280]}
        sizes="(max-width: 768px) 100vw, 680px"
        loading="eager"
      />
    </div>

    <!-- CTA — scroll al formulario -->
    <a
      href="#registro"
      class="btn-primary evento__cta"
      onclick="try{window.posthog?.capture('webinar_cta_clicked',{webinar:'4_mandamientos',location:'hero'})}catch(e){};if(typeof fbq!=='undefined')fbq('trackCustom','Webinar_Hero_CTA');"
    >
      Reclama tu entrada gratuita
      <span class="btn-arrow">→</span>
    </a>

    <!-- Contador regresivo -->
    <div class="evento__countdown" id="wm-countdown" data-fecha={W.fechaISO}>
      <div class="cd-unit"><span class="cd-num" id="wm-cd-dias">--</span><span class="cd-label">días</span></div>
      <span class="cd-sep">:</span>
      <div class="cd-unit"><span class="cd-num" id="wm-cd-horas">--</span><span class="cd-label">horas</span></div>
      <span class="cd-sep">:</span>
      <div class="cd-unit"><span class="cd-num" id="wm-cd-min">--</span><span class="cd-label">min</span></div>
      <span class="cd-sep">:</span>
      <div class="cd-unit"><span class="cd-num" id="wm-cd-seg">--</span><span class="cd-label">seg</span></div>
    </div>

    <!-- Trust pill -->
    <p class="evento__trust">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
      </svg>
      Gratis y seguro — solo necesitas tu correo
    </p>
    </div>

    <!-- Durante esta clase aprenderás -->
    <div class="evento__desc-box">
      <h2 class="evento__desc-title">Durante esta clase aprenderás:</h2>

      <ul class="evento__aprenderas">
        <li>
          <span class="check">✓</span>
          <span>Identificar y eliminar esos gastos hormigas que se llevan tu dinero.</span>
        </li>
        <li>
          <span class="check">✓</span>
          <span>Cómo organizar tus ingresos sin usar presupuestos complicados.</span>
        </li>
        <li>
          <span class="check">✓</span>
          <span>Cómo empezar a ahorrar, aunque actualmente sientas que no te alcanza.</span>
        </li>
        <li>
          <span class="check">✓</span>
          <span>Cómo tomar mejores decisiones antes de gastar.</span>
        </li>
      </ul>
    </div>
  </div>
</section>

<style>
  /* ────────────────────────────
     EVENTO HERO SECTION
  ──────────────────────────── */
  .evento {
    background: var(--bg-hero);
    padding: 20px 0 80px;
    position: relative;
    overflow: hidden;
  }

  .evento__blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
    z-index: 0;
  }

  .evento__blob--1 {
    width: 420px;
    height: 420px;
    background: rgba(246, 183, 43, 0.12);
    top: -100px;
    right: -80px;
  }

  .evento__blob--2 {
    width: 340px;
    height: 340px;
    background: rgba(86, 87, 143, 0.1);
    bottom: -60px;
    left: -60px;
  }

  .evento__inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 12px;
    max-width: 680px;
    margin: 0 auto;
  }

  /* Primera vista: ocupa la pantalla completa hasta el trust pill,
     así "Durante esta clase aprenderás" queda debajo del fold */
  .evento__fold {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    width: 100%;
    min-height: calc(100vh - 96px);
    min-height: calc(100svh - 96px);
  }

  /* Badge */
  .evento__badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: white;
    border: 1.5px solid rgba(43, 44, 100, 0.12);
    border-radius: var(--radius-pill);
    padding: 4px 12px;
    font-size: 11px;
    font-weight: 600;
    color: var(--color-body);
    letter-spacing: 0.02em;
    animation: fadeUp 0.5s 0.1s both;
    box-shadow: 0 2px 12px rgba(43, 44, 100, 0.06);
  }

  .evento__badge-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #E04545;
    box-shadow: 0 0 0 3px rgba(224, 69, 69, 0.2);
    animation: pulse-dot 1.8s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { box-shadow: 0 0 0 3px rgba(224, 69, 69, 0.2); }
    50%       { box-shadow: 0 0 0 6px rgba(224, 69, 69, 0.08); }
  }

  /* Portada — crece con el alto de la pantalla sin empujar el
     countdown/trust fuera de la primera vista */
  .evento__portada {
    width: 100%;
    max-width: clamp(300px, calc((100svh - 460px) * 1.78), 680px);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: 0 12px 48px rgba(43, 44, 100, 0.18);
    animation: fadeUp 0.6s 0.45s both;
  }

  .evento__portada :global(img) {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Title */
  .evento__title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 42px;
    line-height: 1.08;
    color: var(--color-heading);
    animation: fadeUp 0.6s 0.25s both;
  }

  /* Subtitle */
  .evento__subtitle {
    font-size: 17px;
    line-height: 1.5;
    color: var(--color-body);
    animation: fadeUp 0.6s 0.35s both;
  }

  .evento__subtitle strong {
    color: var(--color-heading);
    font-weight: 700;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Chips */
  .evento__chips {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px;
    animation: fadeUp 0.6s 0.4s both;
  }

  .evento__chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: white;
    border-radius: var(--radius-pill);
    padding: 5px 13px;
    font-size: 12px;
    font-weight: 600;
    color: var(--color-heading);
    box-shadow: var(--card-shadow);
  }

  /* Contador regresivo (debajo del CTA) */
  .evento__countdown {
    display: flex;
    align-items: center;
    gap: 8px;
    animation: fadeUp 0.6s 0.55s both;
  }

  .cd-unit {
    display: flex;
    flex-direction: column;
    align-items: center;
    background: white;
    border-radius: var(--radius-md);
    padding: 7px 12px;
    min-width: 56px;
    box-shadow: var(--card-shadow);
  }

  .cd-num {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 21px;
    line-height: 1.1;
    color: var(--color-heading);
    font-variant-numeric: tabular-nums;
  }

  .cd-label {
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-secondary);
  }

  .cd-sep {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 18px;
    color: var(--color-amber);
  }

  /* CTA button */
  .evento__cta {
    font-size: 16px;
    padding: 14px 30px;
    gap: 10px;
    animation: fadeUp 0.5s 0.5s ease forwards;
    box-shadow: 0 6px 24px rgba(245, 166, 35, 0.35);
    border: none;
    cursor: pointer;
  }

  /* Trust pill */
  .evento__trust {
    display: flex;
    align-items: center;
    gap: 7px;
    font-size: 13px;
    color: var(--color-secondary);
    font-weight: 500;
    animation: fadeUp 0.5s 0.6s ease forwards;
  }

  /* Description box */
  .evento__desc-box {
    background: white;
    border-radius: var(--radius-lg);
    padding: 32px 36px;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 16px;
    box-shadow: var(--card-shadow);
    text-align: left;
    animation: fadeUp 0.6s 0.6s both;
  }

  .evento__desc-title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 24px;
    color: var(--color-heading);
    text-align: center;
    margin: 0 0 4px;
  }

  /* Lista "aprenderás" con checks */
  .evento__aprenderas {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .evento__aprenderas li {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    background: var(--bg-hero);
    border-radius: var(--radius-md);
    padding: 14px 16px;
    font-size: 15px;
    color: var(--color-heading);
    font-weight: 500;
    line-height: 1.5;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .evento__aprenderas li:hover {
    transform: translateX(4px);
    box-shadow: var(--card-shadow);
  }

  .check {
    font-weight: 800;
    font-size: 16px;
    color: var(--color-green);
    background: white;
    border-radius: 50%;
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    box-shadow: 0 1px 6px rgba(43, 44, 100, 0.1);
  }

  /* ────────────────────────────
     RESPONSIVE
  ──────────────────────────── */
  @media (max-width: 768px) {
    .evento {
      padding: 24px 0 64px;
    }

    .evento__title {
      font-size: 32px;
    }

    .evento__subtitle {
      font-size: 16px;
    }

    .evento__chip {
      font-size: 12px;
      padding: 5px 12px;
    }

    .evento__desc-box {
      padding: 24px 20px;
    }

    .evento__cta {
      font-size: 15px;
      padding: 15px 26px;
    }
  }

  @media (max-width: 390px) {
    .evento__title {
      font-size: 30px;
    }

    .evento__mascot {
      width: 64px;
      height: 64px;
    }

    .cd-unit {
      min-width: 56px;
      padding: 8px 10px;
    }

    .cd-num {
      font-size: 22px;
    }
  }
</style>

<script>
  // Contador regresivo hacia la fecha del webinar
  const el = document.getElementById('wm-countdown');
  const objetivo = el?.dataset.fecha ? new Date(el.dataset.fecha).getTime() : 0;

  const dias = document.getElementById('wm-cd-dias');
  const horas = document.getElementById('wm-cd-horas');
  const min = document.getElementById('wm-cd-min');
  const seg = document.getElementById('wm-cd-seg');

  function pad(n: number) {
    return String(n).padStart(2, '0');
  }

  function tick() {
    const resta = objetivo - Date.now();
    if (resta <= 0) {
      // Ya empezó: el contador queda en cero
      if (dias) dias.textContent = '00';
      if (horas) horas.textContent = '00';
      if (min) min.textContent = '00';
      if (seg) seg.textContent = '00';
      return;
    }
    const s = Math.floor(resta / 1000);
    if (dias) dias.textContent = pad(Math.floor(s / 86400));
    if (horas) horas.textContent = pad(Math.floor((s % 86400) / 3600));
    if (min) min.textContent = pad(Math.floor((s % 3600) / 60));
    if (seg) seg.textContent = pad(s % 60);
  }

  if (el) {
    tick();
    setInterval(tick, 1000);
  }
</script>
