    color: var(--color-secondary);
    font-weight: 500;
  }

  /* ════════════════ 2. EL PACTO ════════════════ */
  .om-reto {
    background: #ffffff;
    padding: var(--section-py) 0;
  }

  .om-reto__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 40px;
