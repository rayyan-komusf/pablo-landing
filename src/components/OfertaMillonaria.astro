  }

  .om-item__proof-quote {
    font-size: 14px;
    font-style: italic;
    line-height: 1.5;
    color: var(--color-heading);
  }

  .om-item__proof-autor {
    font-size: 12px;
    color: var(--color-secondary);
  }

  .om-item--dark .om-item__proof {
    background: rgba(255, 255, 255, 0.07);
  }

  .om-item--dark .om-item__proof-quote { color: #fff; }
  .om-item--dark .om-item__proof-autor { color: rgba(255, 255, 255, 0.6); }

  /* Módulos un poco más anchos para que respiren */
  .om-stack__list { max-width: 860px; }

  @media (max-width: 700px) {
    .om-item,
    .om-item--dark { flex-direction: column; }
  }

  /* Recap */
  .om-recap {
    width: 100%;
    max-width: 640px;
    background: white;
    border: 2px solid var(--color-amber);
    border-radius: var(--radius-lg);
    padding: 36px 32px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    box-shadow: 0 8px 40px rgba(245, 166, 35, 0.2);
  }

  .om-recap__title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 24px;
    color: var(--color-heading);
    text-align: center;
  }

  .om-recap__list {
    display: flex;
    flex-direction: column;
  }

  .om-recap__list li {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 16px;
    padding: 12px 0;
    border-bottom: 1px dashed rgba(43, 44, 100, 0.15);
    font-size: 14px;
    color: var(--color-heading);
    font-weight: 500;
  }

  .om-recap__val {
    color: var(--color-secondary);
    font-weight: 600;
    text-align: right;
    white-space: nowrap;
    font-size: 13px;
  }

  .om-recap__val s {
    color: var(--color-secondary);
  }

  /* Comparación: S/.240 → hoy S/.200 → S/.0 */
  .om-recap__compare {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
    text-align: center;
    padding: 6px 0;
  }

  .om-comp {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }

  .om-comp__precio {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 24px;
    line-height: 1.1;
    color: var(--color-secondary);
  }

  .om-comp--hoy .om-comp__precio {
    font-size: 34px;
    color: var(--color-heading);
  }

  .om-comp--gratis .om-comp__precio {
    font-size: 34px;
    color: var(--color-green);
  }

  .om-comp__label {
    font-size: 12.5px;
    font-weight: 500;
    color: var(--color-secondary);
  }

  .om-comp__flecha {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 22px;
    color: var(--color-amber);
  }

  /* ════════════════ 4. CARTA ════════════════ */
  .om-carta-sec {
    background: #ffffff;
    padding: var(--section-py) 0;
  }

  .om-carta {
    position: relative;
    max-width: 640px;
    margin: 0 auto;
    background: var(--om-cream, #fffaf0);
    border: 1px solid rgba(43, 44, 100, 0.1);
    border-radius: 6px;
    padding: 48px 40px 40px;
    box-shadow: 0 2px 6px rgba(43, 44, 100, 0.06), 0 16px 40px rgba(43, 44, 100, 0.1);
    transform: rotate(-0.4deg);
    background-image: repeating-linear-gradient(
      transparent,
      transparent 31px,
      rgba(43, 44, 100, 0.05) 31px,
      rgba(43, 44, 100, 0.05) 32px
    );
  }

  /* "Cinta" que sostiene la carta */
  .om-carta__pin {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%) rotate(1.5deg);
    width: 110px;
    height: 26px;
    background: rgba(245, 166, 35, 0.35);
    border-left: 1px dashed rgba(43, 44, 100, 0.15);
    border-right: 1px dashed rgba(43, 44, 100, 0.15);
  }

  .om-carta__p {
    font-size: 16px;
    line-height: 2;
    color: var(--color-heading);
    margin-bottom: 18px;
  }

  .om-carta__firma {
    font-family: 'Caveat', cursive;
    font-weight: 600;
    font-size: 30px;
    color: var(--color-heading);
    margin-top: 28px;
    transform: rotate(-1.2deg);
  }

  /* ════════════════ 5. TESTIMONIOS ════════════════ */
  .om-testimonios {
    background: var(--bg-testimonials);
    padding: var(--section-py) 0;
  }

  .om-testimonios__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 40px;
  }

  .om-test__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    width: 100%;
    max-width: 860px;
  }

  .om-test-card {
    background: white;
    border-radius: var(--radius-lg);
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    box-shadow: var(--card-shadow);
  }

  .om-test-card:last-child {
    grid-column: 1 / -1;
    max-width: 420px;
    justify-self: center;
    width: 100%;
  }

  .om-test-card__quote {
    opacity: 0.6;
  }

  .om-test-card__text {
    font-size: 15px;
    line-height: 1.65;
    color: var(--color-heading);
    flex: 1;
  }

  .om-test-card__ctx {
    font-size: 13px;
    font-weight: 600;
    color: var(--color-green);
  }

  .om-test-card__author {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 2px;
  }

  .om-test-card__name {
    font-weight: 700;
    font-size: 14px;
    color: var(--color-heading);
  }

  .om-test-card__detail {
    font-size: 12px;
    color: var(--color-secondary);
  }

  /* ════════════════ 6. GARANTÍA ════════════════ */
  .om-garantia {
    background: #ffffff;
    padding: var(--section-py) 0;
  }

  .om-garantia__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 40px;
  }

  .om-garantia__cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    width: 100%;
    max-width: 760px;
  }

  .om-g-card {
    background: #fafafe;
    border: 2px solid #c8c5d6;
    border-radius: var(--radius-lg);
    padding: 32px 28px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .om-g-card--amber {
    background: linear-gradient(135deg, #f7ecd4 0%, #f3f3f6 100%);
    border-color: var(--color-amber);
  }

  .om-g-card__icon {
    width: 52px;
    height: 52px;
    border-radius: var(--radius-md);
    background: white;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: var(--card-shadow);
  }

  .om-g-card__title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 20px;
    line-height: 1.3;
    color: var(--color-heading);
  }

  .om-g-card__desc {
    font-size: 15px;
    line-height: 1.6;
    color: var(--color-body);
  }

  /* ════════════════ 7. URGENCIA ════════════════ */
  .om-urgencia {
    background: var(--bg-hero);
    padding: var(--section-py) 0;
  }

  .om-urgencia__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 22px;
    max-width: 640px;
    margin: 0 auto;
  }

  .om-urgencia__title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 30px;
    line-height: 1.2;
    color: var(--color-heading);
  }

  .om-urgencia__sub {
    font-size: 16px;
    line-height: 1.6;
    color: var(--color-body);
  }

  /* ════════════════ 8. FAQ ════════════════ */
  .om-faq {
    background: var(--bg-faq);
    padding: var(--section-py) 0;
  }

  .om-faq__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 40px;
  }

  .om-faq__list {
    width: 100%;
    max-width: 760px;
    display: flex;
    flex-direction: column;
  }

  .om-faq-item {
    border-bottom: 1px solid rgba(43, 44, 100, 0.1);
  }

  .om-faq-q {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 20px 4px;
    font-size: 16px;
    font-weight: 600;
    color: var(--color-heading);
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    transition: color 0.15s;
  }

  .om-faq-q:hover {
    color: var(--color-purple);
  }

  .om-faq-chevron {
    flex-shrink: 0;
    transition: transform 0.3s ease;
    color: var(--color-heading);
  }

  .om-faq-q[aria-expanded='true'] {
    color: var(--color-purple);
  }

  .om-faq-q[aria-expanded='true'] .om-faq-chevron {
    transform: rotate(180deg);
  }

  .om-faq-a p {
    padding: 0 4px 20px;
    font-size: 15px;
    line-height: 1.7;
    color: var(--color-body);
  }

  /* ════════════════ 9. CTA FINAL ════════════════ */
  .om-final {
    background: var(--bg-footer);
    padding: var(--section-py) 0;
  }

  .om-final__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 18px;
    max-width: 640px;
    margin: 0 auto;
  }

  .om-final__mascot {
    width: 110px;
    height: 110px;
    object-fit: contain;
  }

  .om-final__title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 34px;
    line-height: 1.15;
    color: white;
  }

  .om-final__sub {
    font-size: 16px;
    line-height: 1.6;
    color: var(--color-footer-text);
  }

  .om-final__cierre {
    font-size: 14px;
    line-height: 1.6;
    font-weight: 600;
    color: var(--color-footer-text);
  }

  .om-final__trust {
    display: flex;
    align-items: center;
    gap: 7px;
    font-size: 13px;
    color: var(--color-footer-text);
    font-weight: 500;
  }

  /* ════════════════ RESPONSIVE ════════════════ */
  @media (max-width: 768px) {
    .om-sec-title {
      font-size: 26px;
    }

    .om-hero {
      padding: 32px 0 48px;
    }

    .om-hero__title {
      font-size: 28px;
    }

    .om-hero__sub {
      font-size: 15px;
    }

    .om-reto__pasos {
      grid-template-columns: 1fr;
    }

    .om-carta {
      padding: 40px 24px 32px;
    }

    .om-carta__p {
      font-size: 15px;
    }

    .om-item {
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: 24px 20px;
    }

    .om-item__body {
      align-items: center;
    }

    .om-item__tag,
    .om-item__valor {
      align-self: center;
    }

    .om-item__bullets li {
      text-align: left;
    }

    .om-recap {
      padding: 28px 20px;
    }

    .om-recap__list li {
      flex-direction: column;
      gap: 2px;
      align-items: flex-start;
    }

    .om-recap__val {
      white-space: normal;
      text-align: left;
    }

    .om-recap__compare {
      flex-direction: column;
      gap: 8px;
    }

    .om-comp__flecha {
      transform: rotate(90deg);
    }

    .om-test__grid {
      grid-template-columns: 1fr;
      max-width: 480px;
    }

    .om-test-card:last-child {
      grid-column: auto;
      max-width: none;
    }

    .om-garantia__cards {
      grid-template-columns: 1fr;
      max-width: 480px;
    }

    .om-urgencia__title {
      font-size: 24px;
    }

    .om-countdown--big .om-cd__unit {
      min-width: 58px;
      padding: 8px 10px;
    }

    .om-countdown--big .om-cd__num {
      font-size: 24px;
    }

    .om-final__title {
      font-size: 26px;
    }
  }

  @media (max-width: 390px) {
    .om-hero__title {
      font-size: 25px;
    }

    .om-cd__unit {
      min-width: 50px;
      padding: 6px 8px;
    }
  }

  /* ══════════════════════════════════════════════════════════════
     TEMA OSCURO + ESTRUCTURA $100M (rediseño jul-2026)
     Va al final para ganarle a las reglas de arriba.
     ══════════════════════════════════════════════════════════════ */
  .om { background: #16173a; }

  /* ── HERO oscuro, 2 columnas (teléfono + contenido) ── */
  /* ── HERO claro (nada de azul aquí), 2 columnas ── */
  .om-hero { padding: 56px 0 64px; }
  .om-hero__inner {
    display: grid;
    grid-template-columns: minmax(260px, 0.85fr) 1.1fr;
    gap: 56px;
    align-items: center;
    text-align: left;
    max-width: 1060px;
  }
  .om-hero__phone { display: flex; justify-content: center; }
  .om-hero__content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 20px;
    max-width: 560px;
  }
  .om-hero__title {
    text-align: left;
    font-size: clamp(28px, 3vw, 42px);
    line-height: 1.14;
  }

  /* Cajita resumen del hero (clara) */
  .om-hero__resumen {
    width: 100%;
    background: #fff;
    border: 1.5px solid #e6e3f2;
    border-radius: var(--radius-md);
    padding: 18px 20px;
    box-shadow: var(--card-shadow);
  }
  .om-hero__resumen-title {
    font-family: var(--font-heading);
    font-weight: 700;
    color: var(--color-heading);
    font-size: 14px;
    margin-bottom: 10px;
  }
  .om-hero__resumen-list { display: flex; flex-direction: column; gap: 8px; }
  .om-hero__resumen-list li {
    position: relative;
    padding-left: 24px;
    font-size: 14px;
    color: var(--color-body);
    line-height: 1.4;
  }
  .om-hero__resumen-list li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: var(--color-green);
    font-weight: 800;
  }
  .om-hero__resumen-list li[data-noche] { color: #875a00; font-weight: 600; }
  .om-hero__resumen-list li[data-noche]::before { content: "🔥"; }

  /* ── Banda social ── */
  .om-social { background: #20214a; }

  /* ── BONOS: cada uno a pantalla completa; ALTERNAN blanco / navy ── */
  .om-bono {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 72px 0;
    background: #fff;               /* claro por defecto */
  }
  .om-bono--flip { background: #1b1c40; }   /* oscuro */
  .om-bono--noche {
    background: linear-gradient(135deg, #3a2c0e 0%, #20214a 65%);
  }
  .om-bono__inner {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: 64px;
    align-items: center;
    max-width: 1080px;
  }
  .om-bono--flip .om-bono__media { order: 2; }
  .om-bono__media { display: flex; justify-content: center; }
  .om-bono__media img {
    width: min(320px, 72vw);
    height: auto;
    filter: drop-shadow(0 20px 44px rgba(43, 44, 100, 0.25));
  }
  .om-bono--flip .om-bono__media img,
  .om-bono--noche .om-bono__media img {
    filter: drop-shadow(0 24px 48px rgba(0, 0, 0, 0.45));
  }
  .om-bono__body {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 16px;
    max-width: 560px;
  }
  /* Tag: claro por defecto, blanco translúcido en secciones oscuras */
  .om-bono__tag {
    background: #eeedf5;
    color: var(--color-heading);
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 5px 14px;
    border-radius: var(--radius-pill);
  }
  .om-bono--flip .om-bono__tag,
  .om-bono--noche .om-bono__tag {
    background: rgba(255, 255, 255, 0.12);
    color: #fff;
  }
  .om-bono__tag--fire { background: var(--gradient-cta); color: #2b2c64; }
  .om-bono__title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: clamp(26px, 3.4vw, 40px);
    line-height: 1.15;
    color: var(--color-heading);
  }
  .om-bono--flip .om-bono__title,
  .om-bono--noche .om-bono__title { color: #fff; }
  .om-bono__valor { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
  .om-bono__tachado {
    color: var(--color-secondary);
    font-size: 18px;
    text-decoration: line-through;
  }
  .om-bono--flip .om-bono__tachado,
  .om-bono--noche .om-bono__tachado { color: rgba(255, 255, 255, 0.5); }
  .om-bono__incluido {
    background: #fef3da;
    color: #875a00;
    border: 1px solid #f5c970;
    font-weight: 700;
    font-size: 13px;
    padding: 4px 12px;
    border-radius: var(--radius-pill);
  }
  .om-bono__desc {
    font-size: clamp(15px, 2vw, 18px);
    line-height: 1.6;
    color: var(--color-body);
  }
  .om-bono--flip .om-bono__desc,
  .om-bono--noche .om-bono__desc { color: rgba(255, 255, 255, 0.85); }
  .om-bono__bullets { display: flex; flex-direction: column; gap: 10px; }
  .om-bono__bullets li {
    display: flex;
    gap: 10px;
    align-items: flex-start;
    font-size: 15px;
    color: var(--color-body);
    line-height: 1.5;
  }
  .om-bono--flip .om-bono__bullets li,
  .om-bono--noche .om-bono__bullets li { color: rgba(255, 255, 255, 0.85); }
  .om-bono--flip .om-bono__bullets .om-check,
  .om-bono--noche .om-bono__bullets .om-check { stroke: #7BE495; }
  .om-bono__proof {
    border-left: 3px solid var(--color-amber);
    background: #faf7ff;
    border-radius: 0 12px 12px 0;
    padding: 14px 16px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .om-bono--flip .om-bono__proof,
  .om-bono--noche .om-bono__proof { background: rgba(255, 255, 255, 0.06); }
  .om-bono__proof-label {
    font-size: 11px;
    font-weight: 700;
    color: var(--color-green);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .om-bono--flip .om-bono__proof-label,
  .om-bono--noche .om-bono__proof-label { color: #7BE495; }
  .om-bono__proof-quote { font-size: 14px; font-style: italic; color: var(--color-heading); line-height: 1.5; }
  .om-bono--flip .om-bono__proof-quote,
  .om-bono--noche .om-bono__proof-quote { color: #fff; }
  .om-bono__proof-autor { font-size: 12px; color: var(--color-secondary); }
  .om-bono--flip .om-bono__proof-autor,
  .om-bono--noche .om-bono__proof-autor { color: rgba(255, 255, 255, 0.6); }
  .om-bono__cta { align-self: flex-start; margin-top: 6px; }

  /* ── Resumen (claro) ── */
  .om-resumen { background: var(--bg-how); padding: var(--section-py) 0; }
  .om-resumen .om-sec-title { color: var(--color-heading); }
  .om-resumen .om-sec-sub { color: var(--color-body); }

  /* ── Testimonios (claro, como en la landing) ── */
  .om-testimonios { background: var(--bg-testimonials); }
  .om-testimonios .om-sec-title { color: var(--color-heading); }
  .om-testimonios .om-sec-sub { color: var(--color-body); }

  /* ── Carta (tarjeta limpia sobre fondo claro) ── */
  .om-carta-sec { background: var(--bg-page); padding: var(--section-py) 0; }
  .om-carta {
    position: relative;
    background: #fff;
    background-image: none;
    border-radius: var(--radius-lg);
    padding: clamp(28px, 5vw, 56px);
    max-width: 720px;
    margin: 0 auto;
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.35);
  }
  .om-carta__quote {
    position: absolute;
    top: 28px;
    right: 36px;
    font-family: var(--font-heading);
    font-size: 120px;
    line-height: 0.6;
    color: #F0EDE2;
    pointer-events: none;
  }
  .om-carta__titulo {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: clamp(28px, 4.5vw, 42px);
    color: var(--color-heading);
    line-height: 1.1;
    margin-bottom: 22px;
    max-width: 80%;
  }
  .om-carta__p {
    font-size: 16px;
    line-height: 1.75;
    color: #3a3a5c;
    margin-bottom: 16px;
  }
  .om-carta__firma {
