<script>
  // ── Contadores regresivos (hero + urgencia comparten deadline) ──
  function pad(n: number) {
    return String(n).padStart(2, '0');
  }

  const countdowns = document.querySelectorAll<HTMLElement>('.om-countdown');

  function tick() {
    countdowns.forEach((cd) => {
      const deadline = cd.dataset.deadline ? new Date(cd.dataset.deadline).getTime() : 0;
      const resta = deadline - Date.now();
      const s = Math.max(0, Math.floor(resta / 1000));

      const setVal = (key: string, val: number) => {
        const el = cd.querySelector<HTMLElement>(`[data-cd="${key}"]`);
        if (el) el.textContent = pad(val);
      };

      setVal('d', Math.floor(s / 86400));
      setVal('h', Math.floor((s % 86400) / 3600));
      setVal('m', Math.floor((s % 3600) / 60));
      setVal('s', s % 60);
    });
  }

  if (countdowns.length) {
    tick();
    setInterval(tick, 1000);
  }

  // ── FAQ acordeón (mismo patrón que FAQ.astro) ──
  document.querySelectorAll('.om-faq-q').forEach((button) => {
    button.addEventListener('click', () => {
      const isExpanded = button.getAttribute('aria-expanded') === 'true';

      document.querySelectorAll('.om-faq-q').forEach((b) => {
        b.setAttribute('aria-expanded', 'false');
        const id = b.getAttribute('aria-controls')!;
        const a = document.getElementById(id);
        if (a) a.hidden = true;
      });

      if (!isExpanded) {
        button.setAttribute('aria-expanded', 'true');
        const answer = document.getElementById(button.getAttribute('aria-controls')!);
        if (answer) answer.hidden = false;
      }
    });
  });
</script>

<script is:inline define:vars={{ nocheInicio: PROMO_MILLONARIA.nocheInicioISO, nocheFin: PROMO_MILLONARIA.nocheFinISO }}>
  // El bonus 1-a-1 con Rodrigo solo existe la NOCHE del webinar (8:40-11:59
  // del 23). Dentro de esa ventana se revelan los [data-noche]; fuera, quedan
  // ocultos — así la misma página sirve para /webinar después de medianoche
  // (sin 1-1) y para /webinardespues (preview evergreen).
  (function () {
    var ahora = Date.now();
    if (ahora < Date.parse(nocheInicio) || ahora >= Date.parse(nocheFin)) return;
    document.querySelectorAll('[data-noche]').forEach(function (el) {
      el.hidden = false;
    });
  })();
</script>
