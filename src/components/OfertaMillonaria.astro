  .om-paso {
    display: flex;
    gap: 16px;
    align-items: center;
    background: var(--bg-hero);
    border-radius: var(--radius-md);
    padding: 22px;
  }

  .om-paso__num {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--gradient-cta);
    color: var(--color-navy);
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 19px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 3px 10px rgba(245, 166, 35, 0.35);
  }

  .om-paso__title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 17px;
    line-height: 1.35;
    color: var(--color-heading);
  }

  .om-reto__cierre {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    max-width: 560px;
  }

  .om-reto__cierre p {
    font-size: 16px;
    color: var(--color-body);
  }

  .om-reto__frase {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 22px !important;
    color: var(--color-heading) !important;
  }

  .om-reto__ventana {
    font-size: 14px !important;
    line-height: 1.6;
    color: #875a00 !important;
    background: #fef3da;
    border: 1px solid #f5c970;
    border-radius: var(--radius-md);
    padding: 12px 20px;
  }

  /* Mini-testimonios en pills pegados al pacto */
  .om-pacto__pills {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 14px;
    width: 100%;
    max-width: 760px;
  }

  .om-pill {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    background: white;
    border: 1.5px solid #e5e3f0;
    border-radius: 18px;
