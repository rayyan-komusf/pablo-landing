              </button>
              <div class="om-faq-a" id={`om-faq-a-${i}`} role="region" aria-labelledby={`om-faq-btn-${i}`} hidden>
                <p>{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ════════════════ 9. CTA FINAL ════════════════ -->
