    color: var(--color-heading);
  }

  .om-pill__autor {
    font-size: 12px;
    color: var(--color-secondary);
  }

  /* ════════════════ 3. VALUE STACK ════════════════ */
  .om-stack {
    background: var(--bg-how);
    padding: var(--section-py) 0;
  }

  .om-stack__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 40px;
  }

  .om-stack__list {
    display: flex;
    flex-direction: column;
    gap: 20px;
    width: 100%;
    max-width: 760px;
  }

  .om-item {
    display: flex;
    gap: 24px;
    align-items: flex-start;
