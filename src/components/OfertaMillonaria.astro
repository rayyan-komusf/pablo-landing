<style>
  /* Bonus 1-a-1: nace oculto y se revela solo la noche del webinar. El
     !important gana al display de .om-item / .om-recap li. */
  [data-noche][hidden] { display: none !important; }

  /* ════════════════ HEADER MÍNIMO ════════════════ */
  .om-header {
    background: var(--bg-hero);
  }

  .om-header__inner {
    display: flex;
    align-items: center;
    height: 72px;
  }

  .om-header__logo {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
    cursor: default;
  }

  .om-header__img {
    width: 36px;
    height: 36px;
    object-fit: contain;
    border-radius: 8px;
  }

  .om-header__text {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 20px;
    color: var(--color-heading);
  }

  /* ════════════════ BASE ════════════════ */
  .om {
    --om-cream: #fffaf0;
    --om-navy: var(--color-navy);
  }

  .om-sec-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    text-align: center;
  }

  .om-sec-title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 34px;
    line-height: 1.15;
    color: var(--color-heading);
    max-width: 640px;
  }

  .om-sec-sub {
    font-size: 16px;
    color: var(--color-body);
    max-width: 480px;
  }

  /* CTA estilo Duolingo (reborde 3D como el hero del index) */
  .om-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    max-width: 380px;
    padding: 16px 24px;
    border-radius: 16px;
    background: var(--gradient-cta);
    color: #2b2c64;
    font-family: var(--font-body);
    font-weight: 800;
    font-size: 15px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    text-align: center;
    box-shadow: 0 4px 0 0 #c9820a;
    transition: transform 0.12s ease, box-shadow 0.12s ease;
    cursor: pointer;
  }

  .om-cta:hover {
    transform: translateY(-1px);
    box-shadow: 0 5px 0 0 #c9820a;
  }

  .om-cta:active {
    transform: translateY(3px);
    box-shadow: 0 1px 0 0 #c9820a;
  }

  .om-cta--full {
    max-width: none;
  }

  .om-cta--xl {
    max-width: 440px;
    padding: 18px 28px;
    font-size: 16px;
  }

  /* Badge deadline */
  .om-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: white;
    border: 1.5px solid rgba(43, 44, 100, 0.12);
    border-radius: var(--radius-pill);
    padding: 5px 14px;
    font-size: 12px;
    font-weight: 700;
    color: var(--color-heading);
    letter-spacing: 0.02em;
    box-shadow: 0 2px 12px rgba(43, 44, 100, 0.06);
  }

  .om-badge__dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #e04545;
    box-shadow: 0 0 0 3px rgba(224, 69, 69, 0.2);
    animation: om-pulse 1.8s ease-in-out infinite;
  }

  @keyframes om-pulse {
    0%, 100% { box-shadow: 0 0 0 3px rgba(224, 69, 69, 0.2); }
    50% { box-shadow: 0 0 0 6px rgba(224, 69, 69, 0.08); }
  }

  /* Countdown (mismo lenguaje visual que el webinar) */
  .om-countdown {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .om-cd__unit {
    display: flex;
    flex-direction: column;
    align-items: center;
    background: white;
    border-radius: var(--radius-md);
    padding: 7px 12px;
    min-width: 56px;
    box-shadow: var(--card-shadow);
  }

  .om-cd__num {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 21px;
    line-height: 1.1;
    color: var(--color-heading);
    font-variant-numeric: tabular-nums;
  }

  .om-cd__label {
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-secondary);
  }

  .om-cd__sep {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 18px;
    color: var(--color-amber);
  }

  .om-countdown--big .om-cd__unit {
    min-width: 68px;
    padding: 10px 14px;
