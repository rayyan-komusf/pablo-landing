---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import { getPosts, getPostBySlug, renderBlocks } from "../../lib/notion";

export async function getStaticPaths() {
  const posts = await getPosts();
  return posts.map((post) => ({ params: { slug: post.slug } }));
}

const { slug } = Astro.params;
const data = await getPostBySlug(slug!);

if (!data) return Astro.redirect("/blog");

const { meta, blocks } = data;
const content = renderBlocks(blocks);
const fecha = meta.fecha
  ? new Date(meta.fecha).toLocaleDateString("es-PE", {
      year: "numeric",
      month: "long",
      day: "numeric",
    })
  : null;
---

<Layout title={`${meta.title} — Pablo`} description={meta.descripcion}>
  <Navbar />
  <main class="post-page">
    <article class="container">
      <header class="post-header">
        <h1>{meta.title}</h1>
        {meta.descripcion && <p class="post-lead">{meta.descripcion}</p>}
        <div class="post-meta">
          {fecha && <time class="post-date">{fecha}</time>}
          {meta.autor && (
            <>
              <span class="post-meta-sep">|</span>
              <span class="post-autor">{meta.autor}</span>
            </>
          )}
        </div>
      </header>

      {meta.portada && (
        <div class="post-cover">
          <img
            src={meta.portada}
            alt={meta.title}
            width="720"
            height="405"
            fetchpriority="high"
            decoding="async"
          />
        </div>
      )}

      <div class="post-content" set:html={content} />

      <div class="post-back">
        <a href="/blog">← Volver al blog</a>
      </div>
    </article>
  </main>
  <Footer />
</Layout>

<style>
  .post-page {
    min-height: 100vh;
    background: var(--bg-page);
    padding-bottom: 120px;
  }

  .container {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 var(--gutter);
  }

  .post-header {
    padding: 64px 0 32px;
    text-align: center;
  }

  .post-header h1 {
    font-family: var(--font-heading);
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    color: var(--color-heading);
    line-height: 1.2;
    margin-bottom: 16px;
  }

  .post-lead {
    font-size: 1.1rem;
    color: var(--color-body);
    line-height: 1.7;
    margin-bottom: 24px;
    max-width: 560px;
    margin-left: auto;
    margin-right: auto;
  }

  .post-meta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .post-date {
    font-size: 0.82rem;
    color: var(--color-secondary);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .post-meta-sep {
    color: var(--color-secondary);
    opacity: 0.4;
    font-size: 0.82rem;
  }

  .post-autor {
    font-size: 0.82rem;
    color: var(--color-secondary);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .post-cover {
    margin: 32px 0 48px;
    border-radius: var(--radius-lg);
    overflow: hidden;
    max-height: 480px;
  }

  .post-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .post-content {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--color-body);
  }

  .post-content :global(h2) {
    font-family: var(--font-heading);
    font-size: 1.6rem;
    color: var(--color-heading);
    margin: 48px 0 16px;
  }

  .post-content :global(h3) {
    font-family: var(--font-heading);
    font-size: 1.3rem;
    color: var(--color-heading);
    margin: 36px 0 12px;
  }

  .post-content :global(h4) {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    color: var(--color-heading);
    margin: 28px 0 10px;
  }

  .post-content :global(p) {
    margin-bottom: 20px;
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    margin: 16px 0 24px 24px;
  }

  .post-content :global(li) {
    margin-bottom: 8px;
  }

  .post-content :global(blockquote) {
    border-left: 4px solid var(--color-amber);
    padding: 12px 20px;
    margin: 32px 0;
    background: var(--highlight-bg);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    color: var(--color-heading);
    font-style: italic;
  }

  .post-content :global(pre) {
    background: var(--color-heading);
    color: #f5f3ff;
    padding: 20px 24px;
    border-radius: var(--radius-md);
    overflow-x: auto;
    margin: 24px 0;
    font-size: 0.9rem;
  }

  .post-content :global(code) {
    font-family: "Courier New", monospace;
    font-size: 0.88em;
    background: rgba(43, 44, 100, 0.08);
    padding: 2px 6px;
    border-radius: 4px;
  }

  .post-content :global(pre code) {
    background: none;
    padding: 0;
    color: inherit;
  }

  .post-content :global(img) {
    max-width: 100%;
    border-radius: var(--radius-md);
    margin: 32px auto;
    display: block;
  }

  .post-content :global(figure) {
    margin: 32px 0;
    text-align: center;
  }

  .post-content :global(figcaption) {
    font-size: 0.85rem;
    color: var(--color-secondary);
    margin-top: 10px;
  }

  .post-content :global(hr) {
    border: none;
    border-top: 1px solid rgba(43, 44, 100, 0.12);
    margin: 48px 0;
  }

  .post-content :global(a) {
    color: var(--color-amber);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .post-content :global(.blog-btn-wrap) {
    text-align: center;
    margin: 32px 0;
  }

  .post-content :global(.blog-btn) {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--color-amber);
    color: var(--color-heading);
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1rem;
    padding: 12px 24px;
    border-radius: var(--radius-pill);
    text-decoration: none;
    transition: transform 0.2s ease;
  }

  .post-content :global(.blog-btn:hover) {
    transform: scale(1.05);
  }

  .post-content :global(.blog-btn:hover span) {
    transform: translateX(4px);
  }

  .post-content :global(.blog-btn span) {
    display: inline-block;
    transition: transform 0.2s ease;
  }

  .post-content :global(.callout) {
    background: var(--highlight-bg);
    border-radius: var(--radius-md);
    padding: 16px 20px;
    margin: 24px 0;
    color: var(--color-heading);
    font-weight: 500;
  }

  .post-back {
    margin-top: 72px;
    padding-top: 32px;
    border-top: 1px solid rgba(43, 44, 100, 0.1);
  }

  .post-back a {
    color: var(--color-body);
    font-weight: 500;
    transition: color 0.15s;
  }

  .post-back a:hover {
    color: var(--color-heading);
  }
</style>
