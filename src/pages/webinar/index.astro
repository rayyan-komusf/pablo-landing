---
// /webinar: ANTES del fin del webinar muestra el registro del evento; DESPUÉS
// (a partir de las 8:40 PM del 23-jul, hora Perú) muestra la página de ventas
// Oferta Millonaria (mismo componente que /webinardespues). El cambio ocurre
// en el cliente por fecha, así la página se transforma sola sin redeploy.
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import EventoMandamientos from '../../components/eventos/EventoMandamientos.astro';
import RegistroWebinar from '../../components/eventos/RegistroWebinar.astro';
import TestimoniosWebinar from '../../components/eventos/TestimoniosWebinar.astro';
import OfertaMillonaria from '../../components/OfertaMillonaria.astro';
import { PROMO_MILLONARIA } from '../../siteConfig';
// src/pages/webinar/index.astro
---

<Layout
  title="Los 4 Mandamientos Financieros — Webinar gratis"
  description="Webinar en vivo y gratis: las 4 reglas simples para ordenar tu plata de una vez por todas. Jueves 23 de julio por YouTube. Reserva tu lugar."
  hideBanner
  hideMoneda
  noindex
>
  <!-- Registro del webinar (visible antes de que termine) -->
  <div id="wb-registro">
    <Navbar />
    <main>
      <EventoMandamientos />
      <RegistroWebinar />
      <TestimoniosWebinar />
    </main>
  </div>

  <!-- Página de ventas (visible cuando el webinar termina) -->
  <div id="wb-oferta" hidden>
    <OfertaMillonaria />
  </div>

  <Footer />

  <script is:inline define:vars={{ finWebinarISO: PROMO_MILLONARIA.ofertaInicioISO }}>
    // Al terminar el webinar (fin = inicio de la oferta, 8:40 PM del 23) /webinar
    // pasa de "registro" a "oferta". Antes de esa hora se queda en el registro.
    (function () {
      try {
        if (Date.now() < Date.parse(finWebinarISO)) return;
        var reg = document.getElementById('wb-registro');
        var of = document.getElementById('wb-oferta');
        if (reg) reg.hidden = true;
        if (of) of.hidden = false;
      } catch (e) {
        /* ante cualquier error, se queda en el registro */
      }
    })();
  </script>
</Layout>
