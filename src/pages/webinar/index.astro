---
// /webinar transforma su contenido por fecha (todo en el cliente, sin redeploy):
//   • Antes de las 8:00 PM del 23 (inicio del webinar): registro ABIERTO.
//   • 8:00 – 8:40 PM: registro CERRADO (el webinar ya empezó).
//   • 8:40 PM – medianoche del 23: salta a la OFERTA (Oferta Millonaria, con el
//     bono 1-a-1 de la noche).
//   • Desde mañana (medianoche en adelante): la oferta vive en /fiestas-patrias;
//     quien caiga en /webinar es redirigido ahí.
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import EventoMandamientos from '../../components/eventos/EventoMandamientos.astro';
import RegistroWebinar from '../../components/eventos/RegistroWebinar.astro';
import TestimoniosWebinar from '../../components/eventos/TestimoniosWebinar.astro';
import OfertaMillonaria from '../../components/OfertaMillonaria.astro';
import { PROMO_MILLONARIA, WEBINAR_MANDAMIENTOS } from '../../siteConfig';
// src/pages/webinar/index.astro
---

<Layout
  title="Los 4 Mandamientos Financieros — Webinar gratis"
  description="Webinar en vivo y gratis: las 4 reglas simples para ordenar tu plata de una vez por todas. Jueves 23 de julio por YouTube."
  hideBanner
  hideMoneda
  noindex
>
  <!-- Estados del evento (registro / cerrado); comparten navbar. -->
  <div id="wb-evento">
    <Navbar />
    <main>
      <div id="wb-registro">
        <EventoMandamientos />
        <RegistroWebinar />
        <TestimoniosWebinar />
      </div>

      <div id="wb-cerrado" hidden>
        <section class="wb-cerrado">
          <div class="container wb-cerrado__inner">
            <span class="wb-cerrado__pill">🔴 En vivo ahora</span>
            <h1 class="wb-cerrado__title">El webinar ya empezó</h1>
            <p class="wb-cerrado__sub">
              El registro está cerrado. Si te inscribiste, revisa tu correo y
              tu WhatsApp: ahí está tu acceso al webinar.
            </p>
          </div>
        </section>
      </div>
    </main>
  </div>

  <!-- Oferta (aparece a las 8:40 PM del 23 y se queda hasta medianoche). -->
  <div id="wb-oferta" hidden>
    <OfertaMillonaria />
  </div>

  <Footer />

  <style>
    #wb-evento[hidden], #wb-registro[hidden], #wb-cerrado[hidden], #wb-oferta[hidden] {
      display: none !important;
    }
    .wb-cerrado {
      min-height: 60vh;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 64px 0;
      background: var(--bg-hero, #f4f2fb);
    }
    .wb-cerrado__inner {
      max-width: 560px;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 16px;
    }
    .wb-cerrado__pill {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: #FFF0F0;
      color: #C0392B;
      font-weight: 700;
      font-size: 14px;
      padding: 6px 16px;
      border-radius: 100px;
      border: 1.5px solid #F5C6C6;
    }
    .wb-cerrado__title {
      font-family: var(--font-heading, 'Outfit', sans-serif);
      font-size: clamp(1.8rem, 5vw, 2.6rem);
      color: var(--color-heading, #2B2C64);
    }
    .wb-cerrado__sub {
      font-size: 1.05rem;
      color: var(--color-body, #4a4a68);
      line-height: 1.6;
    }
  </style>

  <script is:inline define:vars={{
    webinarInicioISO: WEBINAR_MANDAMIENTOS.fechaISO,
    ofertaInicioISO: PROMO_MILLONARIA.ofertaInicioISO,
    nocheFinISO: PROMO_MILLONARIA.nocheFinISO,
  }}>
    (function () {
      try {
        var ahora = Date.now();
        // Desde mañana (medianoche): la oferta vive en /fiestas-patrias.
        if (ahora >= Date.parse(nocheFinISO)) {
          window.location.replace('/fiestas-patrias');
          return;
        }
        var evento = document.getElementById('wb-evento');
        var registro = document.getElementById('wb-registro');
        var cerrado = document.getElementById('wb-cerrado');
        var oferta = document.getElementById('wb-oferta');
        if (ahora >= Date.parse(ofertaInicioISO)) {
          // 8:40 PM → medianoche: salta a la oferta.
          if (evento) evento.hidden = true;
          if (oferta) oferta.hidden = false;
        } else if (ahora >= Date.parse(webinarInicioISO)) {
          // 8:00 – 8:40 PM: registro cerrado.
          if (registro) registro.hidden = true;
          if (cerrado) cerrado.hidden = false;
        }
        // Antes de las 8:00: registro abierto (estado por defecto).
      } catch (e) {
        /* ante cualquier error, se queda el registro abierto */
      }
    })();
  </script>
</Layout>
