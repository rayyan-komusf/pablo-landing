---
// /webinar: registro del webinar. A las 8:00 PM del 23 (inicio del webinar)
// el registro se CIERRA (nadie más se inscribe). La oferta NO vive aquí: está
// en /fiestas-patrias. El cambio ocurre en el cliente por fecha, sin redeploy.
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import EventoMandamientos from '../../components/eventos/EventoMandamientos.astro';
import RegistroWebinar from '../../components/eventos/RegistroWebinar.astro';
import TestimoniosWebinar from '../../components/eventos/TestimoniosWebinar.astro';
import { WEBINAR_MANDAMIENTOS } from '../../siteConfig';
// src/pages/webinar/index.astro
---

<Layout
  title="Los 4 Mandamientos Financieros — Webinar gratis"
  description="Webinar en vivo y gratis: las 4 reglas simples para ordenar tu plata de una vez por todas. Jueves 23 de julio por YouTube."
>
  <Navbar />
  <main>
    <div id="wb-registro">
      <EventoMandamientos />
      <RegistroWebinar />
      <TestimoniosWebinar />
    </div>

    <div id="wb-cerrado" hidden>
      <section class="wb-cerrado">
        <div class="container wb-cerrado__inner">
          <span class="wb-cerrado__pill">🔴 En vivo ahora</span>
          <h1 class="wb-cerrado__title">El webinar ya empezó</h1>
          <p class="wb-cerrado__sub">
            El registro está cerrado. Si te inscribiste, revisa tu correo y tu
            WhatsApp: ahí está tu acceso al webinar.
          </p>
        </div>
      </section>
    </div>
  </main>
  <Footer />

  <style>
    #wb-registro[hidden], #wb-cerrado[hidden] { display: none !important; }
    .wb-cerrado {
      min-height: 60vh;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 64px 0;
      background: var(--bg-hero, #f4f2fb);
    }
    .wb-cerrado__inner {
      max-width: 560px;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 16px;
    }
    .wb-cerrado__pill {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: #FFF0F0;
      color: #C0392B;
      font-weight: 700;
      font-size: 14px;
      padding: 6px 16px;
      border-radius: 100px;
      border: 1.5px solid #F5C6C6;
    }
    .wb-cerrado__title {
      font-family: var(--font-heading, 'Outfit', sans-serif);
      font-size: clamp(1.8rem, 5vw, 2.6rem);
      color: var(--color-heading, #2B2C64);
    }
    .wb-cerrado__sub {
      font-size: 1.05rem;
      color: var(--color-body, #4a4a68);
      line-height: 1.6;
    }
  </style>

  <script is:inline define:vars={{ webinarInicioISO: WEBINAR_MANDAMIENTOS.fechaISO }}>
    // A las 8:00 PM del 23 (inicio del webinar) se cierra el registro.
    (function () {
      try {
        if (Date.now() < Date.parse(webinarInicioISO)) return;
        var reg = document.getElementById('wb-registro');
        var cerrado = document.getElementById('wb-cerrado');
        if (reg) reg.hidden = true;
        if (cerrado) cerrado.hidden = false;
      } catch (e) {
        /* ante cualquier error, se queda el registro abierto */
      }
    })();
  </script>
</Layout>
