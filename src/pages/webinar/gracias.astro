---
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import iconPablo from '../../assets/iconpablo.png';
import HeroPhone from '../../components/sections/HeroPhone.astro';
import { WEBINAR_MANDAMIENTOS as W } from '../../siteConfig';
// src/pages/webinar/gracias.astro — mensaje post-registro del webinar
---

<Layout
  title="¡Felicitaciones, tu lugar está reservado! — Los 4 Mandamientos Financieros"
  description="Te has registrado correctamente para asistir en vivo a Los 4 Mandamientos Financieros. Únete al grupo exclusivo de WhatsApp."
>
  <Navbar />
  <main>
    <section class="gracias">
      <div class="container gracias__inner">
        <!-- Primera vista: todo visible sin scroll, hasta la lista de desbloqueos -->
        <div class="gracias__fold">
        <!-- Cara de Pablo emocionada -->
        <div class="gracias__mascot">
          <Image src={iconPablo} alt="Pablo emocionado" width={110} height={110} />
        </div>

        <h1 class="gracias__title">¡Felicitaciones, tu lugar está <span class="highlight">reservado</span>! 🎉</h1>

        <p class="gracias__sub">
          Te has registrado correctamente para asistir, <strong>EN VIVO</strong>,
          a <strong>Los 4 Mandamientos Financieros</strong> — te hemos enviado un
          correo con todos los detalles.
        </p>

        <!-- CTA principal: la sala exclusiva es el grupo de WhatsApp -->
        <a
          href={W.whatsappUrl}
          class="gracias__sala"
          target="_blank"
          rel="noopener noreferrer"
          onclick="try{window.posthog?.capture('webinar_whatsapp_clicked',{webinar:'4_mandamientos'})}catch(e){};if(typeof fbq!=='undefined')fbq('trackCustom','Unirse_Grupo_WhatsApp');"
        >
          Ingresar a la sala exclusiva
          <span class="btn-arrow">→</span>
        </a>

        <!-- Qué desbloquea el grupo -->
        <div class="gracias__card">
          <p class="gracias__card-title">
            Ahora únete al grupo exclusivo de WhatsApp para desbloquear:
          </p>
          <ul class="gracias__unlocks">
            <li><span class="check">✓</span><span>El enlace para entrar al webinar.</span></li>
            <li><span class="check">✓</span><span>Recursos gratuitos antes y durante el en vivo.</span></li>
            <li><span class="check">✓</span><span>Recordatorios para que no te pierdas el evento.</span></li>
            <li><span class="check">✓</span><span>Información exclusiva para los participantes.</span></li>
          </ul>
        </div>
        </div>
      </div>
    </section>

    <!-- Pitch de Pablo -->
    <section class="pitch">
      <div class="container pitch__inner">
        <h2 class="pitch__title">
          Prueba a Pablo <span class="highlight">GRATIS por 7 días</span> antes del taller
        </h2>
        <p class="pitch__text">
          Pablo te ayuda a entender tus gastos, ahorrar mejor y dejar atrás el
          estrés financiero. <strong>Todo desde WhatsApp, sin complicarte.</strong>
        </p>

        <!-- Demo animada: Pablo registrando gastos por WhatsApp (misma del home) -->
        <div class="pitch__phone">
          <HeroPhone />
        </div>

        <a
          href="https://www.usapablo.com/#planes"
          class="pitch__cta"
          onclick="try{window.posthog?.capture('webinar_pitch_clicked',{webinar:'4_mandamientos'})}catch(e){};if(typeof fbq!=='undefined')fbq('trackCustom','Webinar_Prueba_Pablo');"
        >
          Desbloquea a Pablo
        </a>
      </div>
    </section>
  </main>
  <Footer />

  <!-- Pixel de Meta: conversión de registro completada -->
  <script is:inline>
    if (typeof fbq !== 'undefined') {
      fbq('track', 'CompleteRegistration', { content_name: 'webinar_4_mandamientos' });
    }
  </script>
</Layout>

<style>
  .gracias {
    background: var(--bg-hero);
    padding: 16px 0 60px;
  }

  .gracias__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 12px;
    max-width: 620px;
    margin: 0 auto;
  }

  /* Primera vista: llena la pantalla hasta la lista de desbloqueos,
     el pitch de Pablo queda debajo del fold */
  .gracias__fold {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 20px;
    width: 100%;
    min-height: calc(100vh - 96px);
    min-height: calc(100svh - 96px);
  }

  .gracias__mascot {
    width: 84px;
    height: 84px;
    animation: floatMascot 3s ease-in-out infinite;
  }

  .gracias__mascot :global(img) {
    width: 100%;
    height: 100%;
  }

  @keyframes floatMascot {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-6px); }
  }

  .gracias__title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 30px;
    line-height: 1.15;
    color: var(--color-heading);
  }

  .gracias__sub {
    font-size: 15px;
    line-height: 1.55;
    color: var(--color-body);
  }

  .gracias__sub strong {
    color: var(--color-heading);
  }

  /* CTA a la sala exclusiva (grupo de WhatsApp), amarillo Pablo */
  .gracias__sala {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    border-radius: 16px;
    padding: 14px 28px;
    font-weight: 800;
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    background: var(--color-amber);
    color: var(--color-navy);
    box-shadow: 0 4px 0 0 #c9820a;
    transition: transform 0.12s ease, box-shadow 0.12s ease;
  }

  .gracias__sala:hover {
    transform: translateY(-1px);
    box-shadow: 0 5px 0 0 #c9820a;
  }

  .gracias__sala:active {
    transform: translateY(3px);
    box-shadow: 0 1px 0 0 #c9820a;
  }

  .gracias__sala .btn-arrow {
    display: inline-block;
    transition: transform 0.2s ease;
  }

  .gracias__sala:hover .btn-arrow {
    transform: translateX(5px);
  }

  .gracias__card {
    background: white;
    border-radius: var(--radius-lg);
    padding: 20px 26px;
    box-shadow: var(--card-shadow);
    display: flex;
    flex-direction: column;
    gap: 14px;
    width: 100%;
    text-align: left;
  }

  .gracias__card-title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 16px;
    color: var(--color-heading);
    text-align: center;
  }

  .gracias__unlocks {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .gracias__unlocks li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    background: var(--bg-hero);
    border-radius: var(--radius-md);
    padding: 10px 14px;
    font-size: 13px;
    color: var(--color-heading);
    font-weight: 500;
    line-height: 1.5;
  }

  .check {
    font-weight: 800;
    font-size: 13px;
    color: var(--color-green);
    background: white;
    border-radius: 50%;
    width: 22px;
    height: 22px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    box-shadow: 0 1px 6px rgba(43, 44, 100, 0.1);
  }

  /* ── Pitch de Pablo (mobile-first): columna centrada con el botón
     justo debajo del celular; en desktop el teléfono va a la IZQUIERDA
     y el copy + botón a la derecha. Todo entra en una sola vista ── */
  .pitch {
    background: var(--bg-page);
    padding: 40px 0 56px;
  }

  .pitch__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 14px;
  }

  .pitch__title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 26px;
    line-height: 1.2;
    color: var(--color-heading);
  }

  /* Resaltador estable: pinta cada fragmento de línea, así "GRATIS por
     7 días" queda bien resaltado aunque el título se parta en 2 líneas */
  .pitch__title :global(.highlight) {
    background: linear-gradient(
      transparent 55%,
      var(--highlight-bg) 55%,
      var(--highlight-bg) 94%,
      transparent 94%
    );
    -webkit-box-decoration-break: clone;
    box-decoration-break: clone;
    border-radius: 3px;
  }

  .pitch__title :global(.highlight)::after {
    display: none;
  }

  .pitch__text {
    font-size: 15px;
    line-height: 1.6;
    color: var(--color-body);
  }

  .pitch__text strong {
    color: var(--color-heading);
  }

  /* Demo animada de Pablo en WhatsApp (misma del home) */
  .pitch__phone {
    display: flex;
    justify-content: center;
  }

  /* El teléfono se escala con el alto de pantalla para que la sección
     completa (título + texto + botón + celular) quepa en una vista */
  .pitch :global(.hphone) {
    --w: min(230px, calc((100svh - 430px) / 2));
    font-size: calc(var(--w) * 0.0412);
  }

  .pitch__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    border-radius: 16px;
    padding: 16px 32px;
    font-weight: 800;
    font-size: 15px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    background: var(--color-amber);
    color: var(--color-navy);
    box-shadow: 0 4px 0 0 #c9820a;
    transition: transform 0.12s ease, box-shadow 0.12s ease;
  }

  .pitch__cta:hover {
    transform: translateY(-1px);
    box-shadow: 0 5px 0 0 #c9820a;
  }

  .pitch__cta:active {
    transform: translateY(3px);
    box-shadow: 0 1px 0 0 #c9820a;
  }

  /* Desktop: teléfono a la IZQUIERDA, copy + botón a la derecha */
  @media (min-width: 769px) {
    .pitch {
      padding: 48px 0 64px;
    }

    .pitch__inner {
      display: grid;
      grid-template-columns: auto minmax(0, 400px);
      column-gap: 64px;
      row-gap: 18px;
      align-items: center;
      align-content: center;
      justify-content: center;
      text-align: left;
    }

    .pitch__phone {
      grid-column: 1;
      grid-row: 1 / 4;
    }

    .pitch__title {
      grid-column: 2;
      grid-row: 1;
      font-size: 32px;
      align-self: end;
    }

    .pitch__text {
      grid-column: 2;
      grid-row: 2;
      font-size: 17px;
    }

    .pitch__cta {
      grid-column: 2;
      grid-row: 3;
      justify-self: start;
      align-self: start;
    }

    .pitch :global(.hphone) {
      --w: min(280px, calc((100svh - 200px) / 2));
    }
  }

  @media (max-width: 768px) {
    .gracias {
      padding: 12px 0 56px;
    }

    .gracias__mascot {
      width: 68px;
      height: 68px;
    }

    .gracias__title {
      font-size: 24px;
    }

    .gracias__sub {
      font-size: 14px;
    }

    .gracias__card {
      padding: 16px 14px;
    }

    .gracias__sala {
      font-size: 13px;
      padding: 13px 22px;
    }

  }
</style>
