---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

const cursos = [
  {
    title: "Cómo ahorrar dinero como un futuro millonario",
    description: "Si te quedas en cero todos los meses y por más que aumentas tus ingresos no logras ahorrar, este curso es para ti.",
    niveles: [
      { label: "Nivel 1", videoId: "o4kCMoCpQ7I" },
      { label: "Nivel 2", videoId: "H-8B7RUHgh0" },
      { label: "Nivel 3", videoId: "Oe5CuEvjGmI" },
      { label: "Nivel 4", videoId: "VpFiXNpq7wI" },
    ],
  },
];
---

<Layout
  title="Cursos — Pablo"
  description="Aprende a manejar tu dinero con los cursos gratuitos de Pablo. Finanzas personales explicadas de forma simple."
>
  <Navbar />
  <main class="cursos-page">
    <div class="container">

      <div class="page-header">
        <div class="page-badge">🎓 Cursos gratuitos</div>
        <h1>Aprende con Pablo</h1>
        <p>Finanzas personales explicadas de forma simple, para que puedas tomar el control de tu dinero hoy.</p>
      </div>

      {cursos.map((curso) => (
        <div class="curso">
          <div class="curso__header">
            <h2 class="curso__title">{curso.title}</h2>
            <p class="curso__desc">{curso.description}</p>
          </div>
          <div class="curso__niveles">
            {curso.niveles.map((nivel) => (
              <div class="video-card" data-video-id={nivel.videoId}>
                <div class="video-facade" data-facade>
                  <img
                    src={`https://img.youtube.com/vi/${nivel.videoId}/hqdefault.jpg`}
                    alt={`${nivel.label} — ${curso.title}`}
                    class="video-thumbnail"
                    loading="lazy"
                  />
                  <div class="video-overlay">
                    <div class="play-btn">
                      <svg viewBox="0 0 24 24" fill="currentColor" width="28" height="28">
                        <path d="M8 5v14l11-7z"/>
                      </svg>
                    </div>
                  </div>
                  <span class="video-level-badge">{nivel.label}</span>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}

    </div>
  </main>
  <Footer />
</Layout>

<style>
  .cursos-page {
    min-height: 100vh;
    padding: 80px 0 120px;
    background: var(--bg-page);
  }

  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--gutter);
  }

  /* Header */
  .page-header {
    text-align: center;
    margin-bottom: 64px;
  }

  .page-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: #EAE8FF;
    color: var(--color-heading);
    font-size: 0.78rem;
    font-weight: 700;
    padding: 5px 14px;
    border-radius: 100px;
    margin-bottom: 18px;
  }

  .page-header h1 {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 5vw, 3rem);
    color: var(--color-heading);
    margin-bottom: 14px;
  }

  .page-header p {
    font-size: 1.05rem;
    color: var(--color-body);
    max-width: 480px;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* Curso block */
  .curso {
    margin-bottom: 64px;
  }

  .curso__header {
    margin-bottom: 28px;
  }

  .curso__title {
    font-family: var(--font-heading);
    font-size: clamp(1.25rem, 3vw, 1.6rem);
    color: var(--color-heading);
    margin-bottom: 8px;
  }

  .curso__desc {
    font-size: 0.95rem;
    color: var(--color-body);
    line-height: 1.65;
    max-width: 600px;
  }

  /* Niveles grid */
  .curso__niveles {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 20px;
  }

  /* Video card */
  .video-card {
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--color-heading);
    box-shadow: 0 4px 16px rgba(43, 44, 100, 0.1);
    cursor: pointer;
  }

  /* Facade (thumbnail + overlay) */
  .video-facade {
    position: relative;
    aspect-ratio: 16/9;
    overflow: hidden;
  }

  .video-thumbnail {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .video-card:hover .video-thumbnail {
    transform: scale(1.04);
  }

  .video-overlay {
    position: absolute;
    inset: 0;
    background: rgba(20, 20, 60, 0.35);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
  }

  .video-card:hover .video-overlay {
    background: rgba(20, 20, 60, 0.2);
  }

  .play-btn {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: white;
    color: var(--color-heading);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 16px rgba(0,0,0,0.25);
    transition: transform 0.2s ease, background 0.2s;
    padding-left: 3px;
  }

  .video-card:hover .play-btn {
    transform: scale(1.1);
    background: var(--color-amber);
  }

  .video-level-badge {
    position: absolute;
    top: 10px;
    left: 10px;
    background: var(--color-heading);
    color: white;
    font-size: 0.72rem;
    font-weight: 700;
    padding: 4px 10px;
    border-radius: 100px;
  }

  @media (max-width: 640px) {
    .curso__niveles {
      grid-template-columns: 1fr;
    }
  }

  /* Video modal */
  .video-modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(10, 10, 40, 0.82);
    z-index: 1000;
    align-items: center;
    justify-content: center;
    padding: 20px;
    backdrop-filter: blur(6px);
  }

  .video-modal-overlay.active {
    display: flex;
  }

  .video-modal {
    position: relative;
    width: 100%;
    max-width: 900px;
  }

  .video-modal__close {
    position: absolute;
    top: -44px;
    right: 0;
    background: rgba(255, 255, 255, 0.15);
    border: none;
    border-radius: 50%;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: white;
    font-size: 1.2rem;
    transition: background 0.2s;
  }

  .video-modal__close:hover {
    background: rgba(255, 255, 255, 0.28);
  }

  .video-modal__player {
    width: 100%;
    height: clamp(260px, 50vw, 506px);
    border-radius: 16px;
    overflow: hidden;
    background: black;
  }

  .video-modal__player iframe {
    width: 100%;
    height: 100%;
    border: none;
    display: block;
  }
</style>

<!-- Video modal -->
<div class="video-modal-overlay" id="video-modal-overlay">
  <div class="video-modal">
    <button class="video-modal__close" id="video-modal-close" aria-label="Cerrar">&times;</button>
    <div class="video-modal__player" id="video-modal-player"></div>
  </div>
</div>

<script>
  const overlay = document.getElementById('video-modal-overlay');
  const player = document.getElementById('video-modal-player');
  const closeBtn = document.getElementById('video-modal-close');

  function openVideo(videoId: string) {
    if (!player || !overlay) return;
    player.innerHTML = `<iframe
      src="https://www.youtube.com/embed/${videoId}?autoplay=1&rel=0"
      width="100%"
      height="100%"
      style="width:100%;height:100%;border:none;display:block;"
      allow="autoplay; encrypted-media; picture-in-picture"
      allowfullscreen
    ></iframe>`;
    overlay.classList.add('active');
    document.body.style.overflow = 'hidden';
  }

  function closeVideo() {
    if (!player || !overlay) return;
    overlay.classList.remove('active');
    player.innerHTML = '';
    document.body.style.overflow = '';
  }

  document.querySelectorAll('.video-card').forEach((card) => {
    card.addEventListener('click', () => {
      const videoId = (card as HTMLElement).dataset.videoId;
      if (videoId) openVideo(videoId);
    });
  });

  closeBtn?.addEventListener('click', closeVideo);
  overlay?.addEventListener('click', (e) => {
    if (e.target === overlay) closeVideo();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeVideo();
  });
</script>
