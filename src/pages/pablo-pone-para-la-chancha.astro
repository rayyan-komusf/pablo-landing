---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

const pasos = [
  "La próxima vez que salgas a comer, registra tu gasto con Pablo.",
  "Tómate una foto con tu comida y el gasto registrado con Pablo.",
  "Súbela junto a tu reseña de Google al restaurante.",
  "Mándanos la captura de tu reseña al soporte de Pablo.",
];
---

<Layout
  title="Pablo pone para la chancha — Pablo"
  description="Participa, sigue los pasos y Pablo pone para la chancha. Así de fácil."
>
  <Navbar />
  <main class="chancha-page">
    <div class="container">
      <div class="page-header">
        <h1>Pablo pone para la chancha</h1>
        <p>
          Participa, sigue los pasos y nosotros ponemos. Así de fácil se puede ganar con Pablo.
        </p>
      </div>

      <div class="chancha-hero">
        <div class="chancha-hero__images">
          <img src="/Pablo%20con%20billtes.png" alt="Pablo con billetes" class="hero-img hero-img--pablo" />
          <img src="/WhatsApp%20Image%202026-07-09%20at%203.20.13%20PM.jpeg" alt="Reseña de Google" class="hero-img hero-img--review" />
        </div>
        <button class="btn-canjea" id="btn-canjea">Canjea tu chancha</button>
      </div>

      <div class="chancha-banner">
        <div class="chancha-amount">S/.1,000</div>
        <div class="chancha-divider"></div>
        <div class="chancha-info">
          <p>Por cada reseña, <strong>Pablo</strong> pone <strong>S/20 para la chancha.</strong></p>
          <span>Hasta que se acabe la chancha.</span>
        </div>
      </div>

      <div class="steps-card">
        <p class="steps-label">Así de fácil se puede participar:</p>
        <ol class="steps-list">
          {pasos.map((paso, i) => (
            <li class="step">
              <span class="step-number">{i + 1}</span>
              <span class="step-text" set:html={paso.replace(/(Pablo)/g, '<strong>$1</strong>')} />
            </li>
          ))}
        </ol>
      </div>

      <div class="page-back">
        <a href="/promos">← Volver a Promos</a>
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .chancha-page {
    min-height: 100vh;
    padding: 80px 0 120px;
    background: var(--bg-page);
  }

  .container {
    max-width: 620px;
    margin: 0 auto;
    padding: 0 var(--gutter);
  }

  .page-header {
    text-align: center;
    margin-bottom: 56px;
  }

  .page-header h1 {
    font-family: var(--font-heading);
    font-size: clamp(1.8rem, 5vw, 2.8rem);
    color: var(--color-heading);
    margin-bottom: 16px;
  }

  .page-header p {
    font-size: 1.05rem;
    color: var(--color-body);
    line-height: 1.7;
    max-width: 480px;
    margin: 0 auto;
  }

  /* Hero images */
  .chancha-hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 28px;
    margin-bottom: 40px;
  }

  .chancha-hero__images {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    width: 100%;
  }

  .hero-img {
    width: 100%;
    height: 260px;
    object-fit: cover;
    border-radius: var(--radius-lg);
    display: block;
  }

  .hero-img--pablo {
    object-position: center top;
  }

  .btn-canjea {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 36px;
    background: var(--color-heading);
    color: white;
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 700;
    border: none;
    border-radius: var(--radius-pill);
    cursor: pointer;
    transition: background 0.2s ease, transform 0.15s ease;
  }

  .btn-canjea:hover {
    background: var(--color-amber);
    color: var(--color-heading);
    transform: translateY(-2px);
  }

  /* Modal */
  .modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(20, 20, 60, 0.6);
    z-index: 1000;
    align-items: center;
    justify-content: center;
    padding: 20px;
    backdrop-filter: blur(4px);
  }

  .modal-overlay.active {
    display: flex;
  }

  .modal {
    background: white;
    border-radius: 24px;
    width: 100%;
    max-width: 460px;
    max-height: 90vh;
    overflow-y: auto;
    position: relative;
    box-shadow: 0 32px 80px rgba(20, 20, 60, 0.22);
  }

  /* Modal header */
  .modal__header {
    background: var(--color-heading);
    border-radius: 24px 24px 0 0;
    padding: 28px 32px 24px;
    position: relative;
  }

  .modal__close {
    position: absolute;
    top: 18px;
    right: 18px;
    background: rgba(255, 255, 255, 0.12);
    border: none;
    border-radius: 50%;
    width: 34px;
    height: 34px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: white;
    font-size: 1.1rem;
    line-height: 1;
    transition: background 0.2s;
  }

  .modal__close:hover {
    background: rgba(255, 255, 255, 0.22);
  }

  .modal__tag {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    background: rgba(255, 255, 255, 0.12);
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    padding: 4px 10px;
    border-radius: 100px;
    margin-bottom: 12px;
  }

  .modal__title {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    color: white;
    margin: 0 0 4px;
    line-height: 1.2;
  }

  .modal__subtitle {
    font-size: 0.83rem;
    color: rgba(255, 255, 255, 0.55);
    margin: 0;
  }

  /* Modal body */
  .modal__body {
    padding: 28px 32px 32px;
  }

  .modal-form {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 7px;
  }

  .form-field label {
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--color-heading);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .form-field input[type="text"],
  .form-field input[type="tel"],
  .form-field input[type="email"] {
    width: 100%;
    padding: 12px 16px;
    border: 2px solid rgba(43, 44, 100, 0.1);
    border-radius: 12px;
    font-size: 0.95rem;
    color: var(--color-heading);
    background: #F8F8FC;
    outline: none;
    transition: border-color 0.2s, background 0.2s;
    box-sizing: border-box;
    font-family: inherit;
  }

  .form-field input[type="text"]::placeholder,
  .form-field input[type="tel"]::placeholder,
  .form-field input[type="email"]::placeholder {
    color: rgba(43, 44, 100, 0.35);
  }

  .form-field input:focus {
    border-color: var(--color-amber);
    background: white;
  }

  /* Custom file upload zone */
  .file-upload-zone {
    position: relative;
    border: 2px dashed rgba(43, 44, 100, 0.18);
    border-radius: 12px;
    padding: 20px 16px;
    text-align: center;
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
    background: #F8F8FC;
  }

  .file-upload-zone:hover {
    border-color: var(--color-amber);
    background: #FFFCF0;
  }

  .file-upload-zone.has-file {
    border-color: var(--color-amber);
    border-style: solid;
    background: #FFFCF0;
  }

  .file-upload-zone input[type="file"] {
    position: absolute;
    inset: 0;
    opacity: 0;
    width: 100%;
    height: 100%;
    cursor: pointer;
  }

  .file-upload-icon {
    font-size: 1.6rem;
    display: block;
    margin-bottom: 6px;
  }

  .file-upload-hint {
    font-size: 0.85rem;
    color: var(--color-body);
    line-height: 1.4;
  }

  .file-upload-hint strong {
    color: var(--color-heading);
  }

  .file-name-display {
    display: none;
    font-size: 0.82rem;
    color: var(--color-amber);
    font-weight: 600;
    margin-top: 6px;
  }

  .file-upload-zone.has-file .file-name-display {
    display: block;
  }

  .file-upload-zone.has-file .file-upload-hint {
    display: none;
  }

  /* Checkbox */
  .checkbox-row {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    background: rgba(43, 44, 100, 0.04);
    border-radius: 12px;
    padding: 14px 16px;
  }

  .checkbox-row input[type="checkbox"] {
    margin-top: 2px;
    width: 17px;
    height: 17px;
    accent-color: var(--color-amber);
    flex-shrink: 0;
    cursor: pointer;
  }

  .checkbox-row label {
    font-size: 0.83rem;
    color: var(--color-body);
    line-height: 1.55;
    cursor: pointer;
  }

  .checkbox-row a {
    color: var(--color-amber);
    font-weight: 700;
    text-decoration: none;
  }

  .checkbox-row a:hover {
    text-decoration: underline;
  }

  /* Submit button */
  .btn-submit-canjea {
    width: 100%;
    padding: 15px;
    background: var(--color-amber);
    color: var(--color-heading);
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 700;
    border: none;
    border-radius: var(--radius-pill);
    cursor: pointer;
    transition: background 0.2s, transform 0.15s, opacity 0.2s;
    margin-top: 4px;
  }

  .btn-submit-canjea:not(:disabled):hover {
    background: #e09800;
    transform: translateY(-1px);
  }

  .btn-submit-canjea:disabled {
    background: rgba(43, 44, 100, 0.1);
    color: rgba(43, 44, 100, 0.35);
    cursor: default;
  }

  /* Success state */
  .modal-success {
    text-align: center;
    padding: 16px 0 8px;
  }

  .modal-success__icon {
    font-size: 2.8rem;
    margin-bottom: 16px;
    display: block;
  }

  .modal-success h3 {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    color: var(--color-heading);
    margin-bottom: 10px;
  }

  .modal-success p {
    font-size: 0.9rem;
    color: var(--color-body);
    line-height: 1.65;
  }

  /* Chancha banner */
  .chancha-banner {
    display: flex;
    align-items: center;
    gap: 20px;
    background: var(--color-heading);
    border-radius: var(--radius-lg);
    padding: 24px 32px;
    margin-bottom: 16px;
  }

  .chancha-amount {
    font-family: var(--font-heading);
    font-size: 2.4rem;
    font-weight: 700;
    color: white;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .chancha-divider {
    width: 2px;
    height: 48px;
    background: rgba(255, 255, 255, 0.2);
    border-radius: 2px;
    flex-shrink: 0;
  }

  .chancha-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .chancha-info p {
    font-size: 0.97rem;
    color: white;
    line-height: 1.5;
    margin: 0;
  }

  .chancha-info strong {
    color: var(--color-amber);
  }

  .chancha-info span {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.55);
  }

  /* Steps card */
  .steps-card {
    background: var(--color-heading);
    border-radius: var(--radius-lg);
    padding: 36px 40px;
  }

  .steps-label {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 700;
    color: white;
    margin-bottom: 28px;
  }

  .steps-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .step {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    background: white;
    border-radius: 12px;
    padding: 16px 20px;
  }

  .step-number {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--color-amber);
    color: var(--color-heading);
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1rem;
    flex-shrink: 0;
  }

  .step-text {
    font-size: 0.97rem;
    color: var(--color-heading);
    line-height: 1.6;
    padding-top: 6px;
  }

  .step-text :global(strong) {
    color: var(--color-purple, #2B2C64);
  }

  /* Back link */
  .page-back {
    margin-top: 48px;
    text-align: center;
  }

  .page-back a {
    font-size: 0.9rem;
    color: var(--color-body);
    font-weight: 500;
    transition: color 0.15s;
  }

  .page-back a:hover {
    color: var(--color-heading);
  }

  @media (max-width: 640px) {
    .steps-card {
      padding: 28px 24px;
    }

    .chancha-hero__images {
      grid-template-columns: 1fr;
    }

    .hero-img {
      height: 200px;
    }
  }
</style>

<!-- Modal canjea tu chancha -->
<div class="modal-overlay" id="canjea-modal">
  <div class="modal" role="dialog" aria-modal="true" aria-labelledby="modal-title">

    <div class="modal__header">
      <button class="modal__close" id="modal-close" aria-label="Cerrar">&times;</button>
      <div class="modal__tag">🐷 Campaña activa</div>
      <h2 class="modal__title" id="modal-title">Canjea tu chancha</h2>
      <p class="modal__subtitle">Completa los datos y revisamos tu reseña en 24–48 h.</p>
    </div>

    <div class="modal__body">
      <div id="modal-form-content">
        <form class="modal-form" id="canjea-form" novalidate>
          <div class="form-field">
            <label for="canjea-nombre">Nombre completo</label>
            <input type="text" id="canjea-nombre" name="nombre" placeholder="Tu nombre" required />
          </div>
          <div class="form-field">
            <label for="canjea-numero">Número de WhatsApp</label>
            <input type="tel" id="canjea-numero" name="numero" placeholder="+51 999 999 999" required />
          </div>
          <div class="form-field">
            <label for="canjea-correo">Correo de tu cuenta Pablo</label>
            <input type="email" id="canjea-correo" name="correo" placeholder="correo@ejemplo.com" required />
          </div>
          <div class="form-field">
            <label>Captura de tu reseña</label>
            <div class="file-upload-zone" id="file-upload-zone">
              <input type="file" id="canjea-captura" name="captura" accept="image/*" required />
              <span class="file-upload-icon">📎</span>
              <p class="file-upload-hint"><strong>Sube tu captura</strong><br/>PNG, JPG o WEBP</p>
              <p class="file-name-display" id="file-name-display"></p>
            </div>
          </div>
          <div class="checkbox-row">
            <input type="checkbox" id="canjea-terms" name="terms" required />
            <label for="canjea-terms">
              Acepto los <a href="/terminos-condiciones-chancha" target="_blank">Términos y Condiciones</a> de la campaña.
            </label>
          </div>
          <button type="submit" class="btn-submit-canjea" id="btn-submit-canjea" disabled>Enviar solicitud</button>
        </form>
      </div>

      <div id="modal-success" class="modal-success" style="display:none">
        <span class="modal-success__icon">🎉</span>
        <h3>¡Ya recibimos tu canje!</h3>
        <p>Revisaremos tu reseña y nos contactaremos contigo para coordinar tu recompensa. ¡Gracias por participar!</p>
      </div>
    </div>

  </div>
</div>

<script>
  const overlay = document.getElementById('canjea-modal');
  const btnOpen = document.getElementById('btn-canjea');
  const btnClose = document.getElementById('modal-close');
  const form = document.getElementById('canjea-form') as HTMLFormElement;
  const successMsg = document.getElementById('modal-success');
  const submitBtn = document.getElementById('btn-submit-canjea') as HTMLButtonElement;

  function openModal() {
    overlay?.classList.add('active');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    overlay?.classList.remove('active');
    document.body.style.overflow = '';
  }

  btnOpen?.addEventListener('click', openModal);
  btnClose?.addEventListener('click', closeModal);
  overlay?.addEventListener('click', (e) => {
    if (e.target === overlay) closeModal();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
  });

  const termsCheckbox = document.getElementById('canjea-terms') as HTMLInputElement;
  termsCheckbox?.addEventListener('change', () => {
    submitBtn.disabled = !termsCheckbox.checked;
  });

  const fileInput = document.getElementById('canjea-captura') as HTMLInputElement;
  const fileZone = document.getElementById('file-upload-zone');
  const fileNameDisplay = document.getElementById('file-name-display');
  fileInput?.addEventListener('change', () => {
    const file = fileInput.files?.[0];
    if (file && fileNameDisplay && fileZone) {
      fileNameDisplay.textContent = file.name;
      fileZone.classList.add('has-file');
    }
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const file = fileInput?.files?.[0];

    let fileBase64 = '';
    let fileName = '';
    if (file) {
      fileBase64 = await new Promise<string>((resolve) => {
        const reader = new FileReader();
        reader.onload = () => {
          const result = reader.result as string;
          resolve(result.split(',')[1]);
        };
        reader.readAsDataURL(file);
      });
      fileName = file.name;
    }

    const payload = {
      tipo: 'canjea_chancha',
      nombre: (document.getElementById('canjea-nombre') as HTMLInputElement)?.value,
      numero: (document.getElementById('canjea-numero') as HTMLInputElement)?.value,
      correo: (document.getElementById('canjea-correo') as HTMLInputElement)?.value,
      capturaBase64: fileBase64,
      capturaFileName: fileName,
    };

    submitBtn.disabled = true;
    submitBtn.textContent = 'Enviando...';

    const endpoint = import.meta.env.PUBLIC_CHANCHA_ENDPOINT;
    if (!endpoint) {
      alert('Error de configuración. Intenta más tarde.');
      submitBtn.disabled = false;
      submitBtn.textContent = 'Enviar';
      return;
    }

    try {
      await fetch(endpoint, {
        method: 'POST',
        body: JSON.stringify(payload),
        headers: { 'Content-Type': 'text/plain' },
      });
      document.getElementById('modal-form-content')!.style.display = 'none';
      successMsg!.style.display = 'block';
    } catch {
      alert('Hubo un error al enviar. Intenta de nuevo.');
      submitBtn.disabled = false;
      submitBtn.textContent = 'Enviar';
    }
  });
</script>
