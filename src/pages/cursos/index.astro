---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import { CURSO, SESIONES } from "../../lib/cursos";
---

<Layout
  title="Cursos — Pablo"
  description="Camino al Millón: el programa gratuito de finanzas de Pablo. Ahorro, presupuesto, metas y deudas explicados de forma simple."
>
  <Navbar />
  <main class="cursos-page">
    <div class="container">

      <div class="page-header">
        <div class="page-badge">🎓 Cursos gratuitos</div>
        <h1>Aprende con Pablo</h1>
        <p>Finanzas personales explicadas de forma simple, para que puedas tomar el control de tu dinero hoy.</p>
      </div>

      <!-- Catálogo estilo blog: tarjeta con la portada y el título abajo -->
      <div class="cursos-grid">
        <a href={`/cursos/${CURSO.slug}`} class="curso-card">
          <div class="curso-card__cover">
            <img
              src={CURSO.portada}
              alt={`Portada del curso ${CURSO.title}`}
              width="640"
              height="330"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="curso-card__body">
            <div class="curso-card__meta">
              <span class="curso-card__sesiones">{SESIONES.length} sesiones</span>
              <span class="curso-card__sep">|</span>
              <span class="curso-card__gratis">Gratis</span>
            </div>
            <h2 class="curso-card__title">{CURSO.title}</h2>
            <p class="curso-card__subtitle">{CURSO.subtitle}</p>
          </div>
        </a>
      </div>

    </div>
  </main>
  <Footer />
</Layout>

<style>
  .cursos-page {
    min-height: 100vh;
    padding: clamp(24px, 5vw, 56px) 0 120px;
    background: var(--bg-page);
  }

  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--gutter);
  }

  /* Header */
  .page-header {
    text-align: center;
    margin-bottom: 64px;
  }

  .page-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: #EAE8FF;
    color: var(--color-heading);
    font-size: 0.78rem;
    font-weight: 700;
    padding: 5px 14px;
    border-radius: 100px;
    margin-bottom: 18px;
  }

  .page-header h1 {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 5vw, 3rem);
    color: var(--color-heading);
    margin-bottom: 14px;
  }

  .page-header p {
    font-size: 1.05rem;
    color: var(--color-body);
    max-width: 480px;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* Grid de cursos (mismo lenguaje que el blog) */
  .cursos-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 40px 32px;
    max-width: 640px;
    margin: 0 auto;
  }

  .curso-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    gap: 16px;
  }

  .curso-card__cover {
    width: 100%;
    aspect-ratio: 16/9;
    overflow: hidden;
    border-radius: var(--radius-md);
    box-shadow: 0 4px 16px rgba(43, 44, 100, 0.12);
  }

  .curso-card__cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .curso-card:hover .curso-card__cover img {
    transform: scale(1.04);
  }

  .curso-card__body {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .curso-card__meta {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .curso-card__sesiones,
  .curso-card__gratis {
    font-size: 0.78rem;
    color: var(--color-secondary);
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .curso-card__sep {
    font-size: 0.78rem;
    color: var(--color-secondary);
    opacity: 0.4;
  }

  .curso-card__title {
    font-family: var(--font-heading);
    font-size: 1.35rem;
    color: var(--color-heading);
    line-height: 1.3;
    transition: color 0.15s;
  }

  .curso-card:hover .curso-card__title {
    color: var(--color-purple);
  }

  .curso-card__subtitle {
    font-size: 0.92rem;
    color: var(--color-body);
    line-height: 1.5;
  }

  @media (max-width: 640px) {
    .cursos-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
