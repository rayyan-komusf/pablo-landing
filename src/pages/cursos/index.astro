---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import { CURSO, SESIONES } from "../../lib/cursos";
---

<Layout
  title="Cursos — Pablo"
  description="Camino al Millón: el programa gratuito de finanzas de Pablo. Ahorro, presupuesto, metas y deudas explicados de forma simple."
>
  <Navbar />
  <main class="cursos-page">
    <div class="container">

      <div class="page-header">
        <div class="page-badge">🎓 Cursos gratuitos</div>
        <h1>Aprende con Pablo</h1>
        <p>Finanzas personales explicadas de forma simple, para que puedas tomar el control de tu dinero hoy.</p>
      </div>

      <div class="curso">
        <img
          src={CURSO.portada}
          alt={`Portada del curso ${CURSO.title}`}
          class="curso__portada"
          loading="lazy"
        />
        <div class="curso__header">
          <h2 class="curso__title">{CURSO.title}</h2>
          <p class="curso__desc">{CURSO.description}</p>
        </div>
        <div class="curso__sesiones">
          {SESIONES.map((sesion) => (
            <a class="video-card" href={`/cursos/${sesion.slug}`}>
              <div class="video-facade">
                <img
                  src={`https://img.youtube.com/vi/${sesion.videoId}/hqdefault.jpg`}
                  alt={`${sesion.label}: ${sesion.nombre} — ${CURSO.title}`}
                  class="video-thumbnail"
                  loading="lazy"
                />
                <div class="video-overlay">
                  <div class="play-btn">
                    <svg viewBox="0 0 24 24" fill="currentColor" width="28" height="28">
                      <path d="M8 5v14l11-7z"/>
                    </svg>
                  </div>
                </div>
                <span class="video-level-badge">{sesion.label}</span>
              </div>
              <div class="video-card__body">
                <span class="video-card__nombre">{sesion.nombre}</span>
                <span class="video-card__ver">Ver clase</span>
              </div>
            </a>
          ))}
        </div>
      </div>

    </div>
  </main>
  <Footer />
</Layout>

<style>
  .cursos-page {
    min-height: 100vh;
    padding: 80px 0 120px;
    background: var(--bg-page);
  }

  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--gutter);
  }

  /* Header */
  .page-header {
    text-align: center;
    margin-bottom: 64px;
  }

  .page-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: #EAE8FF;
    color: var(--color-heading);
    font-size: 0.78rem;
    font-weight: 700;
    padding: 5px 14px;
    border-radius: 100px;
    margin-bottom: 18px;
  }

  .page-header h1 {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 5vw, 3rem);
    color: var(--color-heading);
    margin-bottom: 14px;
  }

  .page-header p {
    font-size: 1.05rem;
    color: var(--color-body);
    max-width: 480px;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* Curso block */
  .curso {
    margin-bottom: 64px;
  }

  .curso__portada {
    width: 100%;
    border-radius: var(--radius-lg);
    box-shadow: 0 4px 16px rgba(43, 44, 100, 0.12);
    margin-bottom: 28px;
    display: block;
  }

  .curso__header {
    margin-bottom: 28px;
  }

  .curso__title {
    font-family: var(--font-heading);
    font-size: clamp(1.25rem, 3vw, 1.6rem);
    color: var(--color-heading);
    margin-bottom: 8px;
  }

  .curso__desc {
    font-size: 0.95rem;
    color: var(--color-body);
    line-height: 1.65;
    max-width: 600px;
  }

  /* Sesiones grid */
  .curso__sesiones {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 20px;
  }

  /* Video card */
  .video-card {
    display: block;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--color-heading);
    box-shadow: 0 4px 16px rgba(43, 44, 100, 0.1);
    cursor: pointer;
  }

  .video-card__body {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    padding: 12px 16px;
  }

  .video-card__nombre {
    color: white;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1rem;
  }

  .video-card__ver {
    color: rgba(255, 255, 255, 0.75);
    font-size: 0.78rem;
    font-weight: 600;
  }

  /* Facade (thumbnail + overlay) */
  .video-facade {
    position: relative;
    aspect-ratio: 16/9;
    overflow: hidden;
  }

  .video-thumbnail {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .video-card:hover .video-thumbnail {
    transform: scale(1.04);
  }

  .video-overlay {
    position: absolute;
    inset: 0;
    background: rgba(20, 20, 60, 0.35);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
  }

  .video-card:hover .video-overlay {
    background: rgba(20, 20, 60, 0.2);
  }

  .play-btn {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: white;
    color: var(--color-heading);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 16px rgba(0,0,0,0.25);
    transition: transform 0.2s ease, background 0.2s;
    padding-left: 3px;
  }

  .video-card:hover .play-btn {
    transform: scale(1.1);
    background: var(--color-amber);
  }

  .video-level-badge {
    position: absolute;
    top: 10px;
    left: 10px;
    background: var(--color-heading);
    color: white;
    font-size: 0.72rem;
    font-weight: 700;
    padding: 4px 10px;
    border-radius: 100px;
  }

  @media (max-width: 640px) {
    .curso__sesiones {
      grid-template-columns: 1fr;
    }
  }
</style>
