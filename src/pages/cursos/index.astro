---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import { CURSO, SESIONES } from "../../lib/cursos";
---

<Layout
  title="Cursos — Pablo"
  description="Camino al Millón: el programa gratuito de finanzas de Pablo. Ahorro, presupuesto, metas y deudas explicados de forma simple."
>
  <Navbar />
  <main class="cursos-page">
    <div class="container">

      <div class="page-header">
        <div class="page-badge">🎓 Cursos gratuitos</div>
        <h1>Aprende con Pablo</h1>
        <p>Finanzas personales explicadas de forma simple, para que puedas tomar el control de tu dinero hoy.</p>
      </div>

      <!-- Catálogo: tarjeta del curso con la portada y el título abajo -->
      <div class="cursos-grid">
        <a href={`/cursos/${CURSO.slug}`} class="curso-card">
          <div class="curso-card__cover">
            <img
              src={CURSO.portada}
              alt={`Portada del curso ${CURSO.title}`}
              width="640"
              height="330"
              loading="lazy"
              decoding="async"
            />
            <span class="curso-card__gratis">Gratis</span>
          </div>
          <div class="curso-card__body">
            <h2 class="curso-card__title">{CURSO.title}</h2>
            <p class="curso-card__subtitle">{CURSO.subtitle}</p>
            <div class="curso-card__chips">
              {SESIONES.map((sesion, i) => (
                <span class="curso-card__chip">
                  <span class="curso-card__chip-num">{i + 1}</span>
                  {sesion.nombre}
                </span>
              ))}
            </div>
            <div class="curso-card__footer">
              <span class="curso-card__cert">🏆 Con certificado</span>
              <span class="curso-card__btn">Empezar gratis →</span>
            </div>
          </div>
        </a>
      </div>

    </div>
  </main>
  <Footer />
</Layout>

<style>
  .cursos-page {
    min-height: 100vh;
    padding: clamp(24px, 5vw, 56px) 0 120px;
    background: var(--bg-page);
  }

  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--gutter);
  }

  /* Header */
  .page-header {
    text-align: center;
    margin-bottom: 64px;
  }

  .page-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: #EAE8FF;
    color: var(--color-heading);
    font-size: 0.78rem;
    font-weight: 700;
    padding: 5px 14px;
    border-radius: 100px;
    margin-bottom: 18px;
  }

  .page-header h1 {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 5vw, 3rem);
    color: var(--color-heading);
    margin-bottom: 14px;
  }

  .page-header p {
    font-size: 1.05rem;
    color: var(--color-body);
    max-width: 480px;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* Grid de cursos */
  .cursos-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 40px 32px;
    max-width: 560px;
    margin: 0 auto;
  }

  /* Tarjeta del curso: card blanca estilo Duo (borde inferior 3D suave) */
  .curso-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    background: #fff;
    border-radius: 24px;
    overflow: hidden;
    border: 2px solid #e9e6f8;
    box-shadow: 0 4px 0 0 #e0dcf3, 0 16px 40px rgba(43, 44, 100, 0.1);
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }

  .curso-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 7px 0 0 #e0dcf3, 0 22px 48px rgba(43, 44, 100, 0.14);
  }

  .curso-card:active {
    transform: translateY(2px);
    box-shadow: 0 2px 0 0 #e0dcf3, 0 10px 28px rgba(43, 44, 100, 0.1);
  }

  .curso-card__cover {
    position: relative;
    width: 100%;
    aspect-ratio: 16/9;
    overflow: hidden;
  }

  .curso-card__cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .curso-card:hover .curso-card__cover img {
    transform: scale(1.04);
  }

  .curso-card__gratis {
    position: absolute;
    top: 12px;
    right: 12px;
    background: var(--color-amber);
    color: #2b2c64;
    font-size: 0.72rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    padding: 5px 12px;
    border-radius: 100px;
    box-shadow: 0 2px 0 0 #c9820a;
  }

  .curso-card__body {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 20px 22px 22px;
  }

  .curso-card__title {
    font-family: var(--font-heading);
    font-size: 1.45rem;
    color: var(--color-heading);
    line-height: 1.25;
  }

  .curso-card__subtitle {
    font-size: 0.92rem;
    color: var(--color-body);
    line-height: 1.5;
  }

  /* Las 4 sesiones como chips numerados */
  .curso-card__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 8px;
  }

  .curso-card__chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: #f1effb;
    color: var(--color-heading);
    font-size: 0.8rem;
    font-weight: 700;
    padding: 5px 12px 5px 6px;
    border-radius: 100px;
  }

  .curso-card__chip-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: var(--color-heading);
    color: #fff;
    font-size: 0.68rem;
    font-weight: 800;
  }

  .curso-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-top: 14px;
    padding-top: 16px;
    border-top: 1px solid #efedf9;
  }

  .curso-card__cert {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-secondary);
  }

  .curso-card__btn {
    background: var(--color-amber);
    color: #2b2c64;
    font-weight: 800;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 10px 18px;
    border-radius: 12px;
    box-shadow: 0 3px 0 0 #c9820a;
    transition: transform 0.12s ease, box-shadow 0.12s ease;
    white-space: nowrap;
  }

  .curso-card:hover .curso-card__btn {
    transform: translateY(-1px);
    box-shadow: 0 4px 0 0 #c9820a;
  }

  @media (max-width: 640px) {
    .cursos-grid {
      grid-template-columns: 1fr;
    }

    .curso-card__body {
      padding: 18px 18px 20px;
    }
  }
</style>
