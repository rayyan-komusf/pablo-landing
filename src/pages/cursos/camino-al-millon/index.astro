---
import Layout from "../../../layouts/Layout.astro";
import Navbar from "../../../components/Navbar.astro";
import Footer from "../../../components/Footer.astro";
import CursoLoginModal from "../../../components/CursoLoginModal.astro";
import { CURSO, SESIONES } from "../../../lib/cursos";

// Página del curso estilo Anthropic Academy: portada + descripción + login
// + currículum visible. Las clases son EXCLUSIVAS para cuentas con
// suscripción de Pablo: el gate lo valida la edge function curso-acceso.
---

<Layout
  title={`${CURSO.title} — Cursos — Pablo`}
  description={`${CURSO.title}: ${CURSO.description}`}
>
  <Navbar />
  <main class="curso-page">
    <div class="container">

      <header class="curso-header">
        <a href="/cursos" class="curso-badge">🎓 Curso exclusivo para usuarios de Pablo</a>
        <h1>{CURSO.title}</h1>
        <p class="curso-subtitle">{CURSO.subtitle}</p>
      </header>

      <img
        src={CURSO.portada}
        alt={`Portada del curso ${CURSO.title}`}
        class="curso-portada"
        fetchpriority="high"
        decoding="async"
      />

      <p class="curso-desc">{CURSO.description}</p>

      <div class="curso-inscribir">
        <button
          class="curso-cta"
          id="curso-cta-inscribir"
          data-inscrito-label="Continuar el curso →"
        >Inicia sesión para ver el curso</button>
        <p class="curso-cta-nota" id="curso-cta-nota">
          El curso está incluido con tu suscripción de Pablo. Entra con la
          misma cuenta que usas en la app.
        </p>
      </div>

      <h2 class="curriculum-titulo">Las clases</h2>

      <!-- Sesiones estilo blog: tarjeta con la miniatura y el título abajo -->
      <div class="sesiones-grid">
        {SESIONES.map((sesion, i) => (
          <a
            href={`/cursos/${CURSO.slug}/${sesion.slug}`}
            class="sesion-card"
            data-sesion-link
            data-sesion={sesion.slug}
            data-index={i}
          >
            <div class="sesion-card__cover">
              <img
                src={`https://img.youtube.com/vi/${sesion.videoId}/hqdefault.jpg`}
                alt={`${sesion.label}: ${sesion.nombre} — ${CURSO.title}`}
                width="640"
                height="360"
                loading="lazy"
                decoding="async"
              />
              <div class="sesion-card__overlay">
                <div class="sesion-card__play" data-play-icon>
                  <svg viewBox="0 0 24 24" fill="currentColor" width="26" height="26">
                    <path d="M8 5v14l11-7z"/>
                  </svg>
                </div>
                <div class="sesion-card__lock" data-lock-icon hidden>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="24" height="24">
                    <rect x="3" y="11" width="18" height="11" rx="2"/>
                    <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                  </svg>
                </div>
              </div>
            </div>
            <div class="sesion-card__body">
              <div class="sesion-card__meta">
                <span class="sesion-card__label">{sesion.label}</span>
                <span class="sesion-card__done" data-done={sesion.slug} hidden>✓ Completada</span>
                <span class="sesion-card__pend" data-pend={sesion.slug} hidden>🔒 Completa la anterior</span>
              </div>
              <h3 class="sesion-card__title">{sesion.nombre}</h3>
            </div>
          </a>
        ))}
      </div>

      <div class="curso-back">
        <a href="/cursos">← Volver a cursos</a>
      </div>

    </div>
  </main>
  <CursoLoginModal />
  <Footer />
</Layout>

<style>
  .curso-page {
    min-height: 100vh;
    padding: clamp(24px, 5vw, 56px) 0 120px;
    background: var(--bg-page);
  }

  .container {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 var(--gutter);
  }

  .curso-header {
    text-align: center;
    margin-bottom: 32px;
  }

  .curso-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: #EAE8FF;
    color: var(--color-heading);
    font-size: 0.78rem;
    font-weight: 700;
    padding: 5px 14px;
    border-radius: 100px;
    margin-bottom: 18px;
    transition: transform 0.15s ease;
  }

  .curso-badge:hover {
    transform: scale(1.04);
  }

  .curso-header h1 {
    font-family: var(--font-heading);
    font-size: clamp(1.9rem, 4.5vw, 2.8rem);
    color: var(--color-heading);
    line-height: 1.2;
    margin-bottom: 8px;
  }

  .curso-subtitle {
    font-size: 1.05rem;
    color: var(--color-body);
    font-weight: 600;
  }

  .curso-portada {
    width: 100%;
    border-radius: var(--radius-lg);
    box-shadow: 0 4px 16px rgba(43, 44, 100, 0.12);
    margin-bottom: 28px;
    display: block;
  }

  .curso-desc {
    font-size: 1.05rem;
    color: var(--color-body);
    line-height: 1.75;
    text-align: center;
    max-width: 600px;
    margin: 0 auto 32px;
  }

  /* Inscripción (como el Register | FREE de Anthropic) */
  .curso-inscribir {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    margin-bottom: 56px;
  }

  .curso-cta {
    display: block;
    width: 100%;
    max-width: 340px;
    border: none;
    cursor: pointer;
    text-align: center;
    border-radius: 16px;
    padding: 16px 22px;
    font-family: var(--font-body);
    font-weight: 800;
    font-size: 15px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    background: var(--color-ambar, #fba920);
    color: #2b2c64;
    box-shadow: 0 4px 0 0 #c9820a;
    transition: transform 0.12s ease, box-shadow 0.12s ease;
  }

  .curso-cta:hover {
    transform: translateY(-1px);
    box-shadow: 0 5px 0 0 #c9820a;
  }

  .curso-cta:active {
    transform: translateY(3px);
    box-shadow: 0 1px 0 0 #c9820a;
  }

  .curso-cta-nota {
    font-size: 0.85rem;
    color: var(--color-secondary);
    text-align: center;
    max-width: 400px;
    line-height: 1.5;
  }

  .curriculum-titulo {
    font-family: var(--font-heading);
    font-size: clamp(1.25rem, 3vw, 1.6rem);
    color: var(--color-heading);
    margin-bottom: 24px;
  }

  /* Sesiones estilo blog: título afuera, debajo de la imagen */
  .sesiones-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 40px 32px;
  }

  .sesion-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    gap: 14px;
  }

  .sesion-card__cover {
    position: relative;
    width: 100%;
    aspect-ratio: 16/9;
    overflow: hidden;
    border-radius: var(--radius-md);
    box-shadow: 0 4px 16px rgba(43, 44, 100, 0.12);
  }

  .sesion-card__cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .sesion-card:hover .sesion-card__cover img {
    transform: scale(1.04);
  }

  .sesion-card__overlay {
    position: absolute;
    inset: 0;
    background: rgba(20, 20, 60, 0.28);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
  }

  .sesion-card:hover .sesion-card__overlay {
    background: rgba(20, 20, 60, 0.16);
  }

  .sesion-card__play {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: white;
    color: var(--color-heading);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 16px rgba(0,0,0,0.25);
    transition: transform 0.2s ease, background 0.2s;
    padding-left: 3px;
    font-size: 1.1rem;
  }

  .sesion-card:hover .sesion-card__play {
    transform: scale(1.1);
    background: var(--color-amber);
  }

  /* Candado de las sesiones bloqueadas (orden estricto) */
  .sesion-card__lock {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: rgba(43, 44, 100, 0.85);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.25);
  }

  .sesion-card__lock[hidden] {
    display: none;
  }

  /* Tarjeta bloqueada: no navega, se ve apagada, oculta el play */
  .sesion-card.locked {
    cursor: not-allowed;
    pointer-events: none;
  }

  .sesion-card.locked .sesion-card__cover img {
    filter: grayscale(0.7) brightness(0.85);
  }

  .sesion-card.locked .sesion-card__overlay {
    background: rgba(20, 20, 60, 0.45);
  }

  .sesion-card.locked .sesion-card__play {
    display: none;
  }

  .sesion-card__body {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .sesion-card__meta {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .sesion-card__label {
    font-size: 0.78rem;
    color: var(--color-secondary);
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .sesion-card__done {
    font-size: 0.72rem;
    font-weight: 800;
    color: #2a7a52;
    background: #ebf9f0;
    padding: 2px 10px;
    border-radius: 100px;
  }

  .sesion-card__done[hidden] {
    display: none;
  }

  .sesion-card__pend {
    font-size: 0.72rem;
    font-weight: 800;
    color: #875a00;
    background: #fef3da;
    padding: 2px 10px;
    border-radius: 100px;
  }

  .sesion-card__pend[hidden] {
    display: none;
  }

  .sesion-card__title {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    color: var(--color-heading);
    line-height: 1.3;
    transition: color 0.15s;
  }

  .sesion-card:hover .sesion-card__title {
    color: var(--color-purple);
  }

  .curso-back {
    margin-top: 72px;
    padding-top: 32px;
    border-top: 1px solid rgba(43, 44, 100, 0.1);
  }

  .curso-back a {
    color: var(--color-body);
    font-weight: 500;
    transition: color 0.15s;
  }

  .curso-back a:hover {
    color: var(--color-heading);
  }

  @media (max-width: 640px) {
    .sesiones-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  import { CURSO, SESIONES } from "../../../lib/cursos";
  import { haySesionCurso, verificarAccesoCurso } from "../../../lib/cursoAcceso";

  // Estado del gate: se resuelve async contra la edge function curso-acceso.
  let desbloqueado = false; // hay suscripción activa
  // Sesiones abiertas por el orden estricto (completaste todas las anteriores).
  const permitidas = new Set<string>();

  const abrirModal = (destino?: string) =>
    (window as any).abrirCursoLoginModal?.(destino);

  const cta = document.getElementById("curso-cta-inscribir");
  const nota = document.getElementById("curso-cta-nota");
  // A dónde lleva "continuar": la primera sesión sin completar.
  let destinoContinuar = `/cursos/${CURSO.slug}/${SESIONES[0].slug}`;

  document.querySelectorAll<HTMLAnchorElement>("a[data-sesion-link]").forEach((link) => {
    link.addEventListener("click", (e) => {
      const slug = link.dataset.sesion ?? "";
      // Sin suscripción: pedir login. Con suscripción pero sesión bloqueada
      // por el orden: no navegar (además la card tiene pointer-events:none).
      if (!desbloqueado) {
        e.preventDefault();
        abrirModal(link.href);
      } else if (!permitidas.has(slug)) {
        e.preventDefault();
      }
    });
  });

  cta?.addEventListener("click", () => {
    if (desbloqueado) {
      window.location.href = destinoContinuar;
    } else {
      abrirModal(destinoContinuar);
    }
  });

  // Con sesión guardada, verificar el acceso y pintar progreso + candados.
  if (haySesionCurso()) {
    verificarAccesoCurso(CURSO.slug).then((acceso) => {
      if (!acceso) return; // sesión vencida o error: se queda el gate
      if (!acceso.acceso) {
        if (nota)
          nota.textContent =
            "Tu cuenta todavía no tiene una suscripción activa. Elige un plan para desbloquear el curso.";
        return;
      }
      desbloqueado = true;

      const completadas = new Set(
        acceso.progreso.filter((p) => p.completado).map((p) => p.sesion),
      );
      // Índice de la primera sesión sin completar (= hasta dónde puede llegar);
      // si están todas, el curso está completo.
      let idxPrimeraIncompleta = SESIONES.findIndex((s) => !completadas.has(s.slug));
      if (idxPrimeraIncompleta === -1) idxPrimeraIncompleta = SESIONES.length;
      destinoContinuar = `/cursos/${CURSO.slug}/${
        SESIONES[Math.min(idxPrimeraIncompleta, SESIONES.length - 1)].slug
      }`;

      if (cta) cta.textContent = cta.dataset.inscritoLabel || "Continuar el curso →";
      if (nota)
        nota.textContent = acceso.curso_completado
          ? "¡Curso completado! Puedes volver a ver las sesiones cuando quieras."
          : "Las sesiones se desbloquean en orden. Tu avance se guarda solo.";

      SESIONES.forEach((s, i) => {
        const card = document.querySelector<HTMLElement>(`.sesion-card[data-sesion="${s.slug}"]`);
        const done = document.querySelector<HTMLElement>(`[data-done="${s.slug}"]`);
        const pend = document.querySelector<HTMLElement>(`[data-pend="${s.slug}"]`);
        const lock = card?.querySelector<HTMLElement>("[data-lock-icon]");
        if (completadas.has(s.slug) && done) done.hidden = false;

        // Desbloqueada si todas las anteriores están completas (i <= primera
        // incompleta). El resto queda con candado.
        if (i <= idxPrimeraIncompleta) {
          permitidas.add(s.slug);
        } else {
          card?.classList.add("locked");
          if (lock) lock.hidden = false;
          if (pend) pend.hidden = false;
        }
      });
    });
  }

  // Deep link (p. ej. redirigido desde una clase sin sesión). Se acepta el
  // viejo ?inscribete=1 por los correos ya enviados.
  const params = new URLSearchParams(window.location.search);
  if (params.has("login") || params.has("inscribete")) {
    abrirModal(destinoContinuar);
  }
</script>
