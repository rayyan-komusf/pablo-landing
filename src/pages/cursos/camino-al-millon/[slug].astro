---
import Layout from "../../../layouts/Layout.astro";
import Navbar from "../../../components/Navbar.astro";
import Footer from "../../../components/Footer.astro";
import { CURSO, SESIONES } from "../../../lib/cursos";

export function getStaticPaths() {
  return SESIONES.map((sesion) => ({ params: { slug: sesion.slug } }));
}

const { slug } = Astro.params;
const index = SESIONES.findIndex((s) => s.slug === slug);
const sesion = SESIONES[index];
if (!sesion) return Astro.redirect(`/cursos/${CURSO.slug}`);

const siguiente = SESIONES[index + 1] ?? null;
---

<Layout
  title={`${sesion.label}: ${sesion.nombre} — ${CURSO.title} — Pablo`}
  description={`${sesion.label} del programa ${CURSO.title}: ${sesion.nombre}. Curso gratuito de finanzas personales de Pablo.`}
>
  <Navbar />
  <main class="clase-page">
    <article class="container">
      <header class="clase-header">
        <a href={`/cursos/${CURSO.slug}`} class="clase-curso-link">🎓 {CURSO.title}</a>
        <h1>{sesion.label}: {sesion.nombre}</h1>
      </header>

      <!-- Oculto hasta confirmar el acceso con la edge function. El player lo
           CONSTRUYE la IFrame API sobre este div (no un iframe propio): así el
           comando seekTo se acepta y el bloqueo de adelantar funciona. -->
      <div class="clase-video" id="clase-video-wrap" hidden>
        <div id="clase-player" data-video-id={sesion.videoId}></div>
      </div>
      <p class="clase-progreso" id="clase-progreso" hidden></p>

      <div class="clase-desc">
        {sesion.parrafos.map((p) => <p>{p}</p>)}
      </div>

      <div class="clase-cta-wrap">
        {siguiente ? (
          <a
            href={`/cursos/${CURSO.slug}/${siguiente.slug}`}
            class="clase-siguiente"
            id="clase-siguiente"
            data-locked-label="Termina este video para continuar 🔒"
            data-unlocked-label={`Ir al siguiente video: ${siguiente.label} — ${siguiente.nombre} →`}
            aria-disabled="true"
          >
            Termina este video para continuar 🔒
          </a>
        ) : (
          <a
            href={`/cursos/${CURSO.slug}`}
            class="clase-siguiente"
            id="clase-siguiente"
            data-locked-label="Termina este video para completar el curso 🔒"
            data-unlocked-label="← Volver al curso"
            aria-disabled="true"
          >
            Termina este video para completar el curso 🔒
          </a>
        )}
      </div>

      <div class="clase-back">
        <a href={`/cursos/${CURSO.slug}`}>← Volver al curso</a>
      </div>
    </article>
  </main>
  <Footer />
</Layout>

<style>
  .clase-page {
    min-height: 100vh;
    background: var(--bg-page);
    padding-bottom: 120px;
  }

  .container {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 var(--gutter);
  }

  .clase-header {
    padding: clamp(24px, 5vw, 56px) 0 32px;
    text-align: center;
  }

  .clase-curso-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: #EAE8FF;
    color: var(--color-heading);
    font-size: 0.78rem;
    font-weight: 700;
    padding: 5px 14px;
    border-radius: 100px;
    margin-bottom: 18px;
    transition: transform 0.15s ease;
  }

  .clase-curso-link:hover {
    transform: scale(1.04);
  }

  .clase-header h1 {
    font-family: var(--font-heading);
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    color: var(--color-heading);
    line-height: 1.2;
  }

  /* El video es el protagonista de la página */
  .clase-video {
    aspect-ratio: 16/9;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: black;
    box-shadow: 0 4px 16px rgba(43, 44, 100, 0.15);
    margin-bottom: 48px;
  }

  .clase-video iframe {
    width: 100%;
    height: 100%;
    border: none;
    display: block;
  }

  .clase-video[hidden] {
    display: none;
  }

  /* Estado del avance bajo el video (se guarda solo / completada) */
  .clase-progreso {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin: -32px 0 48px;
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--color-secondary);
    background: #f1effb;
    padding: 6px 16px;
    border-radius: 100px;
  }

  .clase-progreso.completada {
    color: #2a7a52;
    background: #ebf9f0;
  }

  .clase-progreso[hidden] {
    display: none;
  }

  /* La carta de rodrigo */
  .clase-desc p {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--color-body);
    margin-bottom: 20px;
  }

  .clase-desc p:last-child {
    font-weight: 700;
    color: var(--color-heading);
  }

  /* CTA grande + hyperlink pequeño al siguiente video */
  .clase-cta-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 18px;
    margin-top: 48px;
  }

  .clase-cta {
    display: block;
    width: 100%;
    max-width: 340px;
    text-align: center;
    border-radius: 16px;
    padding: 16px 22px;
    font-weight: 800;
    font-size: 15px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    background: var(--color-ambar, #fba920);
    color: #2b2c64;
    box-shadow: 0 4px 0 0 #c9820a;
    transition: transform 0.12s ease, box-shadow 0.12s ease;
  }

  .clase-cta:hover {
    transform: translateY(-1px);
    box-shadow: 0 5px 0 0 #c9820a;
  }

  .clase-cta:active {
    transform: translateY(3px);
    box-shadow: 0 1px 0 0 #c9820a;
  }

  .clase-siguiente {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-body);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.15s, opacity 0.15s;
  }

  .clase-siguiente:hover {
    color: var(--color-heading);
  }

  /* Bloqueado hasta completar el video: no navega y se ve apagado. */
  .clase-siguiente[aria-disabled="true"] {
    color: var(--color-secondary);
    text-decoration: none;
    opacity: 0.6;
    cursor: not-allowed;
    pointer-events: none;
  }

  .clase-back {
    margin-top: 72px;
    padding-top: 32px;
    border-top: 1px solid rgba(43, 44, 100, 0.1);
  }

  .clase-back a {
    color: var(--color-body);
    font-weight: 500;
    transition: color 0.15s;
  }

  .clase-back a:hover {
    color: var(--color-heading);
  }
</style>

<script>
  import { CURSO, SESIONES } from "../../../lib/cursos";
  import {
    haySesionCurso,
    verificarAccesoCurso,
    reportarProgresoCurso,
  } from "../../../lib/cursoAcceso";

  // ── Gate: las clases requieren cuenta con suscripción activa ────────────
  const sesionSlug = window.location.pathname.split("/").filter(Boolean).pop() ?? "";
  const alLogin = () => window.location.replace(`/cursos/${CURSO.slug}?login=1`);

  const capture = (evento: string, props?: Record<string, unknown>) => {
    try {
      (window as any).posthog?.capture(evento, props);
    } catch {
      /* PostHog puede no estar cargado */
    }
  };

  if (!haySesionCurso()) {
    alLogin();
  } else {
    verificarAccesoCurso(CURSO.slug).then((acceso) => {
      if (!acceso?.acceso) {
        alLogin();
        return;
      }

      // Orden estricto: esta sesión solo se abre si TODAS las anteriores están
      // completas (aunque entren por URL directa). Si no, se les manda a la
      // primera sesión sin completar.
      const completadas = new Set(
        acceso.progreso.filter((p) => p.completado).map((p) => p.sesion),
      );
      const idxActual = SESIONES.findIndex((s) => s.slug === sesionSlug);
      let idxPrimeraIncompleta = SESIONES.findIndex((s) => !completadas.has(s.slug));
      if (idxPrimeraIncompleta === -1) idxPrimeraIncompleta = SESIONES.length;
      if (idxActual > idxPrimeraIncompleta) {
        const destino = SESIONES[Math.min(idxPrimeraIncompleta, SESIONES.length - 1)].slug;
        window.location.replace(`/cursos/${CURSO.slug}/${destino}`);
        return;
      }

      const previo = acceso.progreso.find((p) => p.sesion === sesionSlug);
      iniciarClase(acceso.plan, previo?.segundos_vistos ?? 0, Boolean(previo?.completado));
    });
  }

  // ── Player con progreso y anti-skip (YouTube IFrame API) ────────────────
  // Mientras la sesión no esté completada no se puede adelantar más allá de
  // lo ya visto (Rodrigo: nada de skipear los videos); completada la sesión,
  // el seek queda libre para repasar. El avance se reporta a curso-acceso
  // cada 15 s y al pausar/salir; completado = 90% del video visto o ended.
  function cargarYouTubeAPI(): Promise<any> {
    return new Promise((resolve) => {
      const w = window as any;
      if (w.YT?.Player) return resolve(w.YT);
      const previa = w.onYouTubeIframeAPIReady;
      w.onYouTubeIframeAPIReady = () => {
        previa?.();
        resolve(w.YT);
      };
      const tag = document.createElement("script");
      tag.src = "https://www.youtube.com/iframe_api";
      document.head.appendChild(tag);
    });
  }

  async function iniciarClase(plan: string | null, segundosPrevios: number, yaCompletada: boolean) {
    const wrap = document.getElementById("clase-video-wrap");
    const estadoEl = document.getElementById("clase-progreso");
    const divPlayer = document.getElementById("clase-player");
    const siguienteEl = document.getElementById("clase-siguiente");
    const videoId = divPlayer?.getAttribute("data-video-id") ?? "";
    if (wrap) wrap.hidden = false;

    const pintarEstado = (completada: boolean) => {
      if (!estadoEl) return;
      estadoEl.hidden = false;
      estadoEl.classList.toggle("completada", completada);
      estadoEl.textContent = completada
        ? "✓ Sesión completada"
        : "▶ Tu avance se guarda solo — no se puede adelantar el video";
    };

    // El enlace al siguiente video se desbloquea SOLO al completar la sesión.
    const desbloquearSiguiente = () => {
      if (!siguienteEl) return;
      siguienteEl.setAttribute("aria-disabled", "false");
      const label = siguienteEl.getAttribute("data-unlocked-label");
      if (label) siguienteEl.textContent = label;
    };

    pintarEstado(yaCompletada);
    if (yaCompletada) desbloquearSiguiente();

    const YT = await cargarYouTubeAPI();

    let maxVisto = Math.max(0, segundosPrevios);
    let completada = yaCompletada;
    let ultimoReporte = maxVisto;
    let ultimoEnvio = 0;
    let listo = false;

    const enviar = (marcarCompletada: boolean) => {
      if (!marcarCompletada && Math.floor(maxVisto) <= Math.floor(ultimoReporte)) return;
      ultimoReporte = maxVisto;
      reportarProgresoCurso(CURSO.slug, sesionSlug, maxVisto, marcarCompletada).then((r) => {
        if (!r) return;
        if (r.curso_completado && marcarCompletada) {
          capture("curso_completado", {
            curso: CURSO.slug,
            plan,
            $set: { curso_finanzas_completado: true },
          });
        }
      });
    };

    const completar = () => {
      if (completada) return;
      completada = true;
      pintarEstado(true);
      desbloquearSiguiente();
      enviar(true);
      capture("curso_sesion_completada", {
        curso: CURSO.slug,
        sesion: sesionSlug,
        plan,
        duracion_video: Math.floor(player?.getDuration?.() ?? 0),
      });
    };

    // Corrige un salto hacia adelante devolviendo el player a lo ya visto.
    // Se llama desde el poll Y desde onStateChange (cubre el seek en pausa).
    const frenarSalto = () => {
      if (completada || !listo) return false;
      const t = player.getCurrentTime?.() ?? 0;
      if (t > maxVisto + 2) {
        player.seekTo(maxVisto, true);
        return true;
      }
      return false;
    };

    // El player lo CREA la API sobre el div, con origin correcto: solo así
    // YouTube acepta el comando seekTo (con un iframe ajeno lo ignora, que era
    // la causa de que el bloqueo de adelantar no funcionara).
    const player = new YT.Player("clase-player", {
      videoId,
      host: "https://www.youtube.com",
      playerVars: {
        rel: 0,
        modestbranding: 1,
        playsinline: 1,
        disablekb: 1,
        origin: window.location.origin,
      },
      events: {
        onReady: () => {
          listo = true;
          // Reanudar donde se quedó (permitido: nunca pasa de lo ya visto).
          if (maxVisto > 5) player.seekTo(maxVisto, true);
        },
        onStateChange: (e: any) => {
          // 1 = playing, 2 = paused, 0 = ended
          if (e.data === 1) {
            // Al reanudar tras arrastrar la barra (incluso en pausa): frenar.
            frenarSalto();
          }
          if (e.data === 0) {
            maxVisto = Math.max(maxVisto, Math.floor(player.getDuration() || maxVisto));
            completar();
          }
          if (e.data === 2) enviar(false);
        },
      },
    });

    // Poll de 1 s: frena saltos hacia adelante, acumula lo visto y reporta
    // cada 15 s. Corre siempre que el player esté listo (no solo reproduciendo)
    // para atrapar también el arrastre de la barra en pausa.
    setInterval(() => {
      if (!listo || typeof player.getCurrentTime !== "function") return;
      if (frenarSalto()) return;

      const t = player.getCurrentTime() || 0;
      const duracion = player.getDuration() || 0;
      if (t > maxVisto) maxVisto = t;

      if (!completada && duracion > 0 && maxVisto >= duracion * 0.9) completar();

      const ahora = Date.now();
      if (ahora - ultimoEnvio >= 15_000) {
        ultimoEnvio = ahora;
        enviar(false);
      }
    }, 1000);

    // Último reporte al salir de la página (fetch keepalive en la lib).
    document.addEventListener("visibilitychange", () => {
      if (document.visibilityState === "hidden") enviar(false);
    });
    window.addEventListener("pagehide", () => enviar(false));

    capture("curso_sesion_iniciada", { curso: CURSO.slug, sesion: sesionSlug, plan });
  }
</script>
