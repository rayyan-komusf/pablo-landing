---
// Layout del onboarding interactivo (página /onboarding).
// Independiente de Layout.astro: el onboarding trae su propio CSS
// (public/onboarding/styles) y no comparte estilos con la landing.
import PostHogSnippet from "../components/PostHogSnippet.astro";
const base = "/onboarding";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"
    />
    <!-- SEO -->
    <title>Pablo · Tu asistente financiero</title>
    <meta
      name="description"
      content="Libérate del estrés financiero con Pablo, tu asistente de finanzas personales por WhatsApp."
    />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://usapablo.com/onboarding" />
    <!-- Open Graph -->
    <meta property="og:title" content="Pablo · Tu asistente financiero" />
    <meta
      property="og:description"
      content="Libérate del estrés financiero con Pablo, tu asistente de finanzas personales por WhatsApp."
    />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={`${base}/images/pablo/pablo-wave.png`} />
    <!-- Favicon -->
    <link rel="icon" type="image/png" href={`${base}/images/pablo/pablo-logo.png`} />
    <!-- Preconnect Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Estilos: base (reconstruido del deploy original) + overrides -->
    <link rel="stylesheet" href={`${base}/styles/base.css`} />
    <link rel="stylesheet" href={`${base}/styles/custom.css`} />
    <!-- PostHog (pageviews manuales: cada pantalla emite onboarding_screen_viewed) -->
    <PostHogSnippet capturePageview={false} />
  </head>
  <body>
    <div class="app-shell" id="appShell">
      <header class="topbar hidden" id="topbar" role="banner">
        <!-- Fila superior: X + Saltar -->
        <div class="w-full max-w-[560px] mx-auto flex items-center justify-between mt-6 px-2">
          <button
            class="btn-exit"
            onclick="pabloConfirmExit()"
            aria-label="Salir del onboarding"
            title="Salir"
          >
            ✕
          </button>
          <button
            class="btn-topbar-skip"
            id="topbarSkip"
            onclick="pabloSkip()"
            aria-label="Saltar este paso"
          >
            Saltar
          </button>
        </div>
        <!-- Fila inferior: ← + Pablo avatar + barra progreso -->
        <div class="w-full max-w-[560px] mx-auto flex items-center gap-2 px-1">
          <button
            class="btn-back"
            onclick="pabloPrev()"
            aria-label="Volver al paso anterior"
            title="Atrás"
          >
            ←
          </button>
          <div class="topbar__pablo" aria-hidden="true">
            <img
              src={`${base}/images/pablo/pablo-logo.png`}
              alt="Pablo"
              width="34"
              height="34"
              loading="eager"
            />
          </div>
          <div
            class="progress-track"
            role="progressbar"
            aria-valuemin="0"
            aria-valuemax="100"
            aria-valuenow="0"
            id="progressTrack"
          >
            <div class="progress-fill" id="progressFill"></div>
          </div>
        </div>
      </header>

      <slot />
    </div>

    <!-- Modal de confirmación de salida (pasos avanzados) -->
    <div
      id="exitModal"
      class="fixed inset-0 z-[110] hidden items-center justify-center"
      role="dialog"
      aria-modal="true"
      aria-label="Confirmar salida del onboarding"
    >
      <div
        class="exit-backdrop absolute inset-0 bg-[rgba(43,44,100,0.55)]"
        onclick="pabloCancelExit()"
      >
      </div>
      <div
        class="relative w-full max-w-[340px] bg-lila rounded-[28px] mx-4 px-6 pt-7 pb-6 flex flex-col gap-2 text-center"
      >
        <h3 class="font-display font-bold text-[20px] text-navy">¿Seguro que quieres salir?</h3>
        <p class="text-[14px] font-body text-navy-soft">
          Vas a perder tu progreso en el onboarding.
        </p>
        <div class="flex flex-col gap-3 mt-4">
          <button
            class="w-full py-[14px] rounded-[var(--radius-pill)] bg-white font-display font-bold text-[16px] text-navy shadow-soft transition-transform duration-200 [transition-timing-function:var(--ease-clay)] hover:-translate-y-0.5 active:translate-y-px"
            onclick="pabloCancelExit()"
          >
            Seguir aquí
          </button>
          <button
            class="btn-primary w-full text-[16px] py-[14px]"
            style="box-shadow: none"
            onclick="pabloDoExit()"
          >
            Salir
          </button>
        </div>
      </div>
    </div>

    <!-- Motor de navegación -->
    <script src="../scripts/onboarding.js"></script>
  </body>
</html>
