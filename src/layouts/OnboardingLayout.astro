---
// Layout del onboarding interactivo (página /onboarding).
// Independiente de Layout.astro: el onboarding trae su propio CSS
// (public/onboarding/styles) y no comparte estilos con la landing.
import PostHogSnippet from "../components/PostHogSnippet.astro";
const base = "/onboarding";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"
    />
    <!-- SEO -->
    <title>Pablo · Tu asistente financiero</title>
    <meta
      name="description"
      content="Libérate del estrés financiero con Pablo, tu asistente de finanzas personales por WhatsApp."
    />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://usapablo.com/onboarding" />
    <!-- Open Graph -->
    <meta property="og:title" content="Pablo · Tu asistente financiero" />
    <meta
      property="og:description"
      content="Libérate del estrés financiero con Pablo, tu asistente de finanzas personales por WhatsApp."
    />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={`${base}/images/pablo/pablo-wave.png`} />
    <!-- Favicon -->
    <link rel="icon" type="image/png" href={`${base}/images/pablo/pablo-logo.png`} />
    <!-- Preconnect Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Estilos: base (reconstruido del deploy original) + overrides.
         ?v= : cache-busting manual — subirlo al cambiar custom.css para que
         producción no sirva una versión cacheada con markup nuevo. -->
    <link rel="stylesheet" href={`${base}/styles/base.css`} />
    <link rel="stylesheet" href={`${base}/styles/custom.css?v=5`} />
    <!-- PostHog (pageviews manuales: cada pantalla emite onboarding_screen_viewed) -->
    <PostHogSnippet capturePageview={false} />
  </head>
  <body>
    <div class="app-shell" id="appShell">
      <header class="topbar hidden" id="topbar" role="banner">
        <!-- Una sola fila estilo Duolingo: ← (atrás/salir) + barra de progreso -->
        <div class="w-full max-w-[560px] mx-auto flex items-center gap-2 px-1 mt-4">
          <button
            class="btn-back"
            onclick="pabloPrev()"
            aria-label="Volver al paso anterior o salir"
            title="Atrás"
          >
            ←
          </button>
          <div
            class="progress-track"
            role="progressbar"
            aria-valuemin="0"
            aria-valuemax="100"
            aria-valuenow="0"
            id="progressTrack"
          >
            <div class="progress-fill" id="progressFill"></div>
          </div>
          <button
            class="btn-topbar-skip"
            id="topbarSkip"
            onclick="pabloSkip()"
            aria-label="Saltar este paso"
          >
            Saltar
          </button>
        </div>
      </header>

      <slot />
    </div>

    <!-- Motor de navegación -->
    <script src="../scripts/onboarding.js"></script>
  </body>
</html>
